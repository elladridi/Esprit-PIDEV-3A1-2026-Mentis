{% extends 'base.html.twig' %}

{% block title %}Edit Question - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="mb-4">
        <a href="{{ path('question_by_assessment', {assessmentId: question.assessment ? question.assessment.assessmentId : 0}) }}"
           class="text-decoration-none d-inline-flex align-items-center" style="color: #50C878;">
            <i class="fas fa-arrow-left me-2"></i> Back to Questions
        </a>
    </div>

    <div class="text-center mb-5" data-aos="fade-up">
        <h1 class="display-5 fw-bold mb-3" style="color: #2E7D32;">
            <i class="fas fa-edit me-2"></i>Edit Question
        </h1>
        <p class="lead text-muted">Update question details and settings</p>
    </div>

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show rounded-pill mb-4 d-flex align-items-center" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden" data-aos="fade-up" data-aos-delay="100">
                <div class="card-header text-white py-4 text-center"
                     style="background: linear-gradient(135deg, #50C878 0%, #2E7D32 100%);">
                    <h3 class="mb-0 fw-bold">
                        <i class="fas fa-question-circle me-2"></i>Edit Question #{{ question.questionId }}
                    </h3>
                </div>
                <div class="card-body p-5">

                    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

                    {# Assessment #}
                    <div class="mb-4">
                        <label class="form-label fw-bold mb-2" style="color: #2E7D32; font-size: 16px;">
                            <i class="fas fa-clipboard-list me-1"></i>
                            {{ form_label(form.assessment) }}
                        </label>
                        {{ form_widget(form.assessment) }}
                        {{ form_errors(form.assessment) }}
                        <small class="text-muted">Changing assessment will move this question</small>
                    </div>

                    {# Question Text #}
                    <div class="mb-4">
                        <label class="form-label fw-bold mb-2" style="color: #2E7D32; font-size: 16px;">
                            <i class="fas fa-heading me-1"></i>
                            {{ form_label(form.text) }} <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.text) }}
                        {{ form_errors(form.text) }}
                    </div>

