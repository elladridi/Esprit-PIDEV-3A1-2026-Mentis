{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard - Mentis{% endblock %}

{% block body %}
<div class="admin-dashboard">
    <div class="animated-bg"></div>

    <div class="container-lg py-4 position-relative">
        <!-- Welcome -->
        <div class="welcome-section mb-5">
            <div class="glass-panel p-4">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <div class="welcome-badge">
                            <span class="admin-rank">🎖️ MASTER ADMIN</span>
                            <h1 class="display-4 fw-bold mt-2">
                                Welcome back,
                                <span class="gradient-text">{{ user.firstname }}!</span>
                            </h1>
                            <p class="text-white-50 mb-3">
                                Empower minds, transform lives, and lead the wellness revolution.
                            </p>
                            <div class="admin-stats mt-3">
                                <div class="stat-chip">
                                    <i class="fas fa-calendar-alt"></i> {{ "now"|date("F j, Y") }}
                                </div>
                                <div class="stat-chip">
                                    <i class="fas fa-clock"></i> {{ "now"|date("g:i A") }}
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 text-center">
                        <div class="admin-avatar">
                            <div class="avatar-ring">
                                <div class="avatar-inner">
                                    <i class="fas fa-crown"></i>
                                </div>
                            </div>
                            <div class="avatar-status online"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- KPI -->
        <div class="kpi-grid mb-5">
            <div class="kpi-card" data-target="{{ stats.total_attempts|default(0) }}">
                <div class="kpi-icon bg-gradient-blue">
                    <i class="fas fa-sign-in-alt"></i>
                </div>
                <div class="kpi-info">
                    <h3 class="kpi-value counter" data-count="{{ stats.total_attempts|default(0) }}">0</h3>
                    <p class="kpi-label">Total Login Attempts</p>
                    <span class="trend up"><i class="fas fa-arrow-up"></i> +12%</span>
                </div>
                <div class="kpi-progress"><div class="progress-bar" style="width: 75%"></div></div>
            </div>

            <div class="kpi-card" data-target="{{ stats.failed_attempts|default(0) }}">
                <div class="kpi-icon bg-gradient-red">
                    <i class="fas fa-times-circle"></i>
                </div>
                <div class="kpi-info">
                    <h3 class="kpi-value counter" data-count="{{ stats.failed_attempts|default(0) }}">0</h3>
                    <p class="kpi-label">Failed Attempts</p>
                    <span class="trend down"><i class="fas fa-arrow-down"></i> -5%</span>
                </div>
                <div class="kpi-progress"><div class="progress-bar" style="width: 30%"></div></div>
            </div>

            <div class="kpi-card" data-target="{{ patients|length|default(0) }}">
                <div class="kpi-icon bg-gradient-green">
                    <i class="fas fa-users"></i>
                </div>
                <div class="kpi-info">
                    <h3 class="kpi-value counter" data-count="{{ patients|length|default(0) }}">0</h3>
                    <p class="kpi-label">Active Patients</p>
                    <span class="trend up"><i class="fas fa-arrow-up"></i> +8%</span>
                </div>
                <div class="kpi-progress"><div class="progress-bar" style="width: 85%"></div></div>
            </div>

            <div class="kpi-card" data-target="{{ bannedUsers|default([])|length }}">
                <div class="kpi-icon bg-gradient-orange">
                    <i class="fas fa-ban"></i>
                </div>
                <div class="kpi-info">
                    <h3 class="kpi-value counter" data-count="{{ bannedUsers|default([])|length }}">0</h3>
                    <p class="kpi-label">Banned Users</p>
                    <span class="trend down"><i class="fas fa-arrow-down"></i> -2%</span>
                </div>
                <div class="kpi-progress"><div class="progress-bar" style="width: 15%"></div></div>
            </div>
        </div>

        <!-- Security -->
        <div class="security-card mb-3">
            <div class="security-card-inner">
                <div class="row align-items-center">
                    <div class="col-md-7">
                        <div class="security-content">
                            <div class="security-badge">
                                <i class="fas fa-shield-alt"></i> REAL-TIME PROTECTION
                            </div>
                            <h2 class="text-white mt-3 mb-2">Security Command Center</h2>
                            <p class="text-white-70">
                                Monitor suspicious activities, analyze login patterns, and manage user bans in real-time.
                            </p>
                            <div class="security-features mt-3">
                                <span><i class="fas fa-check-circle"></i> Threat Detection</span>
                                <span><i class="fas fa-check-circle"></i> Login Analytics</span>
                                <span><i class="fas fa-check-circle"></i> Auto-ban System</span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-5 text-center">
                        <div class="security-stats">
                            <div class="stat-circle">
                                <div class="circle-value">{{ stats.failed_attempts|default(0) }}</div>
                                <div class="circle-label">Threats Blocked</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="security-particles"></div>
            </div>
        </div>

        <div class="text-center mb-5">
            <a href="{{ path('admin_security_dashboard') }}" class="btn-security btn-large">
                Launch Security Dashboard <i class="fas fa-arrow-right"></i>
                <div class="btn-shine"></div>
            </a>
        </div>

        <!-- Patients -->
        <div class="section-card mb-4">
            <div class="section-header">
                <div class="header-left">
                    <div class="header-icon">
                        <i class="fas fa-heartbeat"></i>
                    </div>
                    <div>
                        <h3 class="mb-0">Patient Wellness Hub</h3>
                        <p class="text-muted small mb-0">Manage and monitor patient progress</p>
                    </div>
                </div>
                <div class="header-right">
                    <a href="{{ path('app_admin_patient_new') }}" class="btn-primary-modern">
                        <i class="fas fa-plus-circle"></i> New Patient
                    </a>
                </div>
            </div>

            <div class="filters-panel">
                <div class="filter-group">
                    <i class="fas fa-search"></i>
                    <input type="text" id="patientSearch" placeholder="Search patients..." class="filter-input">
                </div>
                <div class="filter-group">
                    <i class="fas fa-venus-mars"></i>
                    <select id="patientGenderFilter" class="filter-select">
                        <option value="">All Genders</option>
                        <option value="male">👨 Male</option>
                        <option value="female">👩 Female</option>
                        <option value="other">👤 Other</option>
                    </select>
                </div>
                <div class="filter-group">
                    <i class="fas fa-chart-line"></i>
                    <select id="patientAgeFilter" class="filter-select">
                        <option value="">All Ages</option>
                        <option value="0-18">0-18 years</option>
                        <option value="19-30">19-30 years</option>
                        <option value="31-45">31-45 years</option>
                        <option value="46-60">46-60 years</option>
                        <option value="60+">60+ years</option>
                    </select>
                </div>
                <button onclick="resetPatientFilters()" class="btn-reset">
                    <i class="fas fa-sync-alt"></i> Reset
                </button>
            </div>

            <div class="stats-grid-modern" id="patientStats">
                <div class="stat-card">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-details">
                        <span class="stat-label">Total Patients</span>
                        <h4 class="stat-number" id="patientTotal">0</h4>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #f093fb, #f5576c);">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div class="stat-details">
                        <span class="stat-label">Average Age</span>
                        <h4 class="stat-number" id="patientAvgAge">0</h4>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #4facfe, #00f2fe);">
                        <i class="fas fa-chart-bar"></i>
                    </div>
                    <div class="stat-details">
                        <span class="stat-label">Age Range</span>
                        <h4 class="stat-number" id="patientAgeRange">0-0</h4>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #43e97b, #38f9d7);">
                        <i class="fas fa-venus-mars"></i>
                    </div>
                    <div class="stat-details">
                        <span class="stat-label">Gender Ratio</span>
                        <h4 class="stat-number" id="patientGenderRatio">👨 0 | 👩 0</h4>
                    </div>
                </div>
            </div>

            <div class="chart-container">
                <canvas id="patientAgeChart" height="100"></canvas>
            </div>

            <div class="table-container">
                <div class="table-responsive">
                    <table class="modern-table">
                        <thead>
                            <tr>
                                <th onclick="sortPatients('id')">ID <i class="fas fa-sort"></i></th>
                                <th onclick="sortPatients('firstname')">Patient <i class="fas fa-sort"></i></th>
                                <th onclick="sortPatients('email')">Contact <i class="fas fa-sort"></i></th>
                                <th onclick="sortPatients('createdAt')">Registered <i class="fas fa-sort"></i></th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="patientsTableBody">
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <div class="loader"></div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div id="patientPagination" class="pagination-modern"></div>
            </div>
        </div>

        <!-- Psychologists -->
        <div class="section-card mb-4 psychologist-section-card">
            <div class="section-header psychologist-header">
                <div class="header-left">
                    <div class="header-icon psychologist-icon">
                        <i class="fas fa-brain"></i>
                    </div>
                    <div>
                        <h3 class="mb-0">Psychology Experts</h3>
                        <p class="text-muted small mb-0">Manage mental health professionals with a richer specialist view</p>
                    </div>
                </div>
                <div class="header-right">
                    <a href="{{ path('app_admin_psychologist_new') }}" class="btn-primary-modern psychologist-btn">
                        <i class="fas fa-user-md"></i> Add Psychologist
                    </a>
                </div>
            </div>

            <div class="filters-panel">
                <div class="filter-group">
                    <i class="fas fa-search"></i>
                    <input type="text" id="psychologistSearch" placeholder="Search psychologists, email, specialty..." class="filter-input">
                </div>
                <div class="filter-group">
                    <i class="fas fa-venus-mars"></i>
                    <select id="psychologistGenderFilter" class="filter-select">
                        <option value="">All Genders</option>
                        <option value="male">👨 Male</option>
                        <option value="female">👩 Female</option>
                        <option value="other">👤 Other</option>
                    </select>
                </div>
                <button onclick="resetPsychologistFilters()" class="btn-reset">
                    <i class="fas fa-sync-alt"></i> Reset
                </button>
            </div>

            <div class="expert-stats-grid" id="psychologistStats">
                <div class="expert-stat-card">
                    <span class="expert-stat-label">Total Experts</span>
                    <strong id="psychologistTotal">0</strong>
                </div>
                <div class="expert-stat-card">
                    <span class="expert-stat-label">Active</span>
                    <strong id="psychologistActive">0</strong>
                </div>
                <div class="expert-stat-card">
                    <span class="expert-stat-label">Banned</span>
                    <strong id="psychologistBanned">0</strong>
                </div>
                <div class="expert-stat-card">
                    <span class="expert-stat-label">Recently Joined</span>
                    <strong id="psychologistRecent">0</strong>
                </div>
            </div>

            <div class="table-container">
                <div class="table-responsive">
                    <table class="modern-table modern-table-psychologists">
                        <thead>
                            <tr>
                                <th onclick="sortPsychologists('id')">ID <i class="fas fa-sort"></i></th>
                                <th onclick="sortPsychologists('firstname')">Psychologist <i class="fas fa-sort"></i></th>
                                <th>Professional Snapshot</th>
                                <th onclick="sortPsychologists('email')">Contact <i class="fas fa-sort"></i></th>
                                <th onclick="sortPsychologists('createdAt')">Joined <i class="fas fa-sort"></i></th>
                                <th>Availability</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="psychologistsTableBody">
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <div class="loader"></div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div id="psychologistPagination" class="pagination-modern"></div>
            </div>
        </div>

        <!-- Logs -->
        <div class="section-card">
            <div class="section-header">
                <div class="header-left">
                    <div class="header-icon" style="background: linear-gradient(135deg, #fa709a, #fee140);">
                        <i class="fas fa-history"></i>
                    </div>
                    <div>
                        <h3 class="mb-0">Activity Timeline</h3>
                        <p class="text-muted small mb-0">Recent content access history</p>
                    </div>
                </div>
                <div class="header-right">
                    <div class="btn-group-modern">
                        <a href="{{ path('app_admin_logs_pdf') }}" class="btn-outline-modern">
                            <i class="fas fa-file-pdf"></i> PDF
                        </a>
                        <a href="{{ path('app_admin_logs_excel') }}" class="btn-outline-modern">
                            <i class="fas fa-file-excel"></i> CSV
                        </a>
                    </div>
                </div>
            </div>

            <div class="timeline-modern">
                {% for log in logs %}
                    <div class="timeline-item">
                        <div class="timeline-badge">
                            <i class="fas fa-eye"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <strong class="timeline-title">{{ log.user.firstname }} {{ log.user.lastname }}</strong>
                                <span class="timeline-date">{{ log.accessedAt|date('M d, Y H:i') }}</span>
                            </div>
                            <div class="timeline-body">
                                <span class="badge-modern">{{ log.contentNode.title }}</span>
                                <span class="email-badge">{{ log.user.email }}</span>
                            </div>
                            <div class="timeline-footer">
                                <form method="post" action="{{ path('app_admin_log_delete', {id: log.id}) }}" style="display: inline-block;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_log' ~ log.id) }}">
                                    <button class="btn-icon" onclick="return confirm('Delete this log entry?')">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="empty-state">
                        <i class="fas fa-inbox"></i>
                        <p>No activity logs found</p>
                    </div>
                {% endfor %}
            </div>

            <div class="d-flex justify-content-center pt-3">
                {{ knp_pagination_render(logs) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0/dist/chartjs-plugin-datalabels.min.js"></script>

<script>
    let patientChart = null;
    let currentPatientSort = 'id';
    let currentPatientOrder = 'DESC';
    let currentPsychologistSort = 'id';
    let currentPsychologistOrder = 'DESC';
    let currentPatientPage = 1;
    let currentPsychologistPage = 1;
    const ITEMS_PER_PAGE = 8;

    document.addEventListener('DOMContentLoaded', function () {
        animateCounters();
        loadPatients(1);
        loadPsychologists(1);
        createParticles();

        const patientSearch = document.getElementById('patientSearch');
        const patientGender = document.getElementById('patientGenderFilter');
        const patientAge = document.getElementById('patientAgeFilter');
        const psychologistSearch = document.getElementById('psychologistSearch');
        const psychologistGender = document.getElementById('psychologistGenderFilter');

        if (patientSearch) patientSearch.addEventListener('input', debounce(() => loadPatients(1), 500));
        if (patientGender) patientGender.addEventListener('change', () => loadPatients(1));
        if (patientAge) patientAge.addEventListener('change', () => loadPatients(1));

        if (psychologistSearch) psychologistSearch.addEventListener('input', debounce(() => loadPsychologists(1), 500));
        if (psychologistGender) psychologistGender.addEventListener('change', () => loadPsychologists(1));
    });

    function animateCounters() {
        const counters = document.querySelectorAll('.counter');
        counters.forEach(counter => {
            const target = parseInt(counter.getAttribute('data-count')) || 0;
            let current = 0;
            const increment = target / 50 || 1;

            const updateCounter = () => {
                if (current < target) {
                    current += increment;
                    counter.innerText = Math.ceil(current);
                    setTimeout(updateCounter, 20);
                } else {
                    counter.innerText = target;
                }
            };

            updateCounter();
        });
    }

    function createParticles() {
        const container = document.querySelector('.security-particles');
        if (!container) return;

        for (let i = 0; i < 50; i++) {
            const particle = document.createElement('div');
            particle.classList.add('particle');
            particle.style.left = Math.random() * 100 + '%';
            particle.style.animationDelay = Math.random() * 5 + 's';
            particle.style.animationDuration = (3 + Math.random() * 4) + 's';
            container.appendChild(particle);
        }
    }

    function debounce(func, delay) {
        let timeout;
        return function () {
            clearTimeout(timeout);
            timeout = setTimeout(() => func.apply(this, arguments), delay);
        };
    }

    function loadPatients(page) {
        page = page || 1;
        currentPatientPage = page;

        const search = document.getElementById('patientSearch')?.value || '';
        const gender = document.getElementById('patientGenderFilter')?.value || '';
        const ageGroup = document.getElementById('patientAgeFilter')?.value || '';

        fetch(`/dashboard/admin/patients/data?search=${encodeURIComponent(search)}&sortField=${currentPatientSort}&sortOrder=${currentPatientOrder}&gender=${encodeURIComponent(gender)}&ageGroup=${encodeURIComponent(ageGroup)}&page=${page}&limit=${ITEMS_PER_PAGE}`)
            .then(r => r.json())
            .then(data => {
                updatePatientsTable(data.patients);
                if (data.stats) {
                    updatePatientStats(data.stats);
                    updatePatientChart(data.stats.ageGroups);
                }
                renderPagination('patientPagination', data.totalPages, data.currentPage, 'loadPatients');
            })
            .catch(err => console.error('Patients error:', err));
    }

    function loadPsychologists(page) {
        page = page || 1;
        currentPsychologistPage = page;

        const search = document.getElementById('psychologistSearch')?.value || '';
        const gender = document.getElementById('psychologistGenderFilter')?.value || '';

        fetch(`/dashboard/admin/psychologists/data?search=${encodeURIComponent(search)}&sortField=${currentPsychologistSort}&sortOrder=${currentPsychologistOrder}&gender=${encodeURIComponent(gender)}&page=${page}&limit=${ITEMS_PER_PAGE}`)
            .then(r => r.json())
            .then(data => {
                updatePsychologistsTable(data.psychologists || []);
                updatePsychologistStats(data.psychologists || [], data);
                renderPagination('psychologistPagination', data.totalPages, data.currentPage, 'loadPsychologists');
            })
            .catch(err => console.error('Psychologists error:', err));
    }

    function renderPagination(containerId, totalPages, currentPage, fnName) {
        const container = document.getElementById(containerId);
        if (!container || !totalPages || totalPages <= 1) {
            if (container) container.innerHTML = '';
            return;
        }

        let html = '<div class="pagination-wrapper"><ul class="pagination-list">';

        html += `<li class="page-item ${currentPage <= 1 ? 'disabled' : ''}">
            <a href="#" onclick="event.preventDefault(); if (${currentPage} > 1) ${fnName}(${currentPage - 1})">
                <i class="fas fa-chevron-left"></i>
            </a>
        </li>`;

        for (let i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                    <a href="#" onclick="event.preventDefault(); ${fnName}(${i})">${i}</a>
                </li>`;
            } else if (i === currentPage - 2 || i === currentPage + 2) {
                html += `<li class="page-item dots"><span>...</span></li>`;
            }
        }

        html += `<li class="page-item ${currentPage >= totalPages ? 'disabled' : ''}">
            <a href="#" onclick="event.preventDefault(); if (${currentPage} < ${totalPages}) ${fnName}(${currentPage + 1})">
                <i class="fas fa-chevron-right"></i>
            </a>
        </li>`;

        html += '</ul></div>';
        container.innerHTML = html;
    }

    function updatePatientsTable(patients) {
        const tbody = document.getElementById('patientsTableBody');
        if (!tbody) return;

        if (!patients || patients.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <div class="empty-state-small">
                            <i class="fas fa-user-friends"></i>
                            <p>No patients found</p>
                        </div>
                    </td>
                </tr>
            `;
            return;
        }

        tbody.innerHTML = patients.map(patient => `
            <tr>
                <td><span class="id-badge">#${patient.id}</span></td>

                <tr>
                    <div class="user-info">
                        <div class="user-avatar" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                            ${getInitials(patient.firstname, patient.lastname)}
                        </div>
                        <div class="user-details">
                            <strong>${escapeHtml(patient.firstname)} ${escapeHtml(patient.lastname)}</strong>
                            <small>Patient profile</small>
                        </div>
                    </div>
                </td>

                <td>
                    <div class="contact-info">
                        <div><i class="fas fa-envelope"></i> ${escapeHtml(patient.email || 'N/A')}</div>
                        <div><i class="fas fa-phone"></i> ${escapeHtml(patient.phone || 'N/A')}</div>
                    </div>
                </td>

                <td>${patient.createdAt ? formatDate(patient.createdAt) : 'N/A'}</td>

                <td>
                    ${patient.isBanned
                        ? '<span class="status-badge banned">Banned</span>'
                        : '<span class="status-badge active">Active</span>'}
                </td>

                <td>
                    <div class="action-group">
                        <a href="/dashboard/admin/user/${patient.id}/edit" class="action-btn edit" title="Edit">
                            <i class="fas fa-edit"></i>
                        </a>
                        <form method="post" action="/dashboard/admin/user/${patient.id}/delete" style="display:inline-block;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete') }}">
                            <button type="submit" class="action-btn delete" onclick="return confirm('Delete this patient?')" title="Delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </td>
            </tr>
        `).join('');
    }

    function updatePsychologistsTable(psychologists) {
        const tbody = document.getElementById('psychologistsTableBody');
        if (!tbody) return;

        if (!psychologists || psychologists.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="8" class="text-center py-5">
                        <div class="empty-state-small">
                            <i class="fas fa-user-md"></i>
                            <p>No psychologists found</p>
                        </div>
                    </td>
                </tr>
            `;
            return;
        }

        tbody.innerHTML = psychologists.map(psych => {
            const fullName = `${escapeHtml(psych.firstname || '')} ${escapeHtml(psych.lastname || '')}`.trim();
            const specialty = escapeHtml(psych.specialization || psych.specialty || psych.domain || 'General Psychology');
            const license = escapeHtml(psych.license || psych.registrationNumber || 'Not provided');
            const availability = psych.isBanned
                ? '<span class="availability-badge unavailable"><i class="fas fa-user-slash"></i> Unavailable</span>'
                : '<span class="availability-badge available"><i class="fas fa-check-circle"></i> Accepting</span>';

