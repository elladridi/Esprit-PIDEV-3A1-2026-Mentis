                    <td>
                        <div class="contact-info contact-info-vertical">
                            <div><i class="fas fa-envelope"></i> ${escapeHtml(psych.email || 'N/A')}</div>
                            <div><i class="fas fa-phone"></i> ${escapeHtml(psych.phone || 'N/A')}</div>
                        </div>
                    </td>

                    <td>
                        <div class="joined-cell">
                            <strong>${psych.createdAt ? formatDate(psych.createdAt) : 'N/A'}</strong>
                            <small>${psych.createdAt ? getRelativeDate(psych.createdAt) : ''}</small>
                        </div>
                    </td>

                    <td>${availability}</td>

                    <td>
                        ${psych.isBanned
