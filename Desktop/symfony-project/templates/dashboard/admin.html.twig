                    <td>
                        <div class="expert-profile">
                            <div class="expert-avatar">
                                ${getInitials(psych.firstname, psych.lastname)}
                            </div>
                            <div class="expert-details">
                                <strong>${fullName || 'Unnamed Psychologist'}</strong>
                                <div class="expert-subline">${specialty}</div>
