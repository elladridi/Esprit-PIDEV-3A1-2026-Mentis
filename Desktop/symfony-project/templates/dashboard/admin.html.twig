    function updatePatientStats(stats) {
        const el = (id) => document.getElementById(id);
        if (el('patientTotal')) el('patientTotal').innerText = stats.total || 0;
        if (el('patientAvgAge')) el('patientAvgAge').innerText = stats.averageAge || 0;
        if (el('patientAgeRange')) el('patientAgeRange').innerHTML = `${stats.minAge || 0} - ${stats.maxAge || 0}`;
        if (el('patientGenderRatio')) el('patientGenderRatio').innerHTML = `👨 ${stats.gender?.male || 0} | 👩 ${stats.gender?.female || 0}`;
    }

    function updatePsychologistStats(psychologists, data) {
        const total = data.totalItems || psychologists.length || 0;
        const banned = psychologists.filter(p => !!p.isBanned).length;
        const active = psychologists.filter(p => !p.isBanned).length;

        const now = new Date();
        const recent = psychologists.filter(p => {
            if (!p.createdAt) return false;
            const created = new Date(p.createdAt);
            const diff = (now - created) / (1000 * 60 * 60 * 24);
            return diff <= 30;
        }).length;

        setText('psychologistTotal', total);
        setText('psychologistActive', active);
        setText('psychologistBanned', banned);
        setText('psychologistRecent', recent);
    }

    function updatePatientChart(ageGroups) {
        if (!ageGroups) return;
        const ctx = document.getElementById('patientAgeChart')?.getContext('2d');
        if (!ctx) return;

        if (patientChart) patientChart.destroy();

        patientChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['0-18', '19-30', '31-45', '46-60', '60+'],
                datasets: [{
                    label: 'Number of Patients',
                    data: [
                        ageGroups['0-18'] || 0,
                        ageGroups['19-30'] || 0,
                        ageGroups['31-45'] || 0,
                        ageGroups['46-60'] || 0,
                        ageGroups['60+'] || 0
                    ],
                    backgroundColor: ['#667eea', '#f093fb', '#4facfe', '#43e97b', '#fa709a'],
                    borderRadius: 10,
                    barPercentage: 0.7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'top',
                        labels: { usePointStyle: true, boxWidth: 10 }
                    },
                    tooltip: {
                        backgroundColor: '#1a1a2e',
                        titleColor: '#50C878'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#e9ecef' },
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });
    }

    function sortPatients(column) {
        if (currentPatientSort === column) {
            currentPatientOrder = currentPatientOrder === 'ASC' ? 'DESC' : 'ASC';
        } else {
            currentPatientSort = column;
            currentPatientOrder = 'ASC';
        }
        loadPatients(1);
    }

    function sortPsychologists(column) {
        if (currentPsychologistSort === column) {
            currentPsychologistOrder = currentPsychologistOrder === 'ASC' ? 'DESC' : 'ASC';
        } else {
            currentPsychologistSort = column;
            currentPsychologistOrder = 'ASC';
        }
        loadPsychologists(1);
    }

    function resetPatientFilters() {
        document.getElementById('patientSearch').value = '';
        document.getElementById('patientGenderFilter').value = '';
        document.getElementById('patientAgeFilter').value = '';
        currentPatientSort = 'id';
        currentPatientOrder = 'DESC';
        loadPatients(1);
    }

    function resetPsychologistFilters() {
        document.getElementById('psychologistSearch').value = '';
        document.getElementById('psychologistGenderFilter').value = '';
        currentPsychologistSort = 'id';
        currentPsychologistOrder = 'DESC';
        loadPsychologists(1);
    }

    function formatDate(dateStr) {
        const date = new Date(dateStr);
        return date.toLocaleDateString('en-US', {
            month: 'short',
            day: 'numeric',
            year: 'numeric'
        });
    }

    function formatDateShort(dateStr) {
        const date = new Date(dateStr);
        return date.toLocaleDateString('en-US', {
            month: 'short',
            year: 'numeric'
        });
    }

    function getRelativeDate(dateStr) {
        const date = new Date(dateStr);
        const now = new Date();
        const diffDays = Math.floor((now - date) / (1000 * 60 * 60 * 24));

        if (diffDays <= 0) return 'Today';
        if (diffDays === 1) return '1 day ago';
        if (diffDays < 30) return `${diffDays} days ago`;

        const diffMonths = Math.floor(diffDays / 30);
        if (diffMonths === 1) return '1 month ago';
        return `${diffMonths} months ago`;
    }

    function getInitials(firstname, lastname) {
        const first = (firstname || '').trim().charAt(0);
        const last = (lastname || '').trim().charAt(0);
        return `${first}${last}`.toUpperCase() || 'NA';
    }

    function setText(id, value) {
        const el = document.getElementById(id);
        if (el) el.innerText = value;
    }

    function escapeHtml(str) {
        if (!str) return '';
        return String(str).replace(/[&<>]/g, function (m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    window.sortPatients = sortPatients;
    window.sortPsychologists = sortPsychologists;
    window.resetPatientFilters = resetPatientFilters;
    window.resetPsychologistFilters = resetPsychologistFilters;
    window.loadPatients = loadPatients;
    window.loadPsychologists = loadPsychologists;
</script>

