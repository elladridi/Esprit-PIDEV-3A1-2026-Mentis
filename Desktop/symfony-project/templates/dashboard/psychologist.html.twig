    border-radius: 12px;
    font-weight: 700;
}

.btn-primary-custom {
    background: linear-gradient(135deg, var(--primary) 0%, #3A9B5E 100%);
    border: none;
    border-radius: 14px;
    font-weight: 700;
    transition: transform 0.3s, box-shadow 0.3s;
    color: white;
    box-shadow: 0 10px 24px rgba(80,200,120,0.18);
}

.btn-primary-custom:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 28px rgba(80,200,120,0.28);
    color: white;
}

/* Filters */
.filter-bar {
    background: linear-gradient(135deg, #fbfffc, #f8fbff);
    border: 1px solid #edf2f7;
    border-radius: 18px;
    padding: 16px;
    margin-bottom: 16px;
}

/* Modern table */
.modern-table {
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 0;
}

.modern-table thead {
    background: #f8fafc;
}

.modern-table thead th {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #64748b;
    border-bottom: 1px solid #e5edf5;
    padding: 14px 16px;
    font-weight: 800;
    white-space: nowrap;
}

.modern-table tbody td {
    padding: 14px 16px;
    vertical-align: middle;
    border-color: #eef2f7;
}

.modern-table tbody tr {
    transition: all 0.2s ease;
}

.modern-table tbody tr:hover {
    background: #f5fff8;
    transform: scale(1.003);
}

.patient-cell {
    display: flex;
    align-items: center;
    gap: 12px;
}

.patient-avatar {
    width: 42px;
    height: 42px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
