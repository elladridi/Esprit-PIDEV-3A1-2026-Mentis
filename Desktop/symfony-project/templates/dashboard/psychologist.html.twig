    font-size: 12px;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    gap: 6px;
}

.risk-pill.low,
.risk-pill.minimal {
    background: #d4edda;
    color: #155724;
}

.risk-pill.mild,
.risk-pill.moderate {
    background: #fff3cd;
    color: #856404;
}

.risk-pill.high {
    background: #f8d7da;
    color: #721c24;
}

.risk-pill.severe {
    background: var(--danger);
    color: white;
}

.session-pill {
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 800;
}

.session-pill.yes {
    background: #ffe2e2;
    color: #b42318;
}

.session-pill.no {
    background: #eef2f7;
    color: #475569;
}

/* Empty states */
.empty-state-box {
    text-align: center;
    padding: 52px 16px;
    color: #94a3b8;
}

.empty-state-box i {
    font-size: 48px;
    margin-bottom: 12px;
    display: block;
}

