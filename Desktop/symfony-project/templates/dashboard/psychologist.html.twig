.card {
    border-radius: 22px;
    border: 1px solid #edf2f7;
    box-shadow: var(--shadow-soft);
    overflow: hidden;
}

.card-header.bg-white {
    background: linear-gradient(135deg, #fcfffd, #f8fbff) !important;
    border-bottom: 1px solid #edf2f7;
    padding: 18px 20px;
}

.card-header h5 {
    margin: 0;
    font-weight: 800;
    color: var(--dark);
}

.card-body {
    padding: 20px;
}

