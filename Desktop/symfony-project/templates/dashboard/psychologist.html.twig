                </div>
            </div>
            <div class="p-3 text-center border-top">
                <button class="btn btn-sm btn-outline-danger rounded-pill px-3" id="markAllReadBtn" onclick="markAllAlertsRead()">
                    <i class="fas fa-check-double me-1"></i> Mark all as read
                </button>
