@media (max-width: 992px) {
    .hero-panel {
        padding: 26px 22px;
    }

    .hero-orb {
        width: 180px;
        height: 180px;
    }

    .hero-orb-value {
        font-size: 42px;
    }

    .profile-grid {
        grid-template-columns: 1fr;
    }
}

