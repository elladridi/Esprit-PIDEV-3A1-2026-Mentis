            <button id="captureFaceBtn" class="btn btn-primary-custom px-4" disabled>
                📸 Capture Sample 1 of 3
            </button>
            <button id="closeFaceModalBtn" class="btn btn-secondary px-4 ms-2">
                <i class="fas fa-times me-2"></i> Cancel
            </button>
        </div>
    </div>
</div>

<script>
// ============================================
// CRISIS ALERT SYSTEM
// ============================================

// CSRF Token helper
let csrfToken = '';
const csrfMeta = document.querySelector('meta[name="csrf-token"]');
if (csrfMeta) {
    csrfToken = csrfMeta.getAttribute('content');
}

let pollInterval = null;
let lastUnreadCount = 0;

// Play alert sound
function playCrisisAlertSound() {
    try {
        const audioContext = new (window.AudioContext || window.webkitAudioContext)();
        const oscillator = audioContext.createOscillator();
        const gainNode = audioContext.createGain();

        oscillator.connect(gainNode);
        gainNode.connect(audioContext.destination);

        oscillator.frequency.value = 500;
        gainNode.gain.value = 0.2;

        oscillator.start();

        setTimeout(() => {
            oscillator.stop();
            audioContext.close();
        }, 500);

        if (navigator.vibrate) {
            navigator.vibrate(300);
        }
    } catch(e) {
        console.log('Audio not supported');
    }
}

// Show floating notification
function showFloatingCrisisAlert(alertCount) {
    const existing = document.querySelector('.floating-crisis-alert');
    if (existing) existing.remove();

    const floatingDiv = document.createElement('div');
    floatingDiv.className = 'floating-crisis-alert';
    floatingDiv.onclick = function() {
        toggleCrisisPanel();
        this.remove();
    };

    floatingDiv.innerHTML = `
        <i class="fas fa-exclamation-triangle"></i>
        <div class="alert-content">
            <div class="alert-title">⚠️ HIGH RISK ALERT</div>
            <div class="alert-message">${alertCount} new high-risk patient assessment${alertCount > 1 ? 's' : ''} detected</div>
        </div>
        <i class="fas fa-chevron-right"></i>
    `;

    document.body.appendChild(floatingDiv);

    setTimeout(() => {
        if (floatingDiv.parentNode) floatingDiv.remove();
    }, 5000);
}

function toggleCrisisPanel() {
    const panel = document.getElementById('crisisPanel');
    panel.classList.toggle('show');
    if (panel.classList.contains('show')) {
        loadCrisisAlerts();
    }
}

async function loadCrisisAlerts() {
    try {
        const response = await fetch('{{ path('crisis_alerts_list') }}');
        const data = await response.json();

        renderAlertList(data.alerts);
        updateBellBadge(data.unreadCount);
    } catch (error) {
        console.error('Failed to load alerts:', error);
        document.getElementById('crisisAlertList').innerHTML = `
            <div class="empty-alerts">
                <i class="fas fa-exclamation-triangle fa-2x mb-2 d-block"></i>
                Failed to load alerts
            </div>
        `;
    }
}

function renderAlertList(alerts) {
    const container = document.getElementById('crisisAlertList');

    if (!alerts || alerts.length === 0) {
        container.innerHTML = `
            <div class="empty-alerts">
                <i class="fas fa-check-circle fa-2x mb-2 d-block" style="color: #50C878;"></i>
                No crisis alerts
                <div style="font-size: 12px; margin-top: 8px;">When patients submit high-risk assessments, they'll appear here</div>
            </div>
        `;
        return;
    }

    container.innerHTML = alerts.map(alert => `
        <div class="crisis-alert-item ${alert.is_seen ? 'read' : 'unread'}"
             onclick="viewPatientResult(${alert.id}, ${alert.patient_id})">
            <div>
                <span class="patient-name">
                    <i class="fas fa-user-circle me-1"></i>${escapeHtml(alert.patient_name)}
                </span>
                <span class="risk-badge">
                    <i class="fas fa-exclamation-triangle me-1"></i>${escapeHtml(alert.risk_level)}
                </span>
                ${!alert.is_seen ? '<span class="new-alert-badge">NEW</span>' : ''}
            </div>
            <div class="small text-muted mt-1">
                <i class="fas fa-clipboard-list me-1"></i>${escapeHtml(alert.assessment_title)}
            </div>
            <div class="small text-muted">
                <i class="fas fa-chart-line me-1"></i>Score: ${alert.total_score}
            </div>
            <div class="alert-time">
                <i class="far fa-clock me-1"></i>${formatTimeAgo(alert.created_at)}
            </div>
        </div>
    `).join('');
}

function viewPatientResult(alertId, patientId) {
    fetch('{{ path('crisis_alerts_mark_read', {id: 'ALERT_ID_PLACEHOLDER'}) }}'.replace('ALERT_ID_PLACEHOLDER', alertId), {
        method: 'POST',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: '_token=' + encodeURIComponent(csrfToken)
    }).then(() => {
        window.location.href = '{{ path('result_by_user', {userId: 'USER_ID_PLACEHOLDER'}) }}'.replace('USER_ID_PLACEHOLDER', patientId);
    }).catch(err => console.error(err));
}

async function markAllAlertsRead() {
    const btn = document.getElementById('markAllReadBtn');
    const originalHtml = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Processing...';
    btn.disabled = true;

    try {
        const response = await fetch('{{ path('crisis_alerts_mark_all_read') }}', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: '_token=' + encodeURIComponent(csrfToken)
        });

        const data = await response.json();

        if (data.success) {
            updateBellBadge(0);
            await loadCrisisAlerts();
            showToastMessage('All alerts marked as read', 'success');

            const panel = document.getElementById('crisisPanel');
            panel.classList.remove('show');
        } else {
            showToastMessage(data.error || 'Failed to mark alerts as read', 'error');
        }
    } catch (error) {
        console.error('Failed to mark all as read:', error);
        showToastMessage('Failed to mark alerts as read', 'error');
    } finally {
        btn.innerHTML = originalHtml;
        btn.disabled = false;
    }
}

function updateBellBadge(count) {
    const badge = document.getElementById('crisisBadge');
    if (count > 0) {
        badge.style.display = 'flex';
        badge.textContent = count > 99 ? '99+' : count;
        badge.style.animation = 'none';
        setTimeout(() => {
            badge.style.animation = 'pulse 1.5s infinite';
        }, 10);
    } else {
        badge.style.display = 'none';
    }
}

async function checkForNewAlerts() {
    try {
        const response = await fetch('{{ path('crisis_alerts_count') }}');
        const data = await response.json();

        if (data.count > lastUnreadCount && data.count > 0) {
            const newCount = data.count - lastUnreadCount;
            updateBellBadge(data.count);
            showFloatingCrisisAlert(newCount);
            playCrisisAlertSound();
            showToastMessage('⚠️ ' + newCount + ' new high-risk alert' + (newCount > 1 ? 's' : ''), 'crisis');

            if (document.getElementById('crisisPanel').classList.contains('show')) {
                loadCrisisAlerts();
            }
        }

        lastUnreadCount = data.count;
    } catch (error) {
        console.error('Failed to check alerts:', error);
    }
}

function showToastMessage(message, type) {
    const toast = document.createElement('div');
    toast.className = 'toast-notification';
    if (type === 'success') toast.classList.add('success');
    if (type === 'info') toast.classList.add('info');
    toast.innerHTML = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

function formatTimeAgo(dateString) {
    const date = new Date(dateString);
    const now = new Date();
    const diffMs = now - date;
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);

    if (diffMins < 1) return 'Just now';
    if (diffMins < 60) return diffMins + ' minute' + (diffMins > 1 ? 's' : '') + ' ago';
    if (diffHours < 24) return diffHours + ' hour' + (diffHours > 1 ? 's' : '') + ' ago';
    return diffDays + ' day' + (diffDays > 1 ? 's' : '') + ' ago';
}

// ============================================
// FACE ID SYSTEM
// ============================================

let faceStream = null;
let isProcessing = false;
let sampleCount = 0;
const REQUIRED_SAMPLES = 3;

const instructions = [
    'Look straight at the camera',
    'Turn your head slightly left',
    'Turn your head slightly right'
];

const enableFaceIdBtn = document.getElementById('enableFaceIdBtn');
const disableFaceIdBtn = document.getElementById('disableFaceIdBtn');
const faceModal = document.getElementById('faceIdModal');
const closeFaceBtn = document.getElementById('closeFaceModalBtn');
const captureFaceBtn = document.getElementById('captureFaceBtn');
const faceVideo = document.getElementById('faceVideo');
const faceCanvas = document.getElementById('faceCanvas');
const faceStatus = document.getElementById('faceStatus');
const faceProgress = document.getElementById('faceProgress');

if (enableFaceIdBtn) {
    enableFaceIdBtn.addEventListener('click', startFaceRegistration);
}

if (closeFaceBtn) {
    closeFaceBtn.addEventListener('click', stopFaceRegistration);
}

if (disableFaceIdBtn) {
    disableFaceIdBtn.addEventListener('click', async () => {
        if (confirm('Are you sure you want to disable Face ID login?')) {
            try {
                const response = await fetch('/face/api/disable/{{ user.id }}', {
                    method: 'POST'
                });
                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Failed to disable Face ID: ' + result.message);
                }
            } catch (error) {
                alert('Error: ' + error.message);
            }
        }
    });
}

function startFaceRegistration() {
    sampleCount = 0;
    isProcessing = false;
    faceModal.style.display = 'block';
    updateFaceUI();

    navigator.mediaDevices.getUserMedia({ video: true })
        .then(stream => {
            faceStream = stream;
            faceVideo.srcObject = stream;
            captureFaceBtn.disabled = false;
        })
        .catch(err => {
            faceStatus.textContent = '❌ Cannot access camera: ' + err.message;
        });
}

function stopFaceRegistration() {
    if (faceStream) {
        faceStream.getTracks().forEach(track => track.stop());
        faceStream = null;
    }
    faceModal.style.display = 'none';
    faceVideo.srcObject = null;
    sampleCount = 0;
    isProcessing = false;
}

function updateFaceUI() {
    const progress = (sampleCount / REQUIRED_SAMPLES) * 100;
    faceProgress.style.width = progress + '%';
    faceStatus.textContent = instructions[sampleCount] || 'Almost done...';
    captureFaceBtn.textContent = `📸 Capture Sample ${sampleCount + 1} of ${REQUIRED_SAMPLES}`;
    captureFaceBtn.disabled = true;
}

if (captureFaceBtn) {
    captureFaceBtn.addEventListener('click', async () => {
        if (isProcessing) return;
        isProcessing = true;
        captureFaceBtn.disabled = true;

        const ctx = faceCanvas.getContext('2d');
        faceCanvas.width = faceVideo.videoWidth;
        faceCanvas.height = faceVideo.videoHeight;
        ctx.drawImage(faceVideo, 0, 0);

        faceCanvas.toBlob(async (blob) => {
            const formData = new FormData();
            formData.append('image', blob, 'face.jpg');

            faceStatus.textContent = `⏳ Processing sample ${sampleCount + 1}...`;

            try {
                const response = await fetch('/face/api/register/{{ user.id }}', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    sampleCount = result.sample_count;

                    if (result.completed) {
                        faceProgress.style.width = '100%';
                        faceStatus.innerHTML = '✅ Face ID registered successfully! Reloading...';
                        captureFaceBtn.disabled = true;
                        setTimeout(() => {
                            stopFaceRegistration();
                            location.reload();
                        }, 1500);
                    } else {
                        faceStatus.innerHTML = `✅ Sample ${sampleCount} saved! ${result.remaining} more needed.`;
                        updateFaceUI();
                        captureFaceBtn.disabled = false;
                        isProcessing = false;
                    }
                } else {
                    faceStatus.innerHTML = `❌ ${result.message} — Please try again.`;
                    captureFaceBtn.disabled = false;
                    isProcessing = false;
                }
            } catch (error) {
                faceStatus.innerHTML = '❌ Error: ' + error.message;
                captureFaceBtn.disabled = false;
                isProcessing = false;
            }
        }, 'image/jpeg');
    });
}

