.stat-card.green {
    background: linear-gradient(135deg, #50C878 0%, #3A9B5E 100%);
}

.stat-card.blue {
    background: linear-gradient(135deg, #4facfe 0%, #00c6ff 100%);
}

.stat-card.red {
    background: linear-gradient(135deg, #ff6a88 0%, #ff4b2b 100%);
}

.stat-icon {
    font-size: 30px;
    margin-bottom: 12px;
    position: relative;
    z-index: 1;
}

.stat-label {
    font-size: 14px;
