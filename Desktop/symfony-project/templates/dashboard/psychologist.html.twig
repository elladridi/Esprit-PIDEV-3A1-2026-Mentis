.btn-primary {
    background: var(--primary);
    border-color: var(--primary);
    border-radius: 12px;
    font-weight: 700;
}

.btn-primary:hover {
    background: #40a860;
    border-color: #40a860;
}

.btn-secondary,
.btn-success,
.btn-outline-danger,
