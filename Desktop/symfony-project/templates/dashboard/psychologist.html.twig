        <div id="crisisPanel" class="crisis-alert-panel">
            <div class="crisis-alert-header">
                <h6><i class="fas fa-exclamation-triangle me-2"></i>Crisis Alerts</h6>
                <button type="button" class="btn-close btn-close-white" onclick="toggleCrisisPanel()"></button>
