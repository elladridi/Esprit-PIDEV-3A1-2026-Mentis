    overflow-x: hidden;
}

.dashboard-shell::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
        radial-gradient(circle at 15% 20%, rgba(80, 200, 120, 0.12), transparent 20%),
        radial-gradient(circle at 85% 10%, rgba(102, 126, 234, 0.10), transparent 22%),
        radial-gradient(circle at 70% 70%, rgba(118, 75, 162, 0.08), transparent 20%);
