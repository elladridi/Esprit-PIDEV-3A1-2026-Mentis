{% extends "base.html.twig" %}

{% block title %}Patient Dashboard - Mentis{% endblock %}

{% block body %}
<div class="container-lg py-4">
    <div class="app-hero mb-4">
        <div class="hero-inner">
            <h1 class="dash-welcome mb-2" style="font-size: 2.3rem; font-weight: 800;">Welcome back, {{ user.firstname }}!</h1>
            <p class="text-muted" style="font-size: 1.05rem;">Your mental wellness journey continues here.</p>
        </div>
    </div>

    <div class="row gy-4">
        <div class="col-md-6">
            <div class="info-card p-4 bg-white">
                <h5><i class="bi bi-person-circle me-2"></i> My Profile</h5>
                <table class="table table-borderless">
                    <tr><th width="35%">Full Name:</th><td>{{ user.firstname }} {{ user.lastname }}</td></tr>
                    <tr><th>Email:</th><td>{{ user.email }}</td></tr>
                    <tr><th>Phone:</th><td>{{ user.phone }}</td></tr>
                    <tr><th>Date of Birth:</th><td>{{ user.dateofbirth }}</td></tr>
                    <tr><th>Age:</th><td>{{ user.age }} years</td></tr>
                    <tr><th>Gender:</th><td>
                        {% if user.gender == 'male' %}
                            <span class="badge-grade" style="background: #d4f5e8;">👨 Male</span>
                        {% elseif user.gender == 'female' %}
                            <span class="badge-grade" style="background: #fce4e4;">👩 Female</span>
                        {% else %}
                            <span class="badge-grade" style="background: #e9ecef;">👤 Other</span>
                        {% endif %}
                    </td></tr>
                </table>
            </div>
        </div>
        <div class="col-md-6">
            <div class="info-card p-4 bg-white">
                <h5><i class="bi bi-heart-pulse me-2"></i> Quick Actions</h5>
                <div class="d-grid gap-2">
                    <a href="{{ path('content_index') }}" class="btn btn-modern">Browse Content</a>

                    <a href="{{ path('app_chatbot') }}" class="btn btn-outline-success">AI Chatbot Support</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}