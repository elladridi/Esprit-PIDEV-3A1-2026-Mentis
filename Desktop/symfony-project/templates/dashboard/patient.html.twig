{% extends "base.html.twig" %}

{% block title %}Patient Dashboard - Mentis{% endblock %}

{% block body %}
<div class="main-nav">
    <div class="container-lg d-flex justify-content-between align-items-center py-3">
        <div class="d-flex align-items-center gap-3">
            <span class="fs-3">🧠</span>
            <div>
                <h5 class="mb-0 fw-bold">Mentis Patient Portal</h5>
                <small class="text-muted">Personalized wellness and content path</small>
            </div>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span>Welcome, <strong>{{ user.firstname }} {{ user.lastname }}</strong></span>
            <a class="btn btn-modern" href="{{ path('app_logout') }}">Logout</a>
        </div>
    </div>
</div>

<div class="container-lg mt-4">
    <div class="app-hero">
        <div class="hero-inner">
            <h1 class="dash-welcome mb-2" style="font-size: 2.3rem; font-weight: 800;">Your mental wellness journey, guided.</h1>
            <p class="text-muted" style="font-size: 1.05rem;">This dashboard shows your assigned resources, progress and suggested next step.</p>
            <div class="mt-3 d-flex gap-2 flex-wrap">
                <a class="btn btn-modern" href="{{ path('content_index') }}">Browse Assigned Content</a>
                <a class="btn btn-outline-success" href="{{ path('content_logs') }}">View Content Usage</a>
            </div>
        </div>
    </div>

    <div class="row gy-4">
        <div class="col-lg-4">
            <div class="info-card p-4 glass-panel">
                <h6 class="mb-2">Assigned Content</h6>
                <strong>{{ contentProgress|length }}</strong>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="info-card p-4 glass-panel">
                <h6 class="mb-2">Unread Content</h6>
                <strong>{{ unreadCount }}</strong>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="info-card p-4 glass-panel">
                <h6 class="mb-2">Read Percentage</h6>
                <strong>{{ contentProgress|length > 0 ? (100 - (unreadCount / contentProgress|length * 100))|round(1) : 0 }}%</strong>
            </div>
        </div>
    </div>

    <div class="mt-4 info-card p-4 glass-panel">
        <h4 class="mb-3">Recommended next content</h4>
        <div class="table-responsive">
            <table class="table table-modern align-middle mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Last Viewed</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in contentProgress %}
                        <tr>
                            <td>{{ item.content.title }}</td>
                            <td>
                                {% if item.seen %}
                                    <span class="badge badge-success">Viewed</span>
                                {% else %}
                                    <span class="badge badge-warning">Unread</span>
                                {% endif %}
                            </td>
                            <td>{{ item.lastAccessed ? item.lastAccessed|date('d/m/Y H:i') : 'Not viewed' }}</td>
                            <td><a class="btn btn-sm btn-modern" href="{{ path('content_show', {id: item.content.id}) }}">Open</a></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
