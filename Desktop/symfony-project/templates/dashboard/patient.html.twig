{% extends "base.html.twig" %}

{% block title %}Patient Dashboard - Mentis{% endblock %}

{% block body %}
<div class="container-lg py-4">
    <!-- Hero Section with Animated Gradient -->
    <div class="hero-section mb-5 text-center">
        <div class="hero-badge-animation">
            <div class="floating-icons">
                <span class="float-icon">🌟</span>
                <span class="float-icon">🏆</span>
                <span class="float-icon">🎯</span>
                <span class="float-icon">💪</span>
            </div>
        </div>
        <h1 class="display-4 fw-bold mb-2" style="background: linear-gradient(135deg, #2E7D32, #50C878, #1ABC9C); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-size: 200% 200%; animation: gradientShift 3s ease infinite;">
            Welcome back, {{ user.firstname }}! 🌟
        </h1>
        <p class="lead text-muted">Your mental wellness journey continues here.</p>
        <div class="level-progress mx-auto mt-3" style="max-width: 300px;">
            <div class="d-flex justify-content-between small mb-1">
                <span>🏅 Level {{ earnedBadges|length }}</span>
                <span>🎯 Next Level: {{ (earnedBadges|length / totalBadges * 100)|round }}%</span>
            </div>
            <div class="progress" style="height: 10px; border-radius: 10px;">
                <div class="progress-bar" role="progressbar" 
                    style="width: {{ (earnedBadges|length / totalBadges * 100)|round }}%; background: linear-gradient(90deg, #50C878, #F1C40F); border-radius: 10px;">
                </div>
            </div>
        </div>
    </div>

    <!-- Face ID Registration Alert with 3D Effect -->
    {% if not user.faceEnabled %}
    <div class="glass-card mb-4 p-4" style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.9), rgba(118, 75, 162, 0.9)); backdrop-filter: blur(10px); border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.2);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="shield-icon" style="font-size: 48px; animation: shake 5s ease infinite;">🛡️</div>
                <div>
                    <h3 class="text-white mb-1 fw-bold">🔐 Fortify Your Account</h3>
                    <p class="text-white-50 mb-0">Enable Face ID for lightning-fast, secure access</p>
                </div>
            </div>
            <button id="enableFaceIdBtn" class="btn-3d">
                <i class="fas fa-face-smile me-2"></i> Enable Face ID
                <span class="btn-3d-shadow"></span>
            </button>
        </div>
    </div>
    {% else %}
    <div class="success-card mb-4 p-4" style="background: linear-gradient(135deg, #50C878, #2E7D32); border-radius: 20px;">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="check-animation">✅</div>
                <div>
                    <h3 class="text-white mb-1 fw-bold">Face ID Active</h3>
                    <p class="text-white-50 mb-0">Your account is secured with biometric authentication</p>
                </div>
            </div>
            <button id="disableFaceIdBtn" class="btn-outline-light-3d">
                <i class="fas fa-trash me-1"></i> Disable
            </button>
        </div>
    </div>
    {% endif %}

    <!-- ==================== CREATIVE BADGES SECTION ==================== -->
    <div class="badges-universe mb-5">
        <div class="badges-header-creative text-center mb-4">
            <div class="badge-crown">👑</div>
            <h2 class="fw-bold" style="background: linear-gradient(135deg, #F1C40F, #E67E22); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                Achievement Gallery
            </h2>
            <p class="text-muted">Your journey, your trophies. Keep collecting!</p>
            <div class="stats-pill mx-auto">
                <span class="stat-item">
                    <i class="fas fa-medal"></i> {{ earnedBadges|length }}/{{ totalBadges }} Badges
                </span>
                <span class="stat-item">
                    <i class="fas fa-star"></i> {{ (earnedBadges|length / totalBadges * 100)|round }}% Complete
                </span>
                <span class="stat-item">
                    <i class="fas fa-trophy"></i> {{ earnedBadges|length * 100 }} XP
                </span>
            </div>
        </div>

        <!-- Badge Carousel / Grid with Creative Flip Cards -->
        <div class="badge-grid">
            {% for badge in badges %}
            <div class="badge-flip-card {% if badge.earned %}earned{% endif %}" data-badge="{{ badge.name }}">
                <div class="badge-flip-inner">
                    <!-- Front Side -->
                    <div class="badge-front" style="background: {% if badge.earned %}linear-gradient(135deg, {{ badge.color }}, {{ badge.color }}dd){% else %}linear-gradient(135deg, #6c757d, #495057){% endif %};">
                        <div class="badge-front-content">
                            <div class="badge-icon-3d">{{ badge.icon }}</div>
                            <h5 class="badge-name">{{ badge.name }}</h5>
                            {% if badge.earned %}
                            <div class="badge-glow"></div>
                            <span class="badge-earned-stamp">
                                <i class="fas fa-check-circle"></i> EARNED
                            </span>
                            {% else %}
                            <div class="badge-lock-overlay">
                                <i class="fas fa-lock"></i>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    <!-- Back Side -->
                    <div class="badge-back">
                        <div class="badge-back-content">
                            <div class="badge-back-icon">{{ badge.icon }}</div>
                            <h6>{{ badge.name }}</h6>
                            <p class="small">{{ badge.description }}</p>
                            {% if not badge.earned %}
                                <div class="requirement-box">
                                    <small><i class="fas fa-info-circle"></i> {{ badge.required|default('Complete requirements') }}</small>
                                    <div class="progress mini-progress mt-1">
                                        <div class="progress-bar" style="width: {{ badge.progress|default(0) }}%; background: {{ badge.color }};"></div>
                                    </div>
                                    <small class="text-muted">{{ badge.progress|default(0) }}% complete</small>
                                </div>
                            {% else %}
                                <div class="earned-date">
                                    <i class="fas fa-calendar-check"></i> Unlocked
                                </div>
                                <div class="earned-badge-check">
                                    <i class="fas fa-check-circle"></i>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        <!-- Milestone Celebration Banner -->
        {% if earnedBadges|length >= 5 %}
        <div class="milestone-banner mt-4 p-3 text-center" style="background: linear-gradient(90deg, #F1C40F20, #F1C40F40, #F1C40F20); border-radius: 50px; animation: shimmer 2s infinite;">
            <span class="firework-icon">🎉</span>
            <strong class="mx-2">Milestone Unlocked!</strong>
            <span>You've earned {{ earnedBadges|length }} badges</span>
            <span class="firework-icon">🎊</span>
        </div>
        {% endif %}
    </div>

    <!-- Achievement Unlocked Toast Notification (shown after new badge) -->
    {% if newlyEarnedBadges is defined and newlyEarnedBadges|length > 0 %}
    <div class="achievement-toast">
        {% for badge in newlyEarnedBadges %}
        <div class="toast show" role="alert">
            <div class="toast-body">
                <div class="achievement-icon">{{ badge.icon }}</div>
                <div>
                    <strong>Achievement Unlocked!</strong>
                    <div>{{ badge.name }} - {{ badge.description }}</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    <!-- Rest of your dashboard content continues... -->
    <!-- Assessment Quick Access Section -->
    <div class="row mt-5 mb-4">
        <div class="col-12">
            <div class="glass-card p-4" style="background: rgba(255,255,255,0.95); border-radius: 25px; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
                <h5 class="mb-3"><i class="fas fa-bolt me-2" style="color: #50C878;"></i> Quick Access</h5>
                <div class="row g-3">
                    <div class="col-md-3">
                        <a href="{{ path('take_assessment_index') }}" class="quick-action-link">
                            <div class="quick-action-card p-3 text-center">
                                <i class="fas fa-clipboard-list" style="font-size: 36px; color: #50C878;"></i>
                                <h6 class="mt-2 mb-0">Take Assessment</h6>
                                <small class="text-muted">+{{ 50 - earnedBadges|length * 5 }} XP</small>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a href="{{ path('result_stats', {userId: user.id}) }}" class="quick-action-link">
                            <div class="quick-action-card p-3 text-center">
                                <i class="fas fa-chart-line" style="font-size: 36px; color: #50C878;"></i>
                                <h6 class="mt-2 mb-0">View Progress</h6>
                                <small class="text-muted">Track your journey</small>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a href="{{ path('content_index') }}" class="quick-action-link">
                            <div class="quick-action-card p-3 text-center">
                                <i class="fas fa-book-open" style="font-size: 36px; color: #50C878;"></i>
                                <h6 class="mt-2 mb-0">View Content</h6>
                                <small class="text-muted">Learn & grow</small>
                            </div>
                        </a>
                    </div>
                    <div class="col-md-3">
                        <a href="{{ path('app_chatbot') }}" class="quick-action-link">
                            <div class="quick-action-card p-3 text-center">
                                <i class="fas fa-robot" style="font-size: 36px; color: #50C878;"></i>
                                <h6 class="mt-2 mb-0">AI Chatbot</h6>
                                <small class="text-muted">24/7 Support</small>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Profile and Stats Section -->
    <div class="row g-4">
        <div class="col-md-5">
            <div class="profile-card p-4" style="background: white; border-radius: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
                <div class="profile-avatar mb-3 text-center">
                    <div class="avatar-circle" style="width: 80px; height: 80px; background: linear-gradient(135deg, #50C878, #2E7D32); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center;">
                        <span style="font-size: 40px;">{{ user.firstname|first }}{{ user.lastname|first }}</span>
                    </div>
                </div>
                <h4 class="text-center mb-3">{{ user.firstname }} {{ user.lastname }}</h4>
                <div class="profile-info">
                    <div class="info-row d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted"><i class="fas fa-envelope me-2"></i> Email</span>
                        <span>{{ user.email }}</span>
                    </div>
                    <div class="info-row d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted"><i class="fas fa-phone me-2"></i> Phone</span>
                        <span>{{ user.phone }}</span>
                    </div>
                    <div class="info-row d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted"><i class="fas fa-calendar me-2"></i> Birth</span>
                        <span>{{ user.dateofbirth ? user.dateofbirth|date('d/m/Y') : 'N/A' }}</span>
                    </div>
                    <div class="info-row d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted"><i class="fas fa-chart-simple me-2"></i> Age</span>
                        <span>{{ user.age }} years</span>
                    </div>
                    <div class="info-row d-flex justify-content-between py-2">
                        <span class="text-muted"><i class="fas fa-calendar-plus me-2"></i> Member Since</span>
                        <span>{{ user.createdAt|date('d/m/Y') }}</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="activity-stats p-4" style="background: white; border-radius: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
                <h5 class="mb-3"><i class="fas fa-chart-simple me-2" style="color: #50C878;"></i> Activity Overview</h5>
                <div class="stats-grid">
                    <div class="stat-box text-center p-3">
                        <div class="stat-value display-4 fw-bold" style="color: #50C878;">{{ recentResults|length }}</div>
                        <div class="stat-label text-muted">Assessments Taken</div>
                    </div>
                    <div class="stat-box text-center p-3">
                        <div class="stat-value display-4 fw-bold" style="color: #F1C40F;">{{ earnedBadges|length }}</div>
                        <div class="stat-label text-muted">Badges Earned</div>
                    </div>
                    <div class="stat-box text-center p-3">
                        <div class="stat-value display-4 fw-bold" style="color: #9B59B6;">{{ (earnedBadges|length * 100) }}</div>
                        <div class="stat-label text-muted">Total XP</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Recent Assessments Section -->
    {% if recentResults is defined and recentResults|length > 0 %}
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm border-0" style="border-radius: 20px;">
                <div class="card-header bg-white" style="border-radius: 20px 20px 0 0;">
                    <h5 class="mb-0"><i class="fas fa-history me-2" style="color: #50C878;"></i> Recent Activity</h5>
                </div>
                <div class="card-body">
                    <div class="timeline">
                        {% for result in recentResults|slice(0, 5) %}
                        <div class="timeline-item">
                            <div class="timeline-icon" style="background: {% if result.riskLevel in ['High', 'Severe'] %}#dc3545{% elseif result.riskLevel in ['Moderate', 'Mild'] %}#ffc107{% else %}#50C878{% endif %};">
                                <i class="fas fa-clipboard-list"></i>
                            </div>
                            <div class="timeline-content">
                                <div class="d-flex justify-content-between align-items-center">
                                    <strong>{{ result.assessment ? result.assessment.title : 'Assessment' }}</strong>
                                    <small class="text-muted">{{ result.takenAt ? result.takenAt|date('M d, Y') : 'N/A' }}</small>
                                </div>
                                <div class="mt-2">
                                    <span class="badge bg-secondary me-2">Score: {{ result.totalScore }}</span>
                                    <span class="badge {% if result.riskLevel in ['High', 'Severe'] %}bg-danger{% elseif result.riskLevel in ['Moderate', 'Mild'] %}bg-warning{% else %}bg-success{% endif %}">
                                        {{ result.riskLevel }}
                                    </span>
                                    <a href="{{ path('result_show', {id: result.resultId}) }}" class="btn btn-sm btn-link">View Details →</a>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
</div>

<!-- Face ID Registration Modal -->
<!-- (Keep your existing modal code here) -->
{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ==================== CREATIVE ANIMATIONS ==================== */
    @keyframes gradientShift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }
    
    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
    }
    
    @keyframes floatDelay {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
    }
    
    @keyframes pulse {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.1); opacity: 0.7; }
    }
    
    @keyframes shimmer {
        0% { background-position: -1000px 0; }
        100% { background-position: 1000px 0; }
    }
    
    @keyframes shake {
        0%, 100% { transform: rotate(0deg); }
        25% { transform: rotate(-10deg); }
        75% { transform: rotate(10deg); }
    }
    
    .floating-icons {
        position: relative;
        height: 60px;
    }
    
    .float-icon {
        position: absolute;
        font-size: 24px;
        animation: float 3s ease-in-out infinite;
    }
    
    .float-icon:nth-child(1) { left: 10%; animation-delay: 0s; }
    .float-icon:nth-child(2) { left: 30%; animation-delay: 0.5s; animation-duration: 4s; }
    .float-icon:nth-child(3) { left: 60%; animation-delay: 1s; animation-duration: 3.5s; }
    .float-icon:nth-child(4) { left: 80%; animation-delay: 0.3s; animation-duration: 4.5s; }
    
    /* 3D Button */
    .btn-3d {
        background: linear-gradient(135deg, #fff, #f0f0f0);
        border: none;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 600;
        color: #2E7D32;
        cursor: pointer;
        position: relative;
        transition: transform 0.2s;
        box-shadow: 0 5px 0 #999;
    }
    
    .btn-3d:active {
        transform: translateY(3px);
        box-shadow: 0 2px 0 #999;
    }
    
    .btn-outline-light-3d {
        background: transparent;
        border: 2px solid white;
        padding: 8px 25px;
        border-radius: 50px;
        color: white;
        font-weight: 600;
        transition: all 0.3s;
    }
    
    .btn-outline-light-3d:hover {
        background: white;
        color: #2E7D32;
    }
    
    /* Stats Pill */
    .stats-pill {
        display: inline-flex;
        gap: 20px;
        background: #f8f9fa;
        padding: 8px 20px;
        border-radius: 50px;
    }
    
    .stat-item {
        font-size: 14px;
        font-weight: 500;
    }
    
    /* Flip Card Badge Grid */
    .badge-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }
    
    .badge-flip-card {
        background-color: transparent;
        width: 100%;
        height: 220px;
        perspective: 1000px;
        cursor: pointer;
    }
    
    .badge-flip-inner {
        position: relative;
        width: 100%;
        height: 100%;
        text-align: center;
        transition: transform 0.6s;
        transform-style: preserve-3d;
        border-radius: 15px;
    }
    
    .badge-flip-card:hover .badge-flip-inner {
        transform: rotateY(180deg);
    }
    
    .badge-front, .badge-back {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        padding: 15px;
    }
    
    .badge-front {
        background: linear-gradient(135deg, #50C878, #2E7D32);
        color: white;
    }
    
    .badge-back {
        background: white;
        color: #333;
        transform: rotateY(180deg);
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        border: 1px solid #e9ecef;
    }
    
    .badge-icon-3d {
        font-size: 48px;
        margin-bottom: 10px;
    }
    
    .badge-name {
        font-size: 14px;
        font-weight: bold;
        margin: 0;
    }
    
    .badge-glow {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border-radius: 15px;
        box-shadow: 0 0 20px rgba(80,200,120,0.6);
        animation: pulse 2s infinite;
    }
    
    .badge-lock-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
    }
    
    .badge-earned-stamp {
        position: absolute;
        bottom: 10px;
        right: 10px;
        font-size: 10px;
        background: rgba(255,255,255,0.2);
        padding: 3px 8px;
        border-radius: 20px;
    }
    
    .requirement-box {
        background: #f8f9fa;
        padding: 8px;
        border-radius: 10px;
        margin-top: 10px;
        width: 100%;
    }
    
    .mini-progress {
        height: 3px;
    }
    
    .earned-date {
        font-size: 11px;
        color: #50C878;
        margin-top: 10px;
    }
    
    .earned-badge-check {
        font-size: 32px;
        color: #50C878;
        margin-top: 10px;
    }
    
    /* Quick Action Cards */
    .quick-action-link {
        text-decoration: none;
    }
    
    .quick-action-card {
        background: #f8f9fa;
        border-radius: 15px;
        transition: all 0.3s;
        border: 1px solid #e9ecef;
    }
    
    .quick-action-card:hover {
        transform: translateY(-5px);
        background: linear-gradient(135deg, #50C878, #2E7D32);
        color: white;
        box-shadow: 0 10px 25px rgba(80,200,120,0.3);
    }
    
    .quick-action-card:hover i,
    .quick-action-card:hover h6,
    .quick-action-card:hover small {
        color: white !important;
    }
    
    /* Timeline */
    .timeline {
        position: relative;
        padding-left: 30px;
    }
    
    .timeline-item {
        position: relative;
        padding-bottom: 25px;
    }
    
    .timeline-icon {
        position: absolute;
        left: -30px;
        top: 0;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }
    
    .timeline-content {
        background: #f8f9fa;
        padding: 12px 15px;
        border-radius: 12px;
        margin-left: 10px;
    }
    
    /* Stats Grid */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
    }
    
    .stat-box {
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
        border-radius: 15px;
        transition: transform 0.3s;
    }
    
    .stat-box:hover {
        transform: scale(1.05);
    }
    
    /* Achievement Toast */
    .achievement-toast {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 1000;
    }
    
    .achievement-toast .toast {
        background: linear-gradient(135deg, #2E7D32, #50C878);
        color: white;
        margin-top: 10px;
        border-radius: 15px;
    }
    
    .achievement-toast .toast-body {
        display: flex;
        align-items: center;
        gap: 15px;
    }
    
    .achievement-icon {
        font-size: 32px;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
        .badge-grid {
            grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        }
        
        .badge-flip-card {
            height: 200px;
        }
        
        .stats-pill {
            flex-direction: column;
            gap: 5px;
            background: transparent;
            padding: 0;
        }
        
        .stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}