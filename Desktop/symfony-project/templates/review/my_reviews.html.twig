{% extends 'base.html.twig' %}

{% block title %}My Reviews - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="text-center mb-5" data-aos="fade-up">
        <h1 class="display-5 fw-bold mb-3" style="color: #2E7D32;">
            <i class="fas fa-star me-2"></i>My Reviews
        </h1>
        <p class="lead text-muted">View and manage your session reviews</p>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show rounded-pill mb-4 d-flex align-items-center" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% if reviews is empty %}
        <div class="text-center py-5" data-aos="fade-up">
            <div class="card shadow-sm border-0 p-5 rounded-4" style="max-width: 500px; margin: 0 auto;">
                <i class="fas fa-star fa-4x mb-3 text-muted"></i>
                <h3 class="text-muted mb-3">No Reviews Yet</h3>
                <p class="text-muted mb-4">You haven't written any reviews yet.<br>Reviews can only be added for past sessions you've attended.</p>
                <a href="{{ path('session_by_patient', {patientId: app.user.id}) }}" class="btn btn-primary-custom rounded-pill px-5">
                    <i class="fas fa-calendar-alt me-2"></i>Go to My Sessions
                </a>
            </div>
        </div>
    {% else %}
        <div class="row g-4">
            {% for review in reviews %}
                <div class="col-12" data-aos="fade-up" data-aos-delay="{{ loop.index * 50 }}">
                    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h4 class="fw-bold mb-1" style="color: #2E7D32;">{{ review.sessionTitle }}</h4>
                                    <div class="text-muted small">
                                        <i class="fas fa-calendar me-1"></i>{{ review.sessionDate|date('M d, Y') }}
                                        <span class="mx-2">•</span>
                                        <i class="fas fa-clock me-1"></i>{{ review.startTime|date('H:i') }} - {{ review.endTime|date('H:i') }}
                                    </div>
                                </div>
                                <div class="text-end">
                                    <div class="mb-1">
                                        {% for i in 1..5 %}
                                            {% if i <= review.rating %}
                                                <i class="fas fa-star text-warning"></i>
                                            {% else %}
                                                <i class="far fa-star text-muted"></i>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                    <small class="text-muted">Reviewed on {{ review.reviewDate|date('M d, Y H:i') }}</small>
                                </div>
                            </div>
                            
                            {% if review.comment %}
                                <p class="mb-3" style="font-style: italic; color: #555;">"{{ review.comment }}"</p>
                            {% endif %}
                            
                            <div class="d-flex gap-2 justify-content-end">
                                <a href="{{ path('review_edit', {id: review.reviewId}) }}" class="btn btn-outline-primary rounded-pill px-4">
                                    <i class="fas fa-edit me-1"></i>Edit
                                </a>
                                <form method="post" action="{{ path('review_delete', {id: review.reviewId}) }}" onsubmit="return confirm('Delete this review?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ review.reviewId) }}">
                                    <button type="submit" class="btn btn-outline-danger rounded-pill px-4">
                                        <i class="fas fa-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        
        <div class="text-center mt-4" data-aos="fade-up">
            <small class="text-muted">You have written {{ reviews|length }} review(s)</small>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block stylesheets %}
<style>
.btn-primary-custom {
    background: linear-gradient(135deg, #50C878 0%, #3A9B5E 100%);
    border: none;
    color: white;
    transition: all 0.3s ease;
    font-weight: 600;
}
.btn-primary-custom:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(80, 200, 120, 0.4);
    color: white !important;
}
.card {
    transition: transform 0.3s ease;
}
.card:hover {
    transform: translateY(-3px);
}
</style>
{% endblock %}