{% extends 'base.html.twig' %}

{% block title %}Review Analysis - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="mb-4">
        <a href="{{ path('review_admin_all') }}"
           class="text-decoration-none d-inline-flex align-items-center" style="color: #50C878;">
            <i class="fas fa-arrow-left me-2"></i> Back to All Reviews
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header text-white py-4 text-center"
                     style="background: linear-gradient(135deg, #2E7D32 0%, #50C878 100%);">
                    <h3 class="mb-0 fw-bold">
                        <i class="fas fa-brain me-2"></i>AI Review Analysis
                    </h3>
                    <p class="mb-0 mt-2 opacity-75">Powered by Groq AI</p>
                </div>
                <div class="card-body p-5">
                    
                    {# Sentiment Badge #}
                    <div class="text-center mb-4">
                        {% if analysis.sentiment == 'positive' %}
                            <span class="badge bg-success fs-5 px-4 py-2 rounded-pill">
                                <i class="fas fa-smile me-2"></i>Positive Review
                            </span>
                        {% elseif analysis.sentiment == 'negative' %}
                            <span class="badge bg-danger fs-5 px-4 py-2 rounded-pill">
                                <i class="fas fa-frown me-2"></i>Needs Attention
                            </span>
                        {% else %}
                            <span class="badge bg-warning fs-5 px-4 py-2 rounded-pill">
                                <i class="fas fa-meh me-2"></i>Neutral Review
                            </span>
                        {% endif %}
                    </div>

                    {# Original Review #}
                    <div class="card border-0 bg-light rounded-4 p-4 mb-4">
                        <h5 class="fw-bold mb-3" style="color: #2E7D32;">
                            <i class="fas fa-comment me-2"></i>Original Review
                        </h5>
                        <p class="mb-2">
                            <strong>Session:</strong> {{ session.title }}
                        </p>
                        <p class="mb-2">
                            <strong>Rating:</strong> 
                            {% for i in 1..5 %}
                                {% if i <= review.rating %}
                                    <i class="fas fa-star text-warning"></i>
                                {% else %}
                                    <i class="far fa-star text-muted"></i>
                                {% endif %}
                            {% endfor %}
                            ({{ review.rating }}/5)
                        </p>
                        <p class="mb-0">
                            <strong>Comment:</strong><br>
                            {{ review.comment|default('No comment provided') }}
                        </p>
                    </div>

                    {# AI Analysis #}
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3" style="color: #2E7D32;">
                            <i class="fas fa-chart-line me-2"></i>AI Analysis
                        </h5>
                        
                        <div class="card border-0 bg-light rounded-4 p-4 mb-3">
                            <p class="mb-2"><strong>🎭 Patient Sentiment:</strong> {{ analysis.analysis.patient_sentiment }}</p>
                            <p class="mb-2"><strong>📊 Key Points:</strong></p>
                            <ul>
                                {% for point in analysis.analysis.key_points %}
                                    <li>{{ point }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>

                    {# What Went Well #}
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3" style="color: #28a745;">
                            <i class="fas fa-check-circle me-2"></i>What Went Well
                        </h5>
                        <div class="card border-0 bg-success-subtle rounded-4 p-4">
                            <ul class="mb-0">
                                {% for item in analysis.analysis.what_went_well %}
                                    <li>{{ item }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>

                    {# Areas for Improvement #}
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3" style="color: #dc3545;">
                            <i class="fas fa-exclamation-triangle me-2"></i>Areas for Improvement
                        </h5>
                        <div class="card border-0 bg-danger-subtle rounded-4 p-4">
                            <ul class="mb-0">
                                {% for area in analysis.analysis.areas_for_improvement %}
                                    <li>{{ area }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>

                    {# Professional Advice #}
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3" style="color: #17a2b8;">
                            <i class="fas fa-lightbulb me-2"></i>Professional Advice
                        </h5>
                        <div class="card border-0 bg-info-subtle rounded-4 p-4">
                            <p class="mb-0">{{ analysis.advice }}</p>
                        </div>
                    </div>

                    {# Action Items #}
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3" style="color: #6f42c1;">
                            <i class="fas fa-tasks me-2"></i>Suggested Action Items
                        </h5>
                        <div class="card border-0 bg-purple-subtle rounded-4 p-4">
                            <ul class="mb-0">
                                {% for action in analysis.action_items %}
                                    <li>{{ action }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>

                    {# Encouragement #}
                    <div class="mb-4">
                        <h5 class="fw-bold mb-3" style="color: #fd7e14;">
                            <i class="fas fa-heart me-2"></i>Message for You
                        </h5>
                        <div class="card border-0 bg-warning-subtle rounded-4 p-4">
                            <p class="mb-0">{{ analysis.encouragement }}</p>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <a href="{{ path('review_admin_all') }}" class="btn btn-primary rounded-pill px-5">
                            <i class="fas fa-check me-2"></i>Done
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.bg-success-subtle { background: #d4edda !important; }
.bg-danger-subtle { background: #f8d7da !important; }
.bg-info-subtle { background: #d1ecf1 !important; }
.bg-purple-subtle { background: #e2d4f0 !important; }
.bg-warning-subtle { background: #fff3cd !important; }
</style>
{% endblock %}