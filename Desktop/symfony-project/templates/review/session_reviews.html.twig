{% extends 'base.html.twig' %}

{% block title %}Reviews for {{ session.title }} - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="mb-4">
        <a href="{{ path('session_show', {id: session.sessionId}) }}"
           class="text-decoration-none d-inline-flex align-items-center" style="color: #50C878;">
            <i class="fas fa-arrow-left me-2"></i> Back to Session
        </a>
    </div>

    <div class="text-center mb-5" data-aos="fade-up">
        <h1 class="display-5 fw-bold mb-3" style="color: #2E7D32;">
            <i class="fas fa-star me-2"></i>Session Reviews
        </h1>
        <h4 class="mb-2">{{ session.title }}</h4>
        <p class="lead text-muted">
            Average Rating: 
            {% for i in 1..5 %}
                {% if i <= averageRating %}
                    <i class="fas fa-star text-warning"></i>
                {% else %}
                    <i class="far fa-star text-muted"></i>
                {% endif %}
            {% endfor %}
            ({{ reviewCount }} review{{ reviewCount != 1 ? 's' : '' }})
        </p>
    </div>

    {% if reviews is empty %}
        <div class="text-center py-5" data-aos="fade-up">
            <div class="card shadow-sm border-0 p-5 rounded-4" style="max-width: 500px; margin: 0 auto;">
                <i class="fas fa-star fa-4x mb-3 text-muted"></i>
                <h3 class="text-muted mb-3">No Reviews Yet</h3>
                <p class="text-muted mb-0">Be the first to review this session!</p>
            </div>
        </div>
    {% else %}
        <div class="row g-4">
            {% for review in reviews %}
                <div class="col-12" data-aos="fade-up" data-aos-delay="{{ loop.index * 50 }}">
                    <div class="card shadow-sm border-0 rounded-4">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="fw-bold mb-1" style="color: #2E7D32;">
                                        <i class="fas fa-user-circle me-2"></i>{{ review.patientName }}
                                    </h5>
                                    <div class="text-muted small">
                                        {{ review.reviewDate|date('M d, Y H:i') }}
                                    </div>
                                </div>
                                <div>
                                    {% for i in 1..5 %}
                                        {% if i <= review.rating %}
                                            <i class="fas fa-star text-warning"></i>
                                        {% else %}
                                            <i class="far fa-star text-muted"></i>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                            
                            {% if review.comment %}
                                <p class="mb-0" style="font-style: italic; color: #555;">"{{ review.comment }}"</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}

{% block stylesheets %}
<style>
.card {
    transition: transform 0.3s ease;
}
.card:hover {
    transform: translateY(-3px);
}
</style>
{% endblock %}
