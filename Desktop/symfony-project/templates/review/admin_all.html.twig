{% extends 'base.html.twig' %}

{% block title %}All Reviews - Admin Panel{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold" style="color: #2E7D32;">
            <i class="fas fa-star me-2"></i>All Reviews
        </h1>
        <a href="{{ path('app_dashboard_admin') }}" class="btn btn-outline-secondary rounded-pill">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead style="background: #f0faf4;">
                        <tr>
                            <th>ID</th>
                            <th>Patient</th>
                            <th>Session</th>
                            <th>Rating</th>
                            <th>Review</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if reviews is defined and reviews|length > 0 %}
                            {% for review in reviews %}
                            <tr>
                                <td>{{ review.reviewId }}</td>
                                <td>
                                    {% if review.patientName %}
                                        {{ review.patientName }}
                                    {% else %}
                                        Patient #{{ review.patientId }}
                                    {% endif %}
                                </td>
                                <td>
                                    {% if review.sessionTitle %}
                                        {{ review.sessionTitle }}
                                    {% else %}
                                        Session #{{ review.sessionId }}
                                    {% endif %}
                                </td>
                                <td>
                                    <div class="text-warning">
                                        {% for i in 1..5 %}
                                            {% if i <= review.rating %}
                                                <i class="fas fa-star"></i>
                                            {% else %}
                                                <i class="far fa-star"></i>
                                            {% endif %}
                                        {% endfor %}
                                        ({{ review.rating }}/5)
                                    </div>
                                </td>
                                <td style="max-width: 300px;">
                                    {{ review.comment|slice(0, 100) }}{% if review.comment|length > 100 %}...{% endif %}
                                </td>
                                <td>{{ review.reviewDate|date('Y-m-d H:i') }}</td>
                                <td>
                                    <button type="button" 
                                            class="btn btn-sm btn-outline-primary rounded-pill"
                                            data-bs-toggle="modal"
                                            data-bs-target="#reviewModal{{ review.reviewId }}">
                                        <i class="fas fa-eye"></i> View
                                    </button>
                                </td>
                            </tr>

                            {# Modal for full review #}
                            <div class="modal fade" id="reviewModal{{ review.reviewId }}" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content rounded-4">
                                        <div class="modal-header" style="background: #f0faf4;">
                                            <h5 class="modal-title">Review Details</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <p><strong>Review ID:</strong> {{ review.reviewId }}</p>
                                            <p><strong>Patient:</strong> {{ review.patientName ?? 'Patient #' ~ review.patientId }}</p>
                                            <p><strong>Session:</strong> {{ review.sessionTitle ?? 'Session #' ~ review.sessionId }}</p>
                                            <p><strong>Rating:</strong> 
                                                <div class="text-warning d-inline-block">
                                                    {% for i in 1..5 %}
                                                        {% if i <= review.rating %}
                                                            <i class="fas fa-star"></i>
                                                        {% else %}
                                                            <i class="far fa-star"></i>
                                                        {% endif %}
                                                    {% endfor %}
                                                </div>
                                            </p>
                                            <p><strong>Review:</strong></p>
                                            <div class="p-3 rounded-3" style="background: #f8f9fa;">
                                                {{ review.comment|nl2br }}
                                            </div>
                                            <p class="mt-3"><strong>Date:</strong> {{ review.reviewDate|date('F j, Y g:i A') }}</p>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Close</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <i class="fas fa-star fa-3x mb-3 text-muted"></i>
                                    <p class="text-muted">No reviews found.</p>
                                </td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
.btn-outline-primary {
    border-color: #50C878;
    color: #2E7D32;
}
.btn-outline-primary:hover {
    background: #50C878;
    border-color: #50C878;
    color: white;
}
</style>
{% endblock %}