{% extends 'base.html.twig' %}

{% block title %}All Reviews - Admin Panel{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1 class="mb-4">All Reviews</h1>
    
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-gradient text-white" style="background: linear-gradient(135deg, #2E7D32 0%, #50C878 100%);">
            <h4 class="mb-0 fw-bold">Reviews Management</h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Patient</th>
                            <th>Session</th>
                            <th>Rating</th>
                            <th>Comment</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for review in reviews %}
                        <tr>
                            <td>{{ review.reviewId }}<\/td>
                            <td>{{ review.patientName ?: 'N/A' }}<\/td>
                            <td>{{ review.sessionTitle ?: 'N/A' }}<\/td>
                            <td>
                                {% for i in 1..5 %}
                                    {% if i <= review.rating %}
                                        <i class="fas fa-star text-warning"></i>
                                    {% else %}
                                        <i class="far fa-star text-muted"></i>
                                    {% endif %}
                                {% endfor %}
                                ({{ review.rating }}/5)
                            <\/td>
                            <td>{{ review.comment|slice(0, 100) }}{% if review.comment|length > 100 %}...{% endif %}<\/td>
                            <td>{{ review.reviewDate ? review.reviewDate|date('Y-m-d H:i') : 'N/A' }}<\/td>
                            <td>
                                <a href="{{ path('session_show', {'id': review.sessionId}) }}" class="btn btn-sm btn-info mb-1">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="{{ path('review_admin_analysis_view', {id: review.reviewId}) }}" 
                                   class="btn btn-sm btn-primary mb-1">
                                    <i class="fas fa-brain me-1"></i> Analyze AI
                                </a>
                                <form method="post" action="{{ path('review_admin_delete', {'id': review.reviewId}) }}" 
                                      style="display: inline-block;" 
                                      onsubmit="return confirm('Are you sure you want to delete this review?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ review.reviewId) }}">
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </form>
                            <\/td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-4">
                                <i class="fas fa-comments fa-3x text-muted mb-2 d-block"></i>
                                No reviews found
                            <\/td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <div class="mt-3">
        <a href="{{ path('session_index') }}" class="btn btn-outline-secondary rounded-pill">
            <i class="fas fa-arrow-left me-2"></i> Back to Sessions
        </a>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
    .table th, .table td {
        vertical-align: middle;
    }
    .fa-star, .far.fa-star {
        font-size: 14px;
    }
    .btn-sm {
        margin: 2px;
    }
</style>
{% endblock %}