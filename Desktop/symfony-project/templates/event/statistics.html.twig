{% extends 'base.html.twig' %}

{% block title %}Statistics - MENTIS Events{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .stat-card {
            background: white;
            border-radius: 15px;
            border: 1px solid #DDE5E2;
            padding: 20px;
            text-align: center;
            transition: transform 0.2s;
        }
        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        }
        .stat-value {
            font-size: 28px;
            font-weight: bold;
            color: #2F5D52;
        }
        .chart-card {
            background: white;
            border-radius: 15px;
            border: 1px solid #DDE5E2;
            padding: 20px;
            height: 100%;
        }
        .chart-title {
            font-size: 16px;
            font-weight: bold;
            color: #2F5D52;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #9BC7B5;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold" style="color: #1E1E1E;">📊 Event Statistics Dashboard</h1>
            <p class="text-muted">Analytics and insights for all events</p>
        </div>
        <a href="{{ path('app_event_index') }}" class="btn" style="background: #9BC7B5; color: #2F5D52;">
            ← Back to Events
        </a>
    </div>
    
    <!-- Summary Stats Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-2 col-sm-4 col-6">
            <div class="stat-card">
                <div class="stat-value">{{ summary.totalEvents }}</div>
                <small class="text-muted">📅 Total Events</small>
            </div>
        </div>
        <div class="col-md-2 col-sm-4 col-6">
            <div class="stat-card">
                <div class="stat-value">{{ summary.totalParticipants }}</div>
                <small class="text-muted">👥 Participants</small>
            </div>
        </div>
        <div class="col-md-2 col-sm-4 col-6">
            <div class="stat-card">
                <div class="stat-value">{{ summary.totalRegistrations }}</div>
                <small class="text-muted">🎟 Registrations</small>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 col-6">
            <div class="stat-card">
                <div class="stat-value">${{ summary.totalRevenue|number_format(2) }}</div>
                <small class="text-muted">💵 Total Revenue</small>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 col-12">
            <div class="stat-card">
                <div class="stat-value">${{ summary.avgTicketPrice|number_format(2) }}</div>
                <small class="text-muted">📊 Avg. Ticket Price</small>
            </div>
        </div>
    </div>
    
    <!-- Charts Row 1 -->
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="chart-card">
                <div class="chart-title">🏷 Events by Type</div>
                <canvas id="eventsByTypeChart" height="250"></canvas>
            </div>
        </div>
        <div class="col-md-6">
            <div class="chart-card">
                <div class="chart-title">💰 Revenue by Event</div>
                <canvas id="revenueByEventChart" height="250"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Chart Row 2 -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="chart-card">
                <div class="chart-title">📈 Registrations Over Time (Last 30 Days)</div>
                <canvas id="registrationsOverTimeChart" height="300"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Chart Row 3 -->
    <div class="row g-4">
        <div class="col-md-6">
            <div class="chart-card">
                <div class="chart-title">🎫 Ticket Type Distribution</div>
                <canvas id="ticketTypeChart" height="250"></canvas>
            </div>
        </div>
        <div class="col-md-6">
            <div class="chart-card">
                <div class="chart-title">📊 Registration Status</div>
                <canvas id="statusChart" height="250"></canvas>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Events by Type Pie Chart
    const eventsByTypeCtx = document.getElementById('eventsByTypeChart').getContext('2d');
    const eventsByTypeData = {{ eventsByType|json_encode|raw }};
    
    new Chart(eventsByTypeCtx, {
        type: 'pie',
        data: {
            labels: eventsByTypeData.map(item => item.type.replace('_', ' ')),
            datasets: [{
                data: eventsByTypeData.map(item => item.count),
                backgroundColor: ['#2F5D52', '#3E6F64', '#9BC7B5', '#AFCFC2', '#6B7280'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { position: 'bottom' }
            }
        }
    });
    
    // Revenue by Event Bar Chart
    const revenueData = {{ revenueByEvent|json_encode|raw }};
    if (revenueData.length > 0) {
        const revenueCtx = document.getElementById('revenueByEventChart').getContext('2d');
        new Chart(revenueCtx, {
            type: 'bar',
            data: {
                labels: revenueData.map(item => item.title.length > 20 ? item.title.substring(0, 20) + '...' : item.title),
                datasets: [{
                    label: 'Revenue ($)',
                    data: revenueData.map(item => item.revenue),
                    backgroundColor: '#2F5D52',
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        title: { display: true, text: 'Revenue ($)' }
                    }
                }
            }
        });
    }
    
    // Registrations Over Time Line Chart
    const regTimeData = {{ registrationsOverTime|json_encode|raw }};
    const regTimeCtx = document.getElementById('registrationsOverTimeChart').getContext('2d');
    new Chart(regTimeCtx, {
        type: 'line',
        data: {
            labels: regTimeData.map(item => item.date),
            datasets: [{
                label: 'Daily Registrations',
                data: regTimeData.map(item => item.count),
                borderColor: '#2F5D52',
                backgroundColor: 'rgba(47, 93, 82, 0.1)',
                fill: true,
                tension: 0.4,
                pointBackgroundColor: '#3E6F64',
                pointBorderColor: 'white',
                pointRadius: 4,
                pointHoverRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                tooltip: { callbacks: { label: (ctx) => `${ctx.raw} registrations` } }
            },
            scales: {
                y: { beginAtZero: true, title: { display: true, text: 'Registrations' } },
                x: { title: { display: true, text: 'Date' } }
            }
        }
    });
    
    // Ticket Type Distribution Pie Chart
    const ticketTypeData = {{ ticketTypeDistribution|json_encode|raw }};
    const ticketTypeCtx = document.getElementById('ticketTypeChart').getContext('2d');
    new Chart(ticketTypeCtx, {
        type: 'doughnut',
        data: {
            labels: ticketTypeData.map(item => item.type),
            datasets: [{
                data: ticketTypeData.map(item => item.count),
                backgroundColor: ['#2F5D52', '#9BC7B5', '#AFCFC2', '#3E6F64'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: { legend: { position: 'bottom' } }
        }
    });
    
    // Status Distribution Pie Chart
    const statusData = {
        'CONFIRMED': {{ confirmedCount|default(0) }},
        'PENDING': {{ pendingCount|default(0) }},
        'CANCELLED': {{ cancelledCount|default(0) }}
    };
    const statusCtx = document.getElementById('statusChart').getContext('2d');
    new Chart(statusCtx, {
        type: 'pie',
        data: {
            labels: ['✅ Confirmed', '⏳ Pending', '❌ Cancelled'],
            datasets: [{
                data: [statusData.CONFIRMED, statusData.PENDING, statusData.CANCELLED],
                backgroundColor: ['#3E6F64', '#AFCFC2', '#D62828'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: { legend: { position: 'bottom' } }
        }
    });
</script>
{% endblock %}