    // Wrap everything in an IIFE to avoid global scope conflicts
    (function() {
        // Form validation
        const loginForm = document.getElementById('loginForm');
        if (loginForm) {
            loginForm.addEventListener('submit', function(event) {
                let isValid = true;
                document.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));
                
                const email = document.getElementById('inputEmail');
                const password = document.getElementById('inputPassword');
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                
                if (!email.value.trim()) {
                    email.classList.add('is-invalid');
                    document.getElementById('emailError').innerText = 'Email is required';
                    isValid = false;
                } else if (!emailRegex.test(email.value)) {
                    email.classList.add('is-invalid');
                    document.getElementById('emailError').innerText = 'Enter a valid email';
                    isValid = false;
                }
                
                if (!password.value) {
                    password.classList.add('is-invalid');
                    document.getElementById('passwordError').innerText = 'Password is required';
                    isValid = false;
                } else if (password.value.length < 6) {
                    password.classList.add('is-invalid');
                    document.getElementById('passwordError').innerText = 'Password must be at least 6 characters';
                    isValid = false;
                }
                
                if (!isValid) event.preventDefault();
            });
        }
        
        // Face ID Login
        const faceIdBtn = document.getElementById('faceIdLoginBtn');
        const faceModal = document.getElementById('faceIdModal');
        const closeFaceBtn = document.getElementById('closeFaceModalBtn');
        const captureFaceVerifyBtn = document.getElementById('captureFaceVerifyBtn');
        const faceVideoModal = document.getElementById('faceVideoModal');
        const faceCanvasModal = document.getElementById('faceCanvasModal');
        const faceStatus = document.getElementById('faceStatus');
        const faceProgress = document.getElementById('faceProgress');
        
        let mediaStream = null;
        let isProcessing = false;
        
        if (faceIdBtn) {
            faceIdBtn.onclick = startFaceLogin;
        }
        
        if (closeFaceBtn) {
            closeFaceBtn.onclick = stopFaceLogin;
        }
        
        function startFaceLogin() {
            faceModal.style.display = 'block';
            faceStatus.textContent = 'Initializing camera...';
            captureFaceVerifyBtn.disabled = true;
            faceProgress.style.width = '0%';
            
            navigator.mediaDevices.getUserMedia({ video: true })
                .then(function(stream) {
                    mediaStream = stream;
                    faceVideoModal.srcObject = stream;
                    faceStatus.textContent = 'Camera ready. Click Verify';
                    captureFaceVerifyBtn.disabled = false;
                    faceProgress.style.width = '50%';
                })
                .catch(function(err) {
                    faceStatus.textContent = '❌ Cannot access camera';
                    console.error(err);
                });
        }
        
        function stopFaceLogin() {
            if (mediaStream) {
                mediaStream.getTracks().forEach(function(track) { track.stop(); });
                mediaStream = null;
            }
            faceModal.style.display = 'none';
            if (faceVideoModal) {
                faceVideoModal.srcObject = null;
            }
            isProcessing = false;
        }
        
        if (captureFaceVerifyBtn) {
            captureFaceVerifyBtn.onclick = function() {
                if (isProcessing) return;
                isProcessing = true;
                
                captureFaceVerifyBtn.disabled = true;
                faceStatus.textContent = 'Verifying...';
                faceProgress.style.width = '75%';
                
                const ctx = faceCanvasModal.getContext('2d');
                faceCanvasModal.width = faceVideoModal.videoWidth;
                faceCanvasModal.height = faceVideoModal.videoHeight;
                ctx.drawImage(faceVideoModal, 0, 0, faceCanvasModal.width, faceCanvasModal.height);
                
                faceProgress.style.width = '85%';
                
                faceCanvasModal.toBlob(function(blob) {
                    const formData = new FormData();
                    formData.append('image', blob, 'face.jpg');
                    
                    fetch('/face/api/verify', {
                        method: 'POST',
                        body: formData
                    })
                    .then(function(response) { 
                        return response.json(); 
                    })
                    .then(function(result) {
                        faceProgress.style.width = '100%';
                        
                        if (result.success) {
                            faceStatus.textContent = '✅ Face recognized! Logging in...';
                            setTimeout(function() { 
                                if (result.redirect) {
                                    window.location.href = result.redirect;
                                } else {
                                    window.location.href = '/dashboard';
                                }
                            }, 1000);
                        } else {
                            faceStatus.textContent = '❌ ' + (result.message || 'Face not recognized');
                            captureFaceVerifyBtn.disabled = false;
                            faceProgress.style.width = '0%';
                            isProcessing = false;
                        }
                    })
                    .catch(function(error) {
                        console.error('Fetch error:', error);
                        faceStatus.textContent = '❌ Error: ' + error.message;
                        captureFaceVerifyBtn.disabled = false;
                        faceProgress.style.width = '0%';
                        isProcessing = false;
                    });
                }, 'image/jpeg');
            };
        }
        
        // Close on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && faceModal && faceModal.style.display === 'block') {
                stopFaceLogin();
            }
        });
    })();
