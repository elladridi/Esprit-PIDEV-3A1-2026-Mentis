{% extends "base.html.twig" %}

{% block title %}Login - Mentis{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-header">
        <h1>🧠 Mentis</h1>
        <p>Smart mental health platform for patients, psychologists and admins</p>
    </div>

    {% if error %}
        <div class="alert alert-danger" role="alert">
            <strong>Login Failed</strong><br>
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    <form method="post" novalidate>
        <div class="form-group">
            <label for="inputEmail" class="form-label">Email address</label>
            <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" class="form-control" autocomplete="email" required autofocus>
        </div>

        <div class="form-group">
            <label for="inputPassword" class="form-label">Password</label>
            <input type="password" name="_password" id="inputPassword" class="form-control" autocomplete="current-password" required>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMe">
                <label class="form-check-label" for="rememberMe">Remember me</label>
            </div>
            <a class="text-muted" href="#">Forgot password?</a>
        </div>

        <button type="submit" class="btn btn-primary">Sign in</button>
    </form>

    <div class="auth-link">
        Don't have an account? <a href="{{ path('app_register') }}">Register here</a>
    </div>
</div>
{% endblock %}
