{% extends 'base.html.twig' %}

{% block title %}Content Observability Logs{% endblock %}

{% block body %}
<style>
    .insight-panel {
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
        border-radius: 16px;
        color: #fff;
    }
    .insight-panel .insight-header {
        border-bottom: 1px solid rgba(255,255,255,0.15);
        padding-bottom: 12px;
        margin-bottom: 16px;
    }
    .insight-text {
        font-size: 0.97rem;
        line-height: 1.75;
        white-space: pre-wrap;
        color: #e0f7e9;
    }
    .btn-ai-insight {
        background: linear-gradient(135deg, #50C878, #3A9B5E);
        border: none;
        color: #fff;
        font-weight: 600;
        border-radius: 30px;
        padding: 10px 28px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(80,200,120,0.4);
    }
    .btn-ai-insight:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(80,200,120,0.5);
        color: #fff;
    }
    .btn-ai-insight:disabled {
        opacity: 0.7;
        transform: none;
    }
    .pulse-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #50C878;
        animation: pulse 1.5s infinite;
        margin-right: 6px;
    }
    @keyframes pulse {
        0%   { box-shadow: 0 0 0 0 rgba(80,200,120,0.6); }
        70%  { box-shadow: 0 0 0 8px rgba(80,200,120,0); }
        100% { box-shadow: 0 0 0 0 rgba(80,200,120,0); }
    }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="d-flex align-items-center gap-2">
                <h1 class="mb-0">Content Access Logs</h1>
                {% if fromCache %}
                    <span class="badge bg-secondary">Cached (refreshes every 5 min)</span>
                {% else %}
                    <span class="badge bg-success"><span class="pulse-dot"></span>Live data</span>
                {% endif %}
            </div>
            <p class="text-muted">Live observability with real assignment metrics.</p>
        </div>
        <form class="d-flex" method="get" action="{{ path('content_logs') }}">
            <input id="logsSearch" type="text" class="form-control me-2" name="q" placeholder="Search content" value="{{ searchTerm|default('') }}">
            <button class="btn btn-outline-success" type="submit">Search</button>
        </form>
        <small class="text-muted ms-3">Filter logs as you type.</small>
    </div>

    {# ═══════════════════════════════════════════════════════════ #}
    {# AI INSIGHT REPORT PANEL                                     #}
    {# ═══════════════════════════════════════════════════════════ #}
    <div class="insight-panel p-4 mb-5 shadow-lg">
        <div class="insight-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-1 fw-bold">
                    <i class="bi bi-stars me-2 text-warning"></i>AI Insight Report
                </h5>
                <small class="text-white-50">Powered by Groq — analyzes your real KPI data and generates actionable recommendations</small>
            </div>
            <button id="generateInsightBtn" class="btn-ai-insight">
                <i class="bi bi-magic me-2"></i>Generate Insight
            </button>
        </div>

        {# Placeholder before generation #}
        <div id="insightPlaceholder" class="text-center py-4 text-white-50">
            <i class="bi bi-bar-chart-line display-5 mb-3 d-block opacity-25"></i>
            <p class="mb-0">Click <strong class="text-white">"Generate Insight"</strong> to get an AI-powered analysis of your platform's content engagement data.</p>
        </div>

        {# Loading state #}
        <div id="insightLoading" class="text-center py-4 d-none">
            <div class="spinner-border text-success mb-3" role="status"></div>
            <p class="text-white-50 mb-0">Analyzing your KPI data with AI...</p>
        </div>

        {# Result #}
        <div id="insightResult" class="d-none">
            <div class="d-flex align-items-center mb-3">
                <i class="bi bi-robot text-success me-2 fs-5"></i>
                <span class="fw-semibold text-white">Mentis AI Analysis</span>
                <span class="ms-auto text-white-50 small" id="insightTimestamp"></span>
            </div>
            <div id="insightText" class="insight-text"></div>

            <div class="mt-4 pt-3 border-top border-white border-opacity-10 d-flex gap-2">
                <button id="regenerateInsightBtn" class="btn btn-sm btn-outline-light rounded-pill px-3">
                    <i class="bi bi-arrow-clockwise me-1"></i> Regenerate
                </button>
                <button id="copyInsightBtn" class="btn btn-sm btn-outline-light rounded-pill px-3">
                    <i class="bi bi-clipboard me-1"></i> Copy
                </button>
            </div>
        </div>

        {# Error state #}
        <div id="insightError" class="d-none">
            <div class="alert alert-danger mb-0">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <span id="insightErrorText"></span>
            </div>
        </div>
    </div>
    {# ═══════════════════════════════════════════════════════════ #}

    {# --- Raw Audit Table --- #}
    <div class="card border-0 shadow-sm mb-5">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <div>
                <h5 class="mb-0 fw-bold text-dark">
                    <i class="bi bi-journal-text me-2 text-success"></i>Mentis - Content Access Logs
                </h5>
                <small class="text-muted">Full audit trail of every content access event</small>
            </div>
            <a class="btn btn-danger btn-sm px-3" href="{{ path('content_logs_export_pdf') }}">
                <i class="bi bi-file-earmark-pdf me-1"></i> Export PDF
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-3">ID</th>
                            <th>User</th>
                            <th>Email</th>
                            <th>Content</th>
                            <th>Accessed At</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for log in pagination %}
                            <tr>
                                <td class="px-3 text-muted small">{{ log.id }}</td>
                                <td><span class="fw-semibold">{{ log.user.firstname }} {{ log.user.lastname }}</span></td>
                                <td class="text-muted small">{{ log.user.email }}</td>
                                <td>
                                    <span class="badge bg-success bg-opacity-10 text-success fw-semibold px-2 py-1">
                                        {{ log.contentNode.title }}
                                    </span>
                                </td>
                                <td class="text-muted small">{{ log.accessedAt|date('Y-m-d H:i:s') }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">No access records found.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-body border-top bg-white">
            {{ knp_pagination_render(pagination) }}
        </div>
        <div class="card-footer bg-white text-muted small py-2 px-3">
            Report generated on: {{ "now"|date("Y-m-d H:i:s") }} &nbsp;|&nbsp; {{ pagination.getTotalItemCount }} record(s)
        </div>
    </div>

    {# KPI Cards #}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 text-center p-3">
                <h6 class="text-muted mb-1">Total Content</h6>
                <h3 class="mb-0">{{ kpis.totalContent }}</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 text-center p-3">
                <h6 class="text-muted mb-1">Total Assignments</h6>
                <h3 class="mb-0">{{ kpis.totalAssigned }}</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 text-center p-3">
                <h6 class="text-muted mb-1">Total Opened</h6>
                <h3 class="mb-0">{{ kpis.totalOpened }}</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 text-center p-3">
                <h6 class="text-muted mb-1">Completion Rate</h6>
                <h3 class="mb-0">{{ kpis.overallCompletionRate }}%</h3>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white"><h6 class="mb-0">Top Completion Content</h6></div>
                <div class="card-body p-3">
                    <ul class="list-unstyled mb-0">
                        {% for entry in topContent %}
                            <li class="mb-2">
                                <strong>{{ entry.nodeTitle }}</strong> - {{ entry.completionRate }}% ({{ entry.totalOpened }}/{{ entry.totalAssigned }})
                            </li>
                        {% else %}
                            <li class="text-muted">No entries yet.</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white"><h6 class="mb-0">Lowest Completion Content</h6></div>
                <div class="card-body p-3">
                    <ul class="list-unstyled mb-0">
                        {% for entry in bottomContent %}
                            <li class="mb-2">
                                <strong>{{ entry.nodeTitle }}</strong> - {{ entry.completionRate }}% ({{ entry.totalOpened }}/{{ entry.totalAssigned }})
                            </li>
                        {% else %}
                            <li class="text-muted">No entries yet.</li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 text-center p-3">
                <h6 class="text-muted mb-1">Average Content Completion</h6>
                <h3 class="mb-0">{{ kpis.averageCompletion }}%</h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 text-center p-3">
                <h6 class="text-muted mb-1">Not Opened Yet</h6>
                <h3 class="mb-0">{{ kpis.totalNotOpened }}</h3>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white"><h6 class="mb-0">Completion by content</h6></div>
                <div class="card-body"><canvas id="completionChart" height="180"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white"><h6 class="mb-0">Assigned vs Opened ratio</h6></div>
                <div class="card-body"><canvas id="ratioChart" height="180"></canvas></div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>Content</th><th>Assigned</th><th>Opened</th><th>Completion</th><th>Not open yet</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in logs %}
                        <tr>
                            <td>{{ entry.nodeTitle }}</td>
                            <td>{{ entry.totalAssigned }}</td>
                            <td>{{ entry.totalOpened }}</td>
                            <td>{{ entry.completionRate }}%</td>
                            <td>{{ entry.notOpenedCount }}</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="text-center">No records found for this query.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white"><h5 class="mb-0">Recently Opened</h5></div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Content</th><th>User</th><th>Accessed</th></tr></thead>
                        <tbody>
                            {% for entry in logs %}
                                {% for path in entry.paths %}
                                    <tr>
                                        <td>{{ entry.nodeTitle }}</td>
                                        <td>{{ path.userFirstname }} {{ path.userLastname }}</td>
                                        <td>{{ path.accessedAt }}</td>
                                    </tr>
                                {% endfor %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white"><h5 class="mb-0">Pending Opens</h5></div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Content</th><th>Patient</th></tr></thead>
                        <tbody>
                            {% for entry in logs %}
                                {% for patient in entry.notOpened %}
                                    <tr>
                                        <td>{{ entry.nodeTitle }}</td>
                                        <td>{{ patient.firstname }} {{ patient.lastname }}</td>
                                    </tr>
                                {% endfor %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <a class="btn btn-secondary" href="{{ path('content_index') }}">
            <i class="bi bi-arrow-left me-1"></i> Back to Content Library
        </a>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {

    // ── Search filter ──
    const logsSearch = document.getElementById('logsSearch');
    const logRows    = document.querySelectorAll('table tbody tr');

    function filterLogs() {
        const query = logsSearch.value.trim().toLowerCase();
        logRows.forEach(row => {
            row.style.display = (!query || row.textContent.toLowerCase().includes(query)) ? 'table-row' : 'none';
        });
    }
    if (logsSearch) {
        logsSearch.addEventListener('input', filterLogs);
        filterLogs();
    }

    // ── Charts ──
    const completionLabels = {{ logs|map(entry => entry.nodeTitle)|json_encode|raw }};
    const completionData   = {{ logs|map(entry => entry.completionRate)|json_encode|raw }};
    const assignedData     = {{ logs|map(entry => entry.totalAssigned)|json_encode|raw }};
    const openedData       = {{ logs|map(entry => entry.totalOpened)|json_encode|raw }};

    new Chart(document.getElementById('completionChart').getContext('2d'), {
        type: 'bar',
        data: {
            labels: completionLabels,
            datasets: [{
                label: 'Completion %',
                data: completionData,
                backgroundColor: 'rgba(54,162,235,0.5)',
                borderColor: 'rgba(54,162,235,1)',
                borderWidth: 1
            }]
        },
        options: { responsive: true, scales: { y: { beginAtZero: true, max: 100, title: { display: true, text: 'Completion %' } } } }
    });

    new Chart(document.getElementById('ratioChart').getContext('2d'), {
        type: 'line',
        data: {
            labels: completionLabels,
            datasets: [
                { label: 'Assigned', data: assignedData, borderColor: 'rgba(99,132,255,1)', backgroundColor: 'rgba(99,132,255,0.4)', fill: false, tension: 0.2 },
                { label: 'Opened',   data: openedData,   borderColor: 'rgba(75,192,192,1)', backgroundColor: 'rgba(75,192,192,0.4)', fill: false, tension: 0.2 }
            ]
        },
        options: { responsive: true, scales: { y: { beginAtZero: true, title: { display: true, text: 'Users' } } } }
    });

    // ── AI Insight ──
    const kpis        = {{ kpis|json_encode|raw }};
    const logs        = {{ logs|json_encode|raw }};
    const topContent  = {{ topContent|json_encode|raw }};
    const bottomContent = {{ bottomContent|json_encode|raw }};

    const generateBtn     = document.getElementById('generateInsightBtn');
    const regenerateBtn   = document.getElementById('regenerateInsightBtn');
    const copyBtn         = document.getElementById('copyInsightBtn');
    const placeholder     = document.getElementById('insightPlaceholder');
    const loading         = document.getElementById('insightLoading');
    const result          = document.getElementById('insightResult');
    const insightText     = document.getElementById('insightText');
    const insightTimestamp = document.getElementById('insightTimestamp');
    const errorDiv        = document.getElementById('insightError');
    const errorText       = document.getElementById('insightErrorText');

    async function generateInsight() {
        // UI: show loading
        placeholder.classList.add('d-none');
        result.classList.add('d-none');
        errorDiv.classList.add('d-none');
        loading.classList.remove('d-none');
        generateBtn.disabled = true;
        generateBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Analyzing...';

        try {
            const response = await fetch('{{ path('content_logs_ai_insight') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    kpis:   kpis,
                    logs:   logs,
                    top:    topContent,
                    bottom: bottomContent
                })
            });

            const data = await response.json();

            loading.classList.add('d-none');

            if (data.success) {
                insightText.textContent = data.insight;
                insightTimestamp.textContent = 'Generated at ' + new Date().toLocaleTimeString();
                result.classList.remove('d-none');
            } else {
                errorText.textContent = data.error || 'AI service unavailable.';
                errorDiv.classList.remove('d-none');
            }
        } catch (e) {
            loading.classList.add('d-none');
            errorText.textContent = 'Network error: ' + e.message;
            errorDiv.classList.remove('d-none');
        } finally {
            generateBtn.disabled = false;
            generateBtn.innerHTML = '<i class="bi bi-magic me-2"></i>Generate Insight';
        }
    }

    generateBtn.addEventListener('click', generateInsight);
    if (regenerateBtn) regenerateBtn.addEventListener('click', generateInsight);

    if (copyBtn) {
        copyBtn.addEventListener('click', () => {
            navigator.clipboard.writeText(insightText.textContent).then(() => {
                copyBtn.innerHTML = '<i class="bi bi-check me-1"></i> Copied!';
                setTimeout(() => { copyBtn.innerHTML = '<i class="bi bi-clipboard me-1"></i> Copy'; }, 2000);
            });
        });
    }
});
</script>
{% endblock %}
