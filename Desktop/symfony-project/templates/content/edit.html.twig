{% extends 'base.html.twig' %}

{% block title %}Edit Content{% endblock %}

{% block body %}
<div class="content-dashboard p-4">
    <div class="container-lg">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h2 class="h4 mb-0">Edit Content</h2>
                <a class="btn btn-outline-secondary" href="{{ path('content_index') }}"><i class="bi bi-arrow-left"></i> Back to Library</a>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-6">{{ form_label(form.title) }} {{ form_widget(form.title, {attr: {class: 'form-control'}}) }} {{ form_errors(form.title) }}</div>
                    <div class="col-md-6">
                        {{ form_label(form.pdfPath) }}
                        {% if contentNode.pdfPath %}
                            <div class="mb-2">
                                <small class="text-muted">Current PDF: <a href="{{ asset(contentNode.pdfPath) }}" target="_blank">{{ contentNode.pdfPath|split('/')|last }}</a></small>
                            </div>
                        {% endif %}
                        {{ form_widget(form.pdfPath, {attr: {class: 'form-control'}}) }}
                        <small class="form-text text-muted">Leave empty to keep current PDF, or upload a new one to replace it.</small>
                        {{ form_errors(form.pdfPath) }}
                    </div>

                    <div class="col-12">{{ form_label(form.description) }} {{ form_widget(form.description, {attr: {class: 'form-control', rows: 5}}) }} {{ form_errors(form.description) }}</div>

                    <div class="col-md-6">{{ form_label(form.parentNode) }} {{ form_widget(form.parentNode, {attr: {class: 'form-select'}}) }} {{ form_errors(form.parentNode) }}</div>
                    <div class="col-md-6">
                        {{ form_label(form.assignedUsers) }}
                        {{ form_widget(form.assignedUsers, {attr: {class: 'form-select'}}) }}
                        <div class="form-text text-muted">Use Ctrl/Cmd + click to select multiple users.</div>
                        {{ form_errors(form.assignedUsers) }}
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-end gap-2">
                    <a class="btn btn-outline-danger" href="{{ path('content_index') }}"><i class="bi bi-x-circle"></i> Cancel</a>
                    <button class="btn btn-success" type="submit"><i class="bi bi-save"></i> Save Changes</button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
