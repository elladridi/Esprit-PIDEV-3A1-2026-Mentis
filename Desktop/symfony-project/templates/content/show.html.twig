{% extends 'base.html.twig' %}

{% block title %}Content Details{% endblock %}

{% block body %}
<div class="content-dashboard p-4">
    <div class="container-lg">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="h4 mb-0">{{ contentNode.title }}</h2>
                        <small class="text-muted">Created by {{ contentNode.createdBy.firstname }} {{ contentNode.createdBy.lastname }} • {{ contentNode.createdAt|date('j M Y, H:i') }}</small>
                    </div>
                    <div class="btn-group">
                        <a class="btn btn-outline-secondary" href="{{ path('content_index') }}"><i class="bi bi-grid-3x3-gap"></i> Library</a>
                        <button id="speakContentBtn" class="btn btn-success"><i class="bi bi-volume-up"></i> Read Aloud</button>
                        <button id="stopSpeakBtn" class="btn btn-outline-danger"><i class="bi bi-volume-mute"></i> Stop</button>
                        <button id="summarizeContentBtn" class="btn btn-info"><i class="bi bi-cpu"></i> AI Summary</button>
                        <button id="toggleChatBtn" class="btn btn-outline-primary" data-bs-toggle="collapse" data-bs-target="#aiChatSection"><i class="bi bi-chat-dots"></i> AI Discussion</button>
                        {% if is_granted('ROLE_ADMIN') or contentNode.createdBy.id == app.user.id %}
                            <a class="btn btn-primary" href="{{ path('content_edit', {id: contentNode.id}) }}"><i class="bi bi-pencil"></i> Edit</a>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="card-body">
                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="p-3 bg-light rounded-3 mb-3">
                            <h5 class="mb-2">Description</h5>
                            <div class="prose mb-0">{{ contentNode.description|default('No description for this item yet.')|markdown_to_html }}</div>
                        </div>

                        {% if contentNode.pdfPath is not empty %}
                            <div class="p-3 bg-white rounded-3 border mb-3">
                                <h5 class="mb-2">PDF Resource</h5>
                                <a class="btn btn-outline-primary" href="{{ asset(contentNode.pdfPublicPath) }}" target="_blank"><i class="bi bi-file-earmark-pdf"></i> Open PDF</a>
                            </div>
                        {% endif %}

                        <div id="summaryCtnr" class="p-3 bg-light rounded-3 mb-3" style="display:none;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="mb-0">AI-Generated Summary</h5>
                                <button class="btn btn-sm btn-outline-secondary" onclick="document.getElementById('summaryCtnr').style.display='none'"><i class="bi bi-x"></i></button>
                            </div>
                            <p id="summaryText" class="mb-0"></p>
                        </div>

                        <!-- AI Chat Section -->
                        <div id="aiChatSection" class="collapse mt-4">
                            <div class="card border rounded-3">
                                <div class="card-header bg-primary bg-opacity-10">
                                    <h5 class="mb-0"><i class="bi bi-chat-dots-fill"></i> AI Discussion & Support</h5>
                                </div>
                                <div class="card-body">
                                    <!-- Chat Messages Area -->
                                    <div id="chatMessages" class="chat-messages mb-3" style="height: 400px; overflow-y: auto; border: 1px solid #ddd; border-radius: 8px; padding: 15px; background-color: #f9f9f9;">
                                        <div class="text-center text-muted py-5">
                                            <small>Start a discussion about this content with AI assistance</small>
                                        </div>
                                    </div>

                                    <!-- Input Area -->
                                    <div class="input-group">
                                        <input 
                                            type="text" 
                                            id="chatInput" 
                                            class="form-control" 
                                            placeholder="Ask a question or share your thoughts..."
                                            autocomplete="off">
                                        <button 
                                            id="sendChatBtn" 
                                            class="btn btn-primary" 
                                            type="button"
                                            onclick="sendChatMessage()">
                                            <i class="bi bi-send"></i> Send
                                        </button>
                                    </div>

                                    <!-- Generate Content Button (Psychologist only) -->
                                    {% if is_granted('ROLE_PSYCHOLOGIST') %}
                                    <div class="mt-3 pt-3 border-top">
                                        <h6>Generate Reusable Content</h6>
                                        <div class="row g-2">
                                            <div class="col-md-8">
                                                <input 
                                                    type="text" 
                                                    id="generateTopic" 
                                                    class="form-control" 
                                                    placeholder="Enter topic for content generation..."
                                                    autocomplete="off">
                                            </div>
                                            <div class="col-md-3">
                                                <select id="generateType" class="form-select">
                                                    <option value="article">Article</option>
                                                    <option value="course">Course</option>
                                                    <option value="explanation">Explanation</option>
                                                </select>
                                            </div>
                                            <div class="col-md-1">
                                                <button 
                                                    id="generateBtn" 
                                                    class="btn btn-success w-100" 
                                                    onclick="generateContent()">
                                                    <i class="bi bi-sparkles"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Generated Content Display -->
                                    <div id="generatedContentContainer" style="display:none;" class="mt-3 pt-3 border-top">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <h6>Generated Content</h6>
                                            <button class="btn btn-sm btn-outline-secondary" onclick="document.getElementById('generatedContentContainer').style.display='none'"><i class="bi bi-x"></i></button>
                                        </div>
                                        <div id="generatedContentBody" class="p-3 bg-light rounded-3"></div>
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="p-3 border rounded-3 mb-3 bg-gradient-primary text-white">
                            <h6>Assigned users</h6>
                            <p class="fs-3 mb-0">{{ assignedUsers|length }}</p>
                        </div>

                        <div class="p-3 border rounded-3" style="max-height: 220px; overflow-y: auto;">
                            {% if assignedUsers is not empty %}
                                {% for assigned in assignedUsers %}
                                    <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                                        <span>{{ assigned.firstname }} {{ assigned.lastname }}</span>
                                        <span class="badge bg-success">{{ assigned.email }}</span>
                                    </div>
                                {% endfor %}
                            {% else %}
                                <div class="text-muted">No assigned users yet — assign from edit screen.</div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-footer text-end bg-white border-top">
                <a class="btn btn-outline-secondary" href="{{ path('content_index') }}"><i class="bi bi-arrow-left"></i> Return to list</a>
            </div>
        </div>
    </div>
</div>

<style>
    .chat-messages {
        display: flex;
        flex-direction: column;
    }

    .prose h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 1rem 0 0.5rem;
        color: #212529;
    }

    .prose p {
        margin-bottom: 0.75rem;
        line-height: 1.7;
        color: #495057;
    }

    .prose ul {
        margin: 0.75rem 0 0.75rem 1.25rem;
        padding-left: 0.75rem;
    }

    .prose li {
        margin-bottom: 0.4rem;
    }

    .chat-message {
        margin-bottom: 15px;
        display: flex;
        animation: slideIn 0.3s ease-out;
    }

    @keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .chat-message.user {
        justify-content: flex-end;
    }

    .chat-message.ai {
        justify-content: flex-start;
    }

    .message-bubble {
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 12px;
        word-wrap: break-word;
        line-height: 1.4;
    }

    .message-bubble.user {
        background-color: #50C878;
        color: white;
        border-bottom-right-radius: 4px;
    }

    .message-bubble.ai {
        background-color: #e9ecef;
        color: #333;
        border-bottom-left-radius: 4px;
    }

    .message-time {
        font-size: 0.75rem;
        color: #999;
        margin-top: 4px;
    }

    .loading-bubble {
        background-color: #e9ecef;
        padding: 12px 16px;
        border-radius: 12px;
    }

    .loading-dots {
        display: inline-flex;
        gap: 4px;
    }

    .loading-dots span {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: #999;
        animation: bounce 1.4s ease-in-out infinite;
    }

    .loading-dots span:nth-child(2) {
        animation-delay: 0.2s;
    }

    .loading-dots span:nth-child(3) {
        animation-delay: 0.4s;
    }

    @keyframes bounce {
        0%, 80%, 100% {
            transform: scale(0.8);
            opacity: 0.5;
        }
        40% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>
{% endblock %}

{% block javascripts %}
    <script>
        const csrfToken = '{{ csrf_token('api_summarize_content') }}';
        const contentId = {{ contentNode.id }};
        const speakBtn = document.getElementById('speakContentBtn');
        const stopBtn = document.getElementById('stopSpeakBtn');
        const summarizeBtn = document.getElementById('summarizeContentBtn');
        const chatInput = document.getElementById('chatInput');
        const sendChatBtn = document.getElementById('sendChatBtn');
        let utterance;

        // Initialize chat
        function initChat() {
            if (chatInput) {
                chatInput.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        sendChatMessage();
                    }
                });
            }
        }

        function speakText(text) {
            if ('speechSynthesis' in window) {
                window.speechSynthesis.cancel();
                utterance = new SpeechSynthesisUtterance(text);
                utterance.rate = 1.0;
                utterance.pitch = 1.0;
                utterance.lang = 'en-US';
                window.speechSynthesis.speak(utterance);
            } else {
                alert('Your browser does not support speech synthesis.');
            }
        }

        if (speakBtn) {
            speakBtn.addEventListener('click', () => {
                const title = '{{ contentNode.title|e('js') }}';
                let description = '{{ contentNode.description|default('No description provided.')|e('js') }}';
                if (!description) {
                    description = 'No description provided.';
                }
                speakText(`Title: ${title}. Description: ${description}`);
            });
        }

        if (stopBtn) {
            stopBtn.addEventListener('click', () => {
                window.speechSynthesis.cancel();
            });
        }

        if (summarizeBtn) {
            summarizeBtn.addEventListener('click', async () => {
                summarizeBtn.disabled = true;
                summarizeBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Generating...';

                try {
                    const headers = { 'Content-Type': 'application/json' };
                    if (csrfToken) {
                        headers['X-CSRF-TOKEN'] = csrfToken;
                    }

                    const response = await fetch('{{ path('api_summarize_content') }}', {
                        method: 'POST',
                        headers: headers,
                        body: JSON.stringify({
                            title: '{{ contentNode.title|e('js') }}',
                            description: '{{ contentNode.description|default('No description provided.')|e('js') }}'
                        })
                    });

                    console.log('Response status:', response.status);
                    
                    const text = await response.text();
                    console.log('Response text:', text);
                    
                    if (!response.ok) {
                        alert('Error: ' + response.status + ' - ' + text.substring(0, 100));
                        return;
                    }

                    try {
                        const data = JSON.parse(text);
                        if (data.summary) {
                            document.getElementById('summaryText').textContent = data.summary;
                            document.getElementById('summaryCtnr').style.display = 'block';
                        } else {
                            alert('Error: ' + (data.error || 'No summary generated'));
                        }
                    } catch (e) {
                        alert('Failed to parse response: ' + e.message);
                    }
                } catch (error) {
                    console.error('Fetch error:', error);
                    alert('Network error: ' + error.message);
                } finally {
                    summarizeBtn.disabled = false;
                    summarizeBtn.innerHTML = '<i class="bi bi-cpu"></i> AI Summary';
                }
            });
        }

        // AI Chat Functions
        function addChatMessage(message, isUser = false) {
            const messagesContainer = document.getElementById('chatMessages');
            
            // Clear initial placeholder if it's the first message
            if (messagesContainer.querySelector('.text-center')) {
                messagesContainer.innerHTML = '';
            }

            const messageElement = document.createElement('div');
            messageElement.className = `chat-message ${isUser ? 'user' : 'ai'}`;
            messageElement.innerHTML = `
                <div>
                    <div class="message-bubble ${isUser ? 'user' : 'ai'}">
                        ${escapeHtml(message)}
                    </div>
                    <div class="message-time text-end">${new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</div>
                </div>
            `;
            
            messagesContainer.appendChild(messageElement);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        function addLoadingMessage() {
            const messagesContainer = document.getElementById('chatMessages');
            const loadingElement = document.createElement('div');
            loadingElement.className = 'chat-message ai';
            loadingElement.id = 'loadingMessage';
            loadingElement.innerHTML = `
                <div class="loading-bubble">
                    <div class="loading-dots">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                </div>
            `;
            messagesContainer.appendChild(loadingElement);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        function removeLoadingMessage() {
            const loadingElement = document.getElementById('loadingMessage');
            if (loadingElement) {
                loadingElement.remove();
            }
        }

        async function sendChatMessage() {
            const message = chatInput.value.trim();
            if (!message) return;

            // Disable input while sending
            chatInput.disabled = true;
            sendChatBtn.disabled = true;

            // Add user message to chat
            addChatMessage(message, true);
            chatInput.value = '';

            // Show loading indicator
            addLoadingMessage();

            try {
                const response = await fetch('{{ path('content_ai_chat') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': csrfToken
                    },
                    body: JSON.stringify({ message: message })
                });

                const data = await response.json();

                removeLoadingMessage();

                if (data.success) {
                    addChatMessage(data.message, false);
                } else {
                    addChatMessage('Sorry, I encountered an error: ' + (data.error || 'Unknown error'), false);
                }
            } catch (error) {
                console.error('Chat error:', error);
                removeLoadingMessage();
                addChatMessage('Sorry, there was a connection error. Please try again.', false);
            } finally {
                chatInput.disabled = false;
                sendChatBtn.disabled = false;
                chatInput.focus();
            }
        }

        async function generateContent() {
            const topic = document.getElementById('generateTopic').value.trim();
            const type = document.getElementById('generateType').value;

            if (!topic) {
                alert('Please enter a topic');
                return;
            }

            const generateBtn = document.getElementById('generateBtn');
            generateBtn.disabled = true;
            generateBtn.innerHTML = '<i class="bi bi-hourglass-split"></i>';

            try {
                const response = await fetch('{{ path('content_generate_content') }}', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': csrfToken
                    },
                    body: JSON.stringify({ 
                        topic: topic,
                        contentType: type
                    })
                });

                const data = await response.json();

                if (data.success && data.content) {
                    displayGeneratedContent(data.content);
                } else {
                    alert('Error: ' + (data.error || 'Failed to generate content'));
                }
            } catch (error) {
                console.error('Generation error:', error);
                alert('An error occurred: ' + error.message);
            } finally {
                generateBtn.disabled = false;
                generateBtn.innerHTML = '<i class="bi bi-sparkles"></i>';
            }
        }

        function displayGeneratedContent(content) {
            const container = document.getElementById('generatedContentContainer');
            const body = document.getElementById('generatedContentBody');

            let html = `<h6>${escapeHtml(content.title)}</h6>`;
            
            if (content.sections && Array.isArray(content.sections)) {
                content.sections.forEach(section => {
                    html += `<h6 class="mt-3"><strong>${escapeHtml(section.heading)}</strong></h6>`;
                    if (section.paragraphs && Array.isArray(section.paragraphs)) {
                        section.paragraphs.forEach(paragraph => {
                            html += `<p class="mb-2">${escapeHtml(paragraph)}</p>`;
                        });
                    }
                });
            }

            html += `<small class="text-muted d-block mt-3">Generated on ${new Date().toLocaleString()}</small>`;

            body.innerHTML = html;
            container.style.display = 'block';
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', initChat);
    </script>
{% endblock %}