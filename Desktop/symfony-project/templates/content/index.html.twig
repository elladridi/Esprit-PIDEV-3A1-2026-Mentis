{% extends 'base.html.twig' %}

{% block title %}Content Hub{% endblock %}

{% macro renderParentTree(node, ancestors = []) %}
    {% if node.parentNode is not null %}
        {% set ancestors = ancestors|merge([node.parentNode.title]) %}
        {{ _self.renderParentTree(node.parentNode, ancestors) }}
    {% elseif ancestors|length > 0 %}
        <div class="content-tree small text-muted mb-2">
            <i class="bi bi-diagram-3 me-1"></i>
            {{ ancestors|reverse|join(' > ') }}
        </div>
    {% endif %}
{% endmacro %}

{% block body %}
<style>
    .section-tab {
        cursor: pointer;
        padding: 15px 25px;
        font-weight: 600;
        color: #6c757d;
        border-bottom: 3px solid transparent;
        transition: all 0.3s ease;
    }
    .section-tab.active {
        color: #50C878;
        border-bottom-color: #50C878;
    }
    .content-section {
        display: none;
        animation: fadeIn 0.5s ease-out;
    }
    .content-section.active {
        display: block;
    }
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .content-card {
        border-radius: 15px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .content-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.1) !important;
    }
    .btn-primary-custom {
        background: linear-gradient(135deg, #50C878 0%, #3A9B5E 100%);
        border: none;
        color: white;
    }
    .btn-outline-custom {
        border: 2px solid #50C878;
        color: #50C878;
        font-weight: 600;
    }
    .btn-outline-custom:hover {
        background: #50C878;
        color: white;
    }
    .pagination {
        justify-content: center;
    }
    .card-actions {
        display: flex;
        gap: 6px;
    }
    .btn-action {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        border: none;
        transition: all 0.2s ease;
        padding: 0;
    }
    .btn-action-edit {
        background: #e8f5e9;
        color: #3A9B5E;
    }
    .btn-action-edit:hover {
        background: #50C878;
        color: white;
    }
    .btn-action-delete {
        background: #fdecea;
        color: #dc3545;
    }
    .btn-action-delete:hover {
        background: #dc3545;
        color: white;
    }
    .btn-action-view {
        background: #e3f2fd;
        color: #1976d2;
    }
    .btn-action-view:hover {
        background: #1976d2;
        color: white;
    }
</style>

<div class="content-dashboard px-3 py-4">
    <div class="container-lg">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
            <div>
                <h1 class="display-6 fw-bold text-dark">Content Hub</h1>
                <p class="text-muted">Personalized recommendations, content library, and AI assistance.</p>
            </div>
            <div class="d-flex gap-2">
                {% if is_granted_admin or isPsychologist %}
                    <a class="btn btn-primary-custom px-4 py-2 rounded-pill shadow-sm" href="{{ path('content_new') }}">
                        <i class="bi bi-plus-lg me-1"></i> Create Content
                    </a>
                {% endif %}
            </div>
        </div>

        <!-- Section Tabs -->
        <div class="d-flex border-bottom mb-4 bg-white rounded-top shadow-sm px-2 overflow-auto">
            <div class="section-tab active" data-target="recommendations-section">
                <i class="bi bi-book me-2"></i>Recommended Books
            </div>
            <div class="section-tab" data-target="library-section">
                <i class="bi bi-collection me-2"></i>Content Library
            </div>
            <div class="section-tab" data-target="ai-assistant-section">
                <i class="bi bi-robot me-2"></i>AI Assistant
            </div>
            {% if is_granted_admin %}
                <a href="{{ path('content_logs') }}" class="section-tab text-decoration-none" style="border-bottom: none;">
                    <i class="bi bi-bar-chart-line me-2"></i>Usage Logs
                </a>
            {% endif %}
        </div>

        <!-- 1. Recommended Books Section -->
        <div id="recommendations-section" class="content-section active">
            {% if recommendations is defined and recommendations %}
                <div class="row g-4">
                    {% for book in recommendations %}
                    <div class="col-sm-6 col-md-4 col-lg-3">
                        <div class="card h-100 shadow-sm border-0 content-card">
                            {% if book.image %}
                            <div class="position-relative">
                                <img src="{{ book.image }}" class="card-img-top" alt="{{ book.title }}" style="height: 240px; object-fit: cover; border-top-left-radius: 15px; border-top-right-radius: 15px;">
                                <div class="position-absolute top-0 end-0 m-2">
                                    <span class="badge bg-white text-dark shadow-sm px-2 py-1"><i class="bi bi-star-fill text-warning"></i> Recommended</span>
                                </div>
                            </div>
                            {% endif %}
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title fw-bold text-dark mb-1">{{ book.title }}</h5>
                                <p class="text-primary small mb-3">by {{ book.author }}</p>
                                <p class="card-text text-muted small mb-4">{{ book.description|slice(0, 120) ~ (book.description|length > 120 ? '...' : '') }}</p>
                                <div class="mt-auto">
                                    <a href="{{ book.link }}" target="_blank" class="btn btn-sm btn-outline-success w-100 rounded-pill">View Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-5">
                    <img src="https://cdn-icons-png.flaticon.com/512/3330/3330314.png" alt="No books" style="width: 120px; opacity: 0.5;">
                    <h5 class="mt-3 text-muted">No recommendations found yet.</h5>
                </div>
            {% endif %}
        </div>

        <!-- 2. Content Library Section -->
        <div id="library-section" class="content-section">
            <div class="bg-white p-3 rounded-3 shadow-sm mb-4">
                <div class="row g-2 align-items-center">
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search text-muted"></i></span>
                            <input id="contentSearch" class="form-control border-start-0" type="search" placeholder="Search your library..." value="{{ searchTerm|default('') }}" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-sort-down text-muted"></i></span>
                            <select id="contentSort" class="form-select border-start-0">
                                <option value="desc" {{ sortOrder|default('desc') == 'desc' ? 'selected' : '' }}>Newest First</option>
                                <option value="asc" {{ sortOrder|default('desc') == 'asc' ? 'selected' : '' }}>Oldest First</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2 text-end">
                        <span class="text-muted small" id="contentCount">{{ nodes.getTotalItemCount }} items</span>
                    </div>
                </div>
            </div>

            <div class="row g-4" id="contentContainer">
                {% for node in nodes %}
                    <div class="col-sm-12 col-md-6 col-lg-4 content-item-wrapper" data-title="{{ node.title|lower }}" data-desc="{{ node.description|lower }}">
                        <div class="card h-100 shadow-sm border-0 content-card">
                            <div class="card-body d-flex flex-column p-4">

                                {# ── Card Header: title + action buttons ── #}
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h3 class="h5 card-title fw-bold text-dark mb-0 me-2" style="flex:1;">
                                        {{ node.title }}
                                    </h3>

                                    {# Always visible action buttons — no hidden dropdown #}
                                    <div class="card-actions flex-shrink-0">
                                        {# View button — always visible to everyone #}
                                        <a href="{{ path('content_show', {id: node.id}) }}"
                                           class="btn-action btn-action-view"
                                           title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        {# Edit & Delete — only for owner or admin #}
                                        {% if is_granted_admin or node.createdBy.id == app.user.id %}
                                            <a href="{{ path('content_edit', {id: node.id}) }}"
                                               class="btn-action btn-action-edit"
                                               title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>

                                            <form method="post"
                                                  action="{{ path('content_delete', {id: node.id}) }}"
                                                  style="display:inline;"
                                                  onsubmit="return confirm('Are you sure you want to delete « {{ node.title|e('js') }} »?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete-content' ~ node.id) }}">
                                                <button type="submit"
                                                        class="btn-action btn-action-delete"
                                                        title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </div>

                                {{ _self.renderParentTree(node) }}

                                <p class="card-text text-muted small mb-4" style="height: 4.5em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                                    {{ node.description|default('No description provided for this content.') }}
                                </p>

                                <div class="mt-auto">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="bg-light rounded-circle p-2 me-2">
                                            <i class="bi bi-person text-success"></i>
                                        </div>
                                        <div class="small">
                                            <div class="text-dark fw-semibold">{{ node.createdBy.firstname }} {{ node.createdBy.lastname }}</div>
                                            <div class="text-muted">{{ node.createdAt|date('M j, Y') }}</div>
                                        </div>
                                    </div>
                                    <a class="btn btn-primary-custom w-100 rounded-pill shadow-sm" href="{{ path('content_show', {id: node.id}) }}">
                                        Read More <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12 text-center py-5">
                        <div class="alert alert-light border shadow-sm p-5 rounded-4">
                            <i class="bi bi-folder2-open display-4 text-muted mb-3 d-block"></i>
                            <h4 class="text-dark">Your library is empty</h4>
                            <p class="text-muted">Start by creating your first content or wait for your psychologist to assign some.</p>
                            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_PSYCHOLOGIST') %}
                                <a class="btn btn-primary-custom px-4 py-2 rounded-pill mt-2" href="{{ path('content_new') }}">Create Content</a>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
            <div class="mt-4">
                {{ knp_pagination_render(nodes) }}
            </div>
        </div>

        <!-- 3. AI Assistant Section -->
        <div id="ai-assistant-section" class="content-section">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 mb-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3">AI Assistant</h5>
                            <p class="text-muted small mb-4">Ask about mental health topics, request explanations, or generate structured content if you're a professional.</p>
                            
                            <div class="mb-3">
                                <label class="form-label fw-semibold small">Discussion Context</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-tag text-muted"></i></span>
                                    <input id="aiTopic" class="form-control bg-light border-start-0" type="text" placeholder="e.g. stress management" value="{{ chatTopic }}" />
                                </div>
                            </div>

                            {% if isPsychologist %}
                                <div class="mb-3">
                                    <label class="form-label fw-semibold small">Content Type</label>
                                    <select id="aiContentType" class="form-select bg-light">
                                        <option value="article">Article</option>
                                        <option value="course">Course</option>
                                        <option value="explanation">Explanation</option>
                                    </select>
                                </div>
                                <button id="generateContentButton" type="button" class="btn btn-outline-primary w-100 rounded-pill">
                                    <i class="bi bi-magic me-1"></i> Generate Pro Content
                                </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
                
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                        <div class="card-header bg-white p-3 border-0 d-flex align-items-center">
                            <div class="bg-success bg-opacity-10 p-2 rounded-circle me-3">
                                <i class="bi bi-robot text-success"></i>
                            </div>
                            <h6 class="mb-0 fw-bold">Active Discussion</h6>
                        </div>
                        <div class="card-body p-0">
                            <div id="aiChatWindow" class="p-4" style="height: 450px; overflow-y: auto; background: #fdfdfd;">
                                <div class="text-center py-5 text-muted">
                                    <i class="bi bi-chat-left-text display-6 mb-3 d-block opacity-25"></i>
                                    <p>How can I help you today?</p>
                                </div>
                            </div>
                            <div id="aiErrorAlert" class="mx-4 mt-3 alert alert-danger d-none" role="alert"></div>
                            <div class="p-3 border-top bg-white">
                                <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                                    <textarea id="aiMessage" class="form-control border-0 px-4 py-3" rows="1" placeholder="Type your message..." style="resize: none;"></textarea>
                                    <button id="sendAiMessage" class="btn btn-primary-custom px-4" style="border-radius: 0;">
                                        <i class="bi bi-send-fill"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    {% if isPsychologist %}
                    <div id="generatedContentPanel" class="card shadow-lg border-0 rounded-4 mt-4 d-none animate-fadeIn">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                                <h5 class="fw-bold text-dark mb-0"><i class="bi bi-stars text-warning me-2"></i>Generated AI Content</h5>
                                <button id="saveGeneratedButton" type="button" class="btn btn-success btn-sm rounded-pill px-3">
                                    <i class="bi bi-cloud-arrow-up me-1"></i> Save to Platform
                                </button>
                            </div>
                            <div id="aiGeneratedContent" class="prose"></div>
                        </div>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        // --- Tab Management ---
        const tabs = document.querySelectorAll('.section-tab');
        const sections = document.querySelectorAll('.content-section');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                const target = tab.getAttribute('data-target');
                tabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                sections.forEach(s => {
                    s.classList.remove('active');
                    if (s.id === target) s.classList.add('active');
                });
            });
        });

        // --- Search & Filter ---
        const searchInput = document.getElementById('contentSearch');
        const sortSelect = document.getElementById('contentSort');
        const wrappers = document.querySelectorAll('.content-item-wrapper');
        const countSpan = document.getElementById('contentCount');

        function updateLibrary() {
            const query = searchInput.value.trim().toLowerCase();
            let visibleCount = 0;
            wrappers.forEach(w => {
                const title = w.getAttribute('data-title');
                const desc = w.getAttribute('data-desc');
                const matches = !query || title.includes(query) || desc.includes(query);
                w.style.display = matches ? 'block' : 'none';
                if (matches) visibleCount++;
            });
            countSpan.textContent = `${visibleCount} item${visibleCount !== 1 ? 's' : ''}`;
        }

        if (searchInput) searchInput.addEventListener('input', updateLibrary);

        if (sortSelect) {
            sortSelect.addEventListener('change', () => {
                const url = new URL(window.location.href);
                url.searchParams.set('sort', sortSelect.value);
                window.location.href = url.toString();
            });
        }

        // --- AI Chat Logic ---
        const aiChatWindow = document.getElementById('aiChatWindow');
        const aiMessage = document.getElementById('aiMessage');
        const aiTopic = document.getElementById('aiTopic');
        const sendAiMessage = document.getElementById('sendAiMessage');
        const aiErrorAlert = document.getElementById('aiErrorAlert');
        const generatedContentPanel = document.getElementById('generatedContentPanel');
        const aiGeneratedContent = document.getElementById('aiGeneratedContent');
        const generateContentButton = document.getElementById('generateContentButton');
        const aiContentType = document.getElementById('aiContentType');
        const saveGeneratedButton = document.getElementById('saveGeneratedButton');

        let lastGeneratedContent = null;

        function appendAiBubble(role, text) {
            const isUser = role === 'user';
            const bubble = document.createElement('div');
            bubble.className = `d-flex mb-4 ${isUser ? 'justify-content-end' : ''}`;
            const content = `
                <div class="d-flex ${isUser ? 'flex-row-reverse' : ''}">
                    <div class="bg-${isUser ? 'primary text-white' : 'white border'} p-3 rounded-4 shadow-sm" style="max-width: 85%;">
                        <div class="small fw-bold mb-1 opacity-75">${isUser ? 'You' : 'Mentis AI'}</div>
                        <div style="white-space: pre-wrap;">${text}</div>
                    </div>
                </div>
            `;
            bubble.innerHTML = content;
            if (aiChatWindow.querySelector('.text-center.py-5')) {
                aiChatWindow.innerHTML = '';
            }
            aiChatWindow.appendChild(bubble);
            aiChatWindow.scrollTop = aiChatWindow.scrollHeight;
        }

        function showAiError(message) {
            aiErrorAlert.textContent = message;
            aiErrorAlert.classList.remove('d-none');
        }

        async function sendAiRequest(url, payload) {
            try {
                aiErrorAlert.classList.add('d-none');
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!response.ok) throw new Error('AI service unavailable.');
                return await response.json();
            } catch (error) {
                showAiError(error.message);
                return null;
            }
        }

        async function handleChat() {
            const text = aiMessage.value.trim();
            if (!text) return;
            appendAiBubble('user', text);
            aiMessage.value = '';
            const result = await sendAiRequest('{{ path('content_ai_chat') }}', {
                message: text,
                topic: aiTopic.value
            });
            if (result && result.success) {
                appendAiBubble('ai', result.message);
            }
        }

        async function handleGeneration() {
            const topic = aiTopic.value.trim();
            if (!topic) {
                showAiError('Please enter a topic context first.');
                return;
            }
            generateContentButton.disabled = true;
            generateContentButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Generating...';
            const result = await sendAiRequest('{{ path('content_generate_content') }}', {
                topic: topic,
                contentType: aiContentType.value
            });
            if (result && result.success) {
                lastGeneratedContent = result.content;
                aiGeneratedContent.innerHTML = `
                    <h4 class="fw-bold text-primary mb-3">${result.content.title}</h4>
                    ${result.content.sections.map(s => `
                        <div class="mb-4">
                            <h6 class="fw-bold text-dark">${s.heading}</h6>
                            <p class="text-muted">${s.paragraphs.join('</p><p class="text-muted">')}</p>
                        </div>
                    `).join('')}
                `;
                generatedContentPanel.classList.remove('d-none');
                generatedContentPanel.scrollIntoView({ behavior: 'smooth' });
            }
            generateContentButton.disabled = false;
            generateContentButton.innerHTML = '<i class="bi bi-magic me-1"></i> Generate Pro Content';
        }

        if (sendAiMessage) sendAiMessage.addEventListener('click', handleChat);
        if (generateContentButton) generateContentButton.addEventListener('click', handleGeneration);

        if (saveGeneratedButton) {
            saveGeneratedButton.addEventListener('click', async () => {
                if (!lastGeneratedContent) return;
                saveGeneratedButton.disabled = true;
                const result = await sendAiRequest('{{ path('content_save_generated') }}', lastGeneratedContent);
                if (result && result.success) {
                    alert('Content saved to your library!');
                    window.location.reload();
                }
                saveGeneratedButton.disabled = false;
            });
        }
    });
</script>
{% endblock %}
