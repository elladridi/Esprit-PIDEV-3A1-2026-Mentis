{% extends 'base.html.twig' %}

{% block title %}Content Management{% endblock %}

{% macro renderParentTree(node, ancestors = []) %}
    {% if node.parentNode is not null %}
        {% set ancestors = ancestors|merge([node.parentNode.title]) %}
        {{ _self.renderParentTree(node.parentNode, ancestors) }}
    {% elseif ancestors|length > 0 %}
        <div class="content-tree small text-muted mb-2">
            <i class="bi bi-diagram-3 me-1"></i>
            {{ ancestors|reverse|join(' > ') }}
        </div>
    {% endif %}
{% endmacro %}

{% block body %}
<div class="content-dashboard px-3 py-4">
    <div class="container-lg">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom border-2 border-light">
            <div>
                <h1 class="display-6 fw-bold">Content Management</h1>
                <p class="text-secondary">Centralize content delivery, assignments, and usage analytics in one workspace.</p>
            </div>

            <form class="d-flex align-items-center me-3" method="get" action="{{ path('content_index') }}">
                <input id="contentSearch" class="form-control form-control-sm me-2" name="q" type="search" placeholder="Search content..." value="{{ searchTerm|default('') }}" autofocus />
                <select name="sort" class="form-select form-select-sm me-2" style="width: 170px;">
                    <option value="desc" {{ sortOrder|default('desc') == 'desc' ? 'selected' : '' }}>Newest first</option>
                    <option value="asc" {{ sortOrder|default('desc') == 'asc' ? 'selected' : '' }}>Oldest first</option>
                </select>
                <button class="btn btn-sm btn-outline-white" type="submit">Search</button>
            </form>

            <div class="d-flex flex-wrap gap-2">
                {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_PSYCHOLOGIST') %}
                    <a class="btn btn-outline-light btn-lg" href="{{ path('content_new') }}" style="color: #50C878;">
                        <i class="bi bi-plus-lg me-1"></i> New Content
                    </a>
                {% endif %}
                {% if is_granted('ROLE_ADMIN') %}
                    <a class="btn btn-outline-info btn-lg" href="{{ path('content_logs') }}"><i class="bi bi-bar-chart-line me-1"></i> Usage Logs</a>
                {% endif %}
            </div>
        </div>

        <div class="row g-4">
            {% for node in nodes %}
                <div class="col-sm-12 col-md-6 col-xl-4">
                    <div class="card h-100 shadow border-0 overflow-hidden content-card">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h3 class="h5 card-title text-white">{{ node.title }}</h3>
                                <span class="badge bg-secondary">{{ node.id }}</span>
                            </div>
                            <p class="card-text text-muted mb-3" style="min-height: 58px;">{{ node.description|default('No description')|slice(0, 120) ~ (node.description|length > 120 ? '…' : '') }}</p>
                            
                            {{ _self.renderParentTree(node) }}

                            <ul class="list-unstyled small text-white-75 mb-3">
                                <li><strong>Creator:</strong> {{ node.createdBy.firstname }} {{ node.createdBy.lastname }}</li>
                                <li><strong>Assigned:</strong> {{ node.assignedUsers|length }}</li>
                            </ul>

                            <div class="mt-auto">
                                <div class="mb-2 overflow-auto" style="max-height: 70px;">
                                    {% for userId in node.assignedUsers %}
                                        {% set assignedUser = assignedUserMap[userId] ?? null %}
                                        {% if assignedUser %}
                                            <span class="badge bg-light text-dark me-1 mb-1">{{ assignedUser.firstname }} {{ assignedUser.lastname }}</span>
                                        {% else %}
                                            <span class="badge bg-secondary me-1 mb-1">#{{ userId }}</span>
                                        {% endif %}
                                    {% endfor %}
                                </div>

                                <div class="d-flex gap-2">
                                    <a class="btn btn-sm btn-light w-100" href="{{ path('content_show', {id: node.id}) }}"><i class="bi bi-eye"></i> View</a>
                                    {% if is_granted('ROLE_ADMIN') or node.createdBy.id == app.user.id %}
                                        <a class="btn btn-sm btn-light w-100" href="{{ path('content_edit', {id: node.id}) }}"><i class="bi bi-pencil"></i> Edit</a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent text-muted small border-0">
                            Created {{ node.createdAt|date('j M Y, H:i') }}
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="alert alert-warning border-0 rounded-3 shadow-sm">No content has been created yet. Click "New Content" to begin.</div>
                </div>
            {% endfor %}
        </div>

        <div class="mt-4">
            {{ knp_pagination_render(nodes) }}
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('contentSearch');
            const cards = document.querySelectorAll('.content-card');

            function filterContent() {
                const query = searchInput.value.trim().toLowerCase();
                let visibleCount = 0;

                cards.forEach(card => {
                    const title = card.querySelector('.card-title')?.textContent?.toLowerCase() || '';
                    const description = card.querySelector('.card-text')?.textContent?.toLowerCase() || '';

                    const matches = !query || title.includes(query) || description.includes(query);
                    card.style.display = matches ? 'block' : 'none';
                    if (matches) visibleCount++;
                });

                const existing = document.getElementById('noResultsMessage');
                if (visibleCount === 0) {
                    if (!existing) {
                        const container = document.createElement('div');
                        container.id = 'noResultsMessage';
                        container.className = 'alert alert-warning mt-4';
                        container.textContent = 'No content matches your search.';
                        document.querySelector('.row.g-4').appendChild(container);
                    }
                } else if (existing) {
                    existing.remove();
                }
            }

            if (searchInput) {
                searchInput.addEventListener('input', filterContent);
                filterContent();
            }
        });
    </script>
{% endblock %}