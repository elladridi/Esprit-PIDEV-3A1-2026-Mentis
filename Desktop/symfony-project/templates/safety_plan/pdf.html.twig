<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
    font-family: DejaVu Sans, sans-serif;
    font-size: 12px;
    color: #333;
    background: white;
}

.header {
    background: #c0392b;
    color: white;
    padding: 25px 30px;
    margin-bottom: 0;
}
.header .logo {
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 6px;
}
.header h1 { font-size: 22px; margin-bottom: 4px; }
.header p  { font-size: 11px; opacity: 0.85; }

.crisis-box {
    background: #fff3f3;
    border: 2px solid #e74c3c;
    padding: 12px 20px;
    margin: 15px 30px;
    border-radius: 6px;
}
.crisis-box strong { color: #c0392b; font-size: 13px; display: block; margin-bottom: 4px; }
.crisis-box p { font-size: 11px; color: #555; }

.content { padding: 10px 30px 30px; }

.section {
    margin-bottom: 16px;
    page-break-inside: avoid;
}
.section-title {
    font-size: 12px;
    font-weight: bold;
    padding: 7px 12px;
    border-radius: 4px 4px 0 0;
    margin-bottom: 0;
}
.section-body {
    background: #fafafa;
    border: 1px solid #eee;
    border-radius: 0 0 4px 4px;
    padding: 10px 12px;
    font-size: 11px;
    line-height: 1.8;
}

.item {
    padding: 3px 0 3px 8px;
    border-bottom: 1px solid #f0f0f0;
}
.item:last-child { border-bottom: none; }

.empty-section {
    color: #aaa;
    font-style: italic;
    font-size: 11px;
    padding: 6px 12px;
}

.footer {
    margin-top: 25px;
    padding-top: 10px;
    border-top: 1px solid #ddd;
    text-align: center;
    font-size: 10px;
    color: #aaa;
    line-height: 1.6;
}
</style>
</head>
<body>

<div class="header">
    <div class="logo">🛡️ Mentis — Personal Safety Plan</div>
    <h1>My Crisis Safety Plan</h1>
    <p>
        Prepared for:
        <strong>{{ user ? user.firstname ~ ' ' ~ user.lastname : 'Anonymous User' }}</strong>
        &nbsp;|&nbsp; Date: {{ date }}
        &nbsp;|&nbsp; CONFIDENTIAL
    </p>
</div>

<div class="crisis-box">
    <strong>🚨 In immediate danger — call NOW:</strong>
    <p>
        USA Crisis Line: <strong>988</strong> &nbsp;|&nbsp;
        Emergency: <strong>911</strong> &nbsp;|&nbsp;
        Tunisia: <strong>1891</strong> &nbsp;|&nbsp;
        EU: <strong>112</strong> &nbsp;|&nbsp;
        Crisis Text: Text <strong>HOME</strong> to <strong>741741</strong>
    </p>
</div>

<div class="content">

    {# ── Step 1: Warning Signs ── #}
    <div class="section">
        <div class="section-title" style="background: #fff3e0; color: #e65100;">
            ⚠️ Step 1 — My Warning Signs
        </div>
        <div class="section-body">
            {% if plan.warning_signs is defined and plan.warning_signs|length > 0 %}
                {% for item in plan.warning_signs %}
                    <div class="item">→ {{ item }}</div>
                {% endfor %}
            {% else %}
                <div class="empty-section">No warning signs added yet.</div>
            {% endif %}
        </div>
    </div>

    {# ── Step 2: Coping Strategies ── #}
    <div class="section">
        <div class="section-title" style="background: #e8f5e9; color: #2E7D32;">
            💚 Step 2 — Coping Strategies (Things I Can Do Alone)
        </div>
        <div class="section-body">
            {% if plan.coping_strategies is defined and plan.coping_strategies|length > 0 %}
                {% for item in plan.coping_strategies %}
                    <div class="item">→ {{ item }}</div>
                {% endfor %}
            {% else %}
                <div class="empty-section">No coping strategies added yet.</div>
            {% endif %}
        </div>
    </div>

    {# ── Step 3: Social Distractions ── #}
    <div class="section">
        <div class="section-title" style="background: #e3f2fd; color: #1565c0;">
            👥 Step 3 — Social Distractions
        </div>
        <div class="section-body">
            {% if plan.social_distractions is defined and plan.social_distractions|length > 0 %}
                {% for item in plan.social_distractions %}
                    <div class="item">→ {{ item }}</div>
                {% endfor %}
            {% else %}
                <div class="empty-section">No social distractions added yet.</div>
            {% endif %}
        </div>
    </div>

    {# ── Step 4: Safe Environment ── #}
    <div class="section">
        <div class="section-title" style="background: #e0f2f1; color: #00695c;">
            🏠 Step 4 — Making My Environment Safe
        </div>
        <div class="section-body">
            {% if plan.safe_environment is defined and plan.safe_environment|trim != '' %}
                <div style="white-space: pre-wrap; line-height: 1.8;">{{ plan.safe_environment }}</div>
            {% else %}
                <div class="empty-section">No safe environment steps added yet.</div>
            {% endif %}
        </div>
    </div>

    {# ── Step 5: Reasons to Live ── #}
    <div class="section">
        <div class="section-title" style="background: #fff8e1; color: #e65100;">
            ⭐ Step 5 — My Reasons to Live
        </div>
        <div class="section-body">
            {% if plan.reasons_to_live is defined and plan.reasons_to_live|length > 0 %}
                {% for item in plan.reasons_to_live %}
                    <div class="item">★ {{ item }}</div>
                {% endfor %}
            {% else %}
                <div class="empty-section">No reasons to live added yet.</div>
            {% endif %}
        </div>
    </div>

    {# ── Crisis Numbers ── #}
    <div class="section">
        <div class="section-title" style="background: #ffebee; color: #c0392b;">
            🆘 Emergency Crisis Numbers — Always Available
        </div>
        <div class="section-body">
            {% if plan.crisis_numbers is defined and plan.crisis_numbers|length > 0 %}
                {% for number in plan.crisis_numbers %}
                    <div class="item">
                        📞 <strong>{{ number.label }}:</strong>
                        {{ number.number }}
                    </div>
                {% endfor %}
            {% else %}
                <div class="item">📞 <strong>USA Crisis Line:</strong> 988</div>
                <div class="item">📞 <strong>Crisis Text Line:</strong> Text HOME to 741741</div>
                <div class="item">📞 <strong>Emergency Services:</strong> 911</div>
                <div class="item">📞 <strong>Tunisia:</strong> 1891</div>
                <div class="item">📞 <strong>International:</strong> 116 123</div>
            {% endif %}
        </div>
    </div>

    <div class="footer">
        Mentis Mental Health Platform &nbsp;|&nbsp; Personal Safety Plan &nbsp;|&nbsp;
        {{ user ? user.firstname ~ ' ' ~ user.lastname : 'User' }} &nbsp;|&nbsp;
        {{ date }}<br>
        CONFIDENTIAL — Keep this document somewhere safe and accessible at all times.<br>
        This plan is for personal use only and does not replace professional mental health care.
    </div>

</div>
</body>
</html>