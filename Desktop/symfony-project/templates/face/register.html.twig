{# templates/face/register.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Register Face ID - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4>📸 Register Face ID</h4>
                    <p class="mb-0">Take 5 photos from different angles</p>
                </div>
                <div class="card-body text-center">
                    <div id="step1">
                        <video id="video" autoplay muted style="width: 100%; border-radius: 10px; border: 2px solid #50C878;"></video>
                        <canvas id="canvas" style="display: none;"></canvas>
                        <div class="mt-3">
                            <button id="captureBtn" class="btn btn-success btn-lg">
                                <i class="fas fa-camera"></i> Take Photo
                            </button>
                        </div>
                    </div>
                    
                    <div id="step2" style="display: none;">
                        <img id="preview" style="width: 150px; height: 150px; border-radius: 50%; object-fit: cover; border: 3px solid #50C878;">
                        <div class="mt-3">
                            <button id="saveBtn" class="btn btn-primary">Save Sample</button>
                            <button id="retakeBtn" class="btn btn-secondary">Retake</button>
                        </div>
                    </div>
                    
                    <div class="progress mt-4" style="height: 10px;">
                        <div id="progress" class="progress-bar bg-success" style="width: 0%"></div>
                    </div>
                    <p id="status" class="mt-2">0 of 5 samples captured</p>
                </div>
            </div>
        </div>
    </div>
</div>

{% block javascripts %}
<script>
    let video = document.getElementById('video');
    let canvas = document.getElementById('canvas');
    let captureBtn = document.getElementById('captureBtn');
    let saveBtn = document.getElementById('saveBtn');
    let retakeBtn = document.getElementById('retakeBtn');
    let preview = document.getElementById('preview');
    let step1 = document.getElementById('step1');
    let step2 = document.getElementById('step2');
    let progressBar = document.getElementById('progress');
    let statusText = document.getElementById('status');
    
    let sampleCount = {{ current_samples }};
    let userId = {{ user.id }};
    let requiredSamples = {{ required_samples }};
    let capturedImage = null;
    let stream = null;
    
    // Instructions pour les 5 photos
    const instructions = [
        "Look straight at camera",
        "Turn head slightly left",
        "Turn head slightly right",
        "Tilt head up slightly",
        "Tilt head down slightly"
    ];
    
    updateStatus();
    
    navigator.mediaDevices.getUserMedia({ video: true })
        .then(s => {
            stream = s;
            video.srcObject = s;
        })
        .catch(err => alert('Camera error: ' + err.message));
    
    captureBtn.onclick = function() {
        let ctx = canvas.getContext('2d');
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        ctx.drawImage(video, 0, 0);
        
        capturedImage = canvas.toDataURL('image/jpeg');
        preview.src = capturedImage;
        
        step1.style.display = 'none';
        step2.style.display = 'block';
    };
    
    retakeBtn.onclick = function() {
        step2.style.display = 'none';
        step1.style.display = 'block';
        capturedImage = null;
    };
    
    saveBtn.onclick = async function() {
        if (!capturedImage) return;
        
        saveBtn.disabled = true;
        saveBtn.innerHTML = 'Saving...';
        
        let formData = new FormData();
        formData.append('image', capturedImage);
        
        try {
            let response = await fetch('/face/api/register/' + userId, {
                method: 'POST',
                body: formData
            });
            
            let result = await response.json();
            
            if (result.success) {
                sampleCount = result.sample_count;
                updateStatus();
                
                if (result.completed) {
                    statusText.innerHTML = '✅ Face ID registered successfully!';
                    alert('Face ID registered! You can now login with your face.');
                    window.location.href = '/dashboard';
                } else {
                    step2.style.display = 'none';
                    step1.style.display = 'block';
                    capturedImage = null;
                    saveBtn.disabled = false;
                    saveBtn.innerHTML = 'Save Sample';
                }
            } else {
                alert('Error: ' + result.message);
                saveBtn.disabled = false;
                saveBtn.innerHTML = 'Save Sample';
            }
        } catch (error) {
            alert('Error: ' + error.message);
            saveBtn.disabled = false;
            saveBtn.innerHTML = 'Save Sample';
        }
    };
    
    function updateStatus() {
        let progress = (sampleCount / requiredSamples) * 100;
        progressBar.style.width = progress + '%';
        
        if (sampleCount < requiredSamples) {
            statusText.innerHTML = `${sampleCount} of ${requiredSamples} samples - ${instructions[sampleCount]}`;
        } else {
            statusText.innerHTML = '✅ Complete!';
        }
    }
    
    window.addEventListener('beforeunload', function() {
        if (stream) stream.getTracks().forEach(track => track.stop());
    });
</script>
{% endblock %}