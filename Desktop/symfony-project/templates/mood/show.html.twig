{% extends 'base.html.twig' %}

{% block title %}Mood Details{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div>
                            <h1 class="mb-2">
                                {% if mood.feeling == 'very_happy' %}
                                    😄 Very Happy
                                {% elseif mood.feeling == 'happy' %}
                                    😊 Happy
                                {% elseif mood.feeling == 'neutral' %}
                                    😐 Neutral
                                {% elseif mood.feeling == 'sad' %}
                                    😞 Sad
                                {% elseif mood.feeling == 'very_sad' %}
                                    😢 Very Sad
                                {% endif %}
                            </h1>
                            <small class="text-muted">
                                <i class="bi bi-calendar-event"></i>
                                {{ mood.createdAt|date('F d, Y \a\t H:i') }}
                            </small>
                        </div>
                    </div>

                    {% if mood.note %}
                        <div class="mb-4 p-4 bg-light border rounded">
                            <h5 class="mb-2">
                                <i class="bi bi-chat-dots"></i> Notes
                            </h5>
                            <p>{{ mood.note }}</p>
                        </div>
                    {% endif %}

                    <div class="d-flex gap-2 pt-3 border-top">
                        <a href="{{ path('app_mood_edit', {id: mood.id}) }}" class="btn btn-primary">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <form method="POST" action="{{ path('app_mood_delete', {id: mood.id}) }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ mood.id) }}">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure?')">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                        <a href="{{ path('app_mood_index') }}" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
