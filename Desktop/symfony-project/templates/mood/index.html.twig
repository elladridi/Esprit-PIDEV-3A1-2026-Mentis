{% extends 'base.html.twig' %}

{% block title %}Mood Tracker - My Moods{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-0">
                <i class="bi bi-emoji-smile"></i> Mood Tracker
            </h1>
            <p class="text-muted">Track and monitor your emotional well-being</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_mood_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Record New Mood
            </a>
        </div>
    </div>

    {% if moods is empty %}
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i>
            <strong>No moods recorded yet.</strong> Start tracking your emotions by recording your first mood!
        </div>
    {% else %}
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Your Mood History</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Feeling</th>
                                <th>Note</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for mood in moods %}
                                <tr>
                                    <td>
                                        {% if mood.feeling == 'very_happy' %}
                                            😄 Very Happy
                                        {% elseif mood.feeling == 'happy' %}
                                            😊 Happy
                                        {% elseif mood.feeling == 'neutral' %}
                                            😐 Neutral
                                        {% elseif mood.feeling == 'sad' %}
                                            😞 Sad
                                        {% elseif mood.feeling == 'very_sad' %}
                                            😢 Very Sad
                                        {% endif %}
                                    </td>
                                    <td>{{ mood.note|slice(0, 50) }}{% if mood.note|length > 50 %}...{% endif %}</td>
                                    <td>{{ mood.createdAt|date('M d, Y H:i') }}</td>
                                    <td>
                                        <a href="{{ path('app_mood_show', {id: mood.id}) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                        <a href="{{ path('app_mood_edit', {id: mood.id}) }}" class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form method="POST" action="{{ path('app_mood_delete', {id: mood.id}) }}" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ mood.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% endif %}
</div>

<style>
    .hover-shadow:hover {
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
    }
</style>
{% endblock %}
