{% extends 'base.html.twig' %}

{% block title %}Our Services - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="text-center mb-5" data-aos="fade-up">
        <h1 class="display-4 fw-bold" style="color: #2E7D32;">Our Services</h1>
        <p class="lead">Comprehensive solutions for your mental well-being</p>
    </div>
    <div class="row g-4">
        <div class="col-md-6 col-lg-4" data-aos="fade-up">
            <div class="card h-100 p-4 shadow-sm border-0" style="background: #F1F8E9;">
                <i class="fas fa-chalkboard-user fa-3x mb-3" style="color: #4CAF50;"></i>
                <h4 style="color: #2E7D32;">Individual Therapy</h4>
                <p class="text-muted">One-on-one sessions with experienced psychologists tailored to your needs.</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="100">
            <div class="card h-100 p-4 shadow-sm border-0" style="background: #F1F8E9;">
                <i class="fas fa-video fa-3x mb-3" style="color: #4CAF50;"></i>
                <h4 style="color: #2E7D32;">Online Consultation</h4>
                <p class="text-muted">Virtual sessions from the comfort of your home, anytime anywhere.</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="200">
            <div class="card h-100 p-4 shadow-sm border-0" style="background: #F1F8E9;">
                <i class="fas fa-head-side-medical fa-3x mb-3" style="color: #4CAF50;"></i>
                <h4 style="color: #2E7D32;">Emergency Support</h4>
                <p class="text-muted">24/7 emergency support for immediate mental health assistance.</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="300">
            <div class="card h-100 p-4 shadow-sm border-0" style="background: #F1F8E9;">
                <i class="fas fa-chart-line fa-3x mb-3" style="color: #4CAF50;"></i>
                <h4 style="color: #2E7D32;">Progress Tracking</h4>
                <p class="text-muted">Monitor your mental health journey with detailed analytics.</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="400">
            <div class="card h-100 p-4 shadow-sm border-0" style="background: #F1F8E9;">
                <i class="fas fa-robot fa-3x mb-3" style="color: #4CAF50;"></i>
                <h4 style="color: #2E7D32;">AI Chatbot</h4>
                <p class="text-muted">24/7 AI-powered support for immediate guidance.</p>
            </div>
        </div>
        <div class="col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="500">
            <div class="card h-100 p-4 shadow-sm border-0" style="background: #F1F8E9;">
                <i class="fas fa-graduation-cap fa-3x mb-3" style="color: #4CAF50;"></i>
                <h4 style="color: #2E7D32;">Workshops</h4>
                <p class="text-muted">Educational events on various mental health topics.</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}