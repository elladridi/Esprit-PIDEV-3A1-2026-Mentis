{% extends 'base.html.twig' %}

{% block title %}Mentis - Calm Your Mind. Change Your Life.{% endblock %}

{% block body %}
    {# Hero Section #}
   <section class="hero" style="background:url('/pi.png'); background-size: cover; background-position: center; background-attachment: fixed; padding: 120px 0;">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6" data-aos="fade-right">
                    <h1 class="display-4 fw-bold mb-4" style="color: black;">Calm Your Mind.<br>Change Your Life.</h1>
                    <p class="lead mb-4" style="color: rgba(0,0,0,1);">The #1 app for sleep, meditation, and mental relaxation.</p>
                    {% if not app.user %}
                        <a href="{{ path('app_register') }}" class="btn btn-light btn-lg px-5 me-3" style="color: #2E7D32; font-weight: 600;">Try Mentis Free</a>
                        <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-lg px-5" style="border-width: 2px;">Sign In</a>
                    {% else %}
                        <a href="{{ path('app_dashboard') }}" class="btn btn-light btn-lg px-5" style="color: #2E7D32; font-weight: 600;">Go to Dashboard</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>

    {# Features Section #}
    <section class="features py-5">
        <div class="container">
            <div class="text-center mb-5" data-aos="fade-up">
                <h2 class="display-5 fw-bold" style="color: #2E7D32;">Why Choose Mentis?</h2>
                <p class="lead text-muted">Comprehensive solutions for your mental well-being</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="card h-100 text-center p-4 shadow-sm border-0" style="background: #F1F8E9;">
                        <div class="card-body">
                            <i class="fas fa-moon fa-3x mb-3" style="color: #4CAF50;"></i>
                            <h4 style="color: #2E7D32;">Sleep</h4>
                            <p class="text-muted">Improve your sleep with guided meditations and soothing stories.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="card h-100 text-center p-4 shadow-sm border-0" style="background: #F1F8E9;">
                        <div class="card-body">
                            <i class="fas fa-brain fa-3x mb-3" style="color: #4CAF50;"></i>
                            <h4 style="color: #2E7D32;">Stress & Anxiety</h4>
                            <p class="text-muted">Learn to manage stress and anxiety with proven techniques.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="card h-100 text-center p-4 shadow-sm border-0" style="background: #F1F8E9;">
                        <div class="card-body">
                            <i class="fas fa-leaf fa-3x mb-3" style="color: #4CAF50;"></i>
                            <h4 style="color: #2E7D32;">Mindfulness</h4>
                            <p class="text-muted">Develop daily mindfulness for a more balanced life.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
   {# About Us Section - Improved #}
    <section class="about py-5 bg-white" data-aos="fade-up">
        <div class="container">
            <div class="text-center mb-5">
                <span class="badge" style="background: #E8F5E9; color: #2E7D32; padding: 8px 20px; border-radius: 30px;">About Us</span>
                <h2 class="display-5 fw-bold mt-3" style="color: #2E7D32;">Your Trusted Mental Health Partner</h2>
                <p class="lead text-muted">We are dedicated to making mental health support accessible to everyone.</p>
            </div>
            <div class="row align-items-center">
                <div class="col-lg-6 mb-4 mb-lg-0" data-aos="fade-right">
                    <img src="https://cdn-icons-png.flaticon.com/512/2920/2920344.png" alt="About Mentis" style="max-width: 90%;">
                </div>
                <div class="col-lg-6" data-aos="fade-left">
                    <h3 style="color: #2E7D32;">Our Story</h3>
                    <p class="lead">Founded in 2024, Mentis has grown to become a trusted platform for mental wellness.</p>
                    <p>We connect patients with qualified psychologists and provide resources for better mental health. Our mission is to break the stigma around mental health and make professional support accessible to all.</p>
                    
                    <div class="row mt-4">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-check-circle fa-2x me-3" style="color: #50C878;"></i>
                                <div>
                                    <h6 class="mb-0">Professional Therapists</h6>
                                    <small class="text-muted">Licensed and experienced</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-flask fa-2x me-3" style="color: #50C878;"></i>
                                <div>
                                    <h6 class="mb-0">Evidence-Based</h6>
                                    <small class="text-muted">Proven approaches</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-lock fa-2x me-3" style="color: #50C878;"></i>
                                <div>
                                    <h6 class="mb-0">Confidential & Secure</h6>
                                    <small class="text-muted">Your privacy matters</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-clock fa-2x me-3" style="color: #50C878;"></i>
                                <div>
                                    <h6 class="mb-0">24/7 Availability</h6>
                                    <small class="text-muted">Support when you need it</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# Services Section #}
    <section class="services py-5" style="background: #F1F8E9;" data-aos="fade-up">
        <div class="container">
            <div class="text-center mb-5">
                <h2 style="color: #2E7D32;">Our Services</h2>
                <p class="lead">Comprehensive mental health solutions tailored to your needs</p>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 text-center p-4 shadow-sm border-0">
                        <i class="fas fa-chalkboard-user fa-3x mb-3" style="color: #50C878;"></i>
                        <h4>Individual Therapy</h4>
                        <p>One-on-one sessions with experienced psychologists tailored to your needs.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 text-center p-4 shadow-sm border-0">
                        <i class="fas fa-users fa-3x mb-3" style="color: #50C878;"></i>
                        <h4>Group Therapy</h4>
                        <p>Connect with others facing similar challenges in a supportive environment.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 text-center p-4 shadow-sm border-0">
                        <i class="fas fa-heart fa-3x mb-3" style="color: #50C878;"></i>
                        <h4>Couples Therapy</h4>
                        <p>Strengthen your relationship with professional guidance.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 text-center p-4 shadow-sm border-0">
                        <i class="fas fa-users-between fa-3x mb-3" style="color: #50C878;"></i>
                        <h4>Family Therapy</h4>
                        <p>Improve communication and resolve conflicts within your family.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 text-center p-4 shadow-sm border-0">
                        <i class="fas fa-brain fa-3x mb-3" style="color: #50C878;"></i>
                        <h4>Cognitive Behavioral Therapy</h4>
                        <p>Evidence-based approach to change negative thought patterns.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 text-center p-4 shadow-sm border-0">
                        <i class="fas fa-video fa-3x mb-3" style="color: #50C878;"></i>
                        <h4>Online Consultation</h4>
                        <p>Virtual sessions from the comfort of your home, anytime anywhere.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# Contact Section #}
    <section class="contact py-5 bg-white" data-aos="fade-up">
        <div class="container">
            <div class="text-center mb-5">
                <h2 style="color: #2E7D32;">Get In Touch</h2>
                <p class="lead">We're here to help and answer any questions you might have</p>
            </div>
            <div class="row">
                <div class="col-md-4 text-center mb-4">
                    <div class="p-4">
                        <i class="fas fa-map-marker-alt fa-3x mb-3" style="color: #50C878;"></i>
                        <h4>Visit Us</h4>
                        <p>123 Wellness Street<br>Tunis, Tunisia</p>
                    </div>
                </div>
                <div class="col-md-4 text-center mb-4">
                    <div class="p-4">
                        <i class="fas fa-phone fa-3x mb-3" style="color: #50C878;"></i>
                        <h4>Call Us</h4>
                        <p>+216 12 345 678</p>
                        <p>+216 98 765 432</p>
                    </div>
                </div>
                <div class="col-md-4 text-center mb-4">
                    <div class="p-4">
                        <i class="fas fa-envelope fa-3x mb-3" style="color: #50C878;"></i>
                        <h4>Email Us</h4>
                        <p>contact@mentis.com</p>
                        <p>support@mentis.com</p>
                    </div>
                </div>
            </div>
            <div class="row mt-4">
                <div class="col-lg-8 mx-auto">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <h4 class="text-center mb-4">Send us a message</h4>
                            <form>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <input type="text" class="form-control" placeholder="Your Name">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <input type="email" class="form-control" placeholder="Your Email">
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <input type="text" class="form-control" placeholder="Subject">
                                </div>
                                <div class="mb-3">
                                    <textarea class="form-control" rows="4" placeholder="Your Message"></textarea>
                                </div>
                                <div class="text-center">
                                    <button type="submit" class="btn btn-primary-custom px-5">Send Message</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# CTA Section #}
    <section class="cta py-5" style="background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%); color: white;" data-aos="fade-up">
        <div class="container text-center">
            <h2 class="display-5 fw-bold mb-4">Ready to Start Your Journey?</h2>
            <p class="lead mb-4">Join thousands of people who found wellness with Mentis.</p>
            {% if not app.user %}
                <a href="{{ path('app_register') }}" class="btn btn-light btn-lg px-5" style="color: #2E7D32;">Get Started Free</a>
            {% else %}
                <a href="{{ path('app_dashboard') }}" class="btn btn-light btn-lg px-5" style="color: #2E7D32;">Go to Dashboard</a>
            {% endif %}
        </div>
    </section>
{% endblock %}

{% block stylesheets %}
<style>
    .btn-primary-custom {
        background: linear-gradient(135deg, #50C878 0%, #3A9B5E 100%);
        border: none;
        border-radius: 30px;
        padding: 12px 30px;
        font-weight: 600;
        transition: transform 0.3s, box-shadow 0.3s;
        color: white;
    }
    
    .btn-primary-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(80, 200, 120, 0.4);
        color: white;
    }
    
    .btn-outline-custom {
        background: transparent;
        border: 2px solid #50C878;
        color: #3A9B5E;
        border-radius: 30px;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s;
    }
    
    .btn-outline-custom:hover {
        background: #50C878;
        color: white;
        transform: translateY(-2px);
    }
    
    .card {
        transition: transform 0.3s, box-shadow 0.3s;
        border-radius: 15px;
    }
    
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    
    .form-control {
        border-radius: 10px;
        padding: 12px 15px;
        border: 1px solid #e0e0e0;
    }
    
    .form-control:focus {
        border-color: #50C878;
        box-shadow: 0 0 0 0.2rem rgba(80, 200, 120, 0.25);
    }
</style>
{% endblock %}