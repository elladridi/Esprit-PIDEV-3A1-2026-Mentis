{% extends 'base.html.twig' %}

{% block title %}About Us - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto text-center" data-aos="fade-up">
            <h1 class="display-4 fw-bold mb-4" style="color: #2E7D32;">About Mentis</h1>
            <p class="lead">We are dedicated to making mental health support accessible to everyone.</p>
        </div>
    </div>
    <div class="row mt-5">
        <div class="col-md-6" data-aos="fade-right">
            <h3 style="color: #4CAF50;">Our Mission</h3>
            <p>To provide accessible, affordable, and quality mental health care through innovative technology and compassionate professionals.</p>
        </div>
        <div class="col-md-6" data-aos="fade-left">
            <h3 style="color: #4CAF50;">Our Vision</h3>
            <p>A world where mental health is prioritized and everyone has access to the support they need.</p>
        </div>
    </div>
</div>
{% endblock %}