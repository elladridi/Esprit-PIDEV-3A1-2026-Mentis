<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token('') }}">
    <title>{% block title %}Mentis - Mental Health Platform{% endblock %}</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <style>
        :root {
            --primary-color: #50C878;
            --primary-light: #7DDA9C;
            --primary-dark: #3A9B5E;
            --secondary-color: #A8E6CF;
            --text-dark: #2C3E50;
            --text-light: #6C757D;
            --bg-light: #F0FDF4;
            --white: #FFFFFF;
        }

        * {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: var(--bg-light);
            color: var(--text-dark);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        main {
            flex: 1;
        }

        .tophead {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
            color: white;
            padding: 8px 0;
            font-size: 0.85rem;
        }

        .tophead a {
            color: white;
            text-decoration: none;
            transition: opacity 0.3s;
        }

        .tophead a:hover {
            opacity: 0.8;
        }

        .social-icons a {
            margin-left: 15px;
            font-size: 0.9rem;
        }

        .navbar {
            background: var(--white);
            box-shadow: 0 2px 20px rgba(0,0,0,0.08);
            padding: 12px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            text-decoration: none;
        }

        .navbar-brand img {
            height: 40px;
            width: auto;
            margin-right: 10px;
        }

        .navbar-brand span {
            font-weight: 800;
            font-size: 1.8rem;
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-link {
            font-weight: 500;
            color: var(--text-dark);
            transition: color 0.3s;
            margin: 0 8px;
            text-decoration: none;
        }

        .nav-link:hover {
            color: var(--primary-color);
        }

        .btn-login {
            background: transparent;
            border: 2px solid var(--primary-color);
            color: var(--primary-dark);
            padding: 8px 25px;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s;
            margin-right: 10px;
            text-decoration: none;
            display: inline-block;
        }

        .btn-login:hover {
            background: var(--primary-color);
            color: white;
            transform: translateY(-2px);
        }

        .btn-register {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
            color: white;
            border: none;
            padding: 8px 25px;
            border-radius: 25px;
            font-weight: 600;
            transition: transform 0.3s, box-shadow 0.3s;
            text-decoration: none;
            display: inline-block;
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(80, 200, 120, 0.4);
            color: white;
        }

        .btn-primary-custom {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
            border: none;
            border-radius: 30px;
            padding: 12px 30px;
            font-weight: 600;
            transition: transform 0.3s, box-shadow 0.3s;
            color: white;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(80, 200, 120, 0.4);
            color: white;
        }

        .btn-outline-custom {
            background: transparent;
            border: 2px solid var(--primary-color);
            color: var(--primary-dark);
            border-radius: 30px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s;
            text-decoration: none;
            display: inline-block;
        }

        .btn-outline-custom:hover {
            background: var(--primary-color);
            color: white;
            transform: translateY(-2px);
        }

        footer {
            background: linear-gradient(135deg, #1a3a2a 0%, #0d2a1a 100%);
            color: #fff;
            padding: 60px 0 20px;
            margin-top: 60px;
        }

        .footer-logo {
            display: flex;
            align-items: center;
            text-decoration: none;
            margin-bottom: 20px;
        }

        .footer-logo img {
            height: 35px;
            width: auto;
            margin-right: 10px;
        }

        .footer-logo span {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--primary-color);
        }

        .footer-links h5 {
            color: #fff;
            margin-bottom: 20px;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .footer-links ul {
            list-style: none;
            padding: 0;
        }

        .footer-links ul li {
            margin-bottom: 10px;
        }

        .footer-links ul li a {
            color: #aaa;
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-links ul li a:hover {
            color: var(--primary-color);
        }

        .newsletter-input {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            border-radius: 30px;
            padding: 10px 20px;
            width: 100%;
        }

        .newsletter-input::placeholder {
            color: rgba(255,255,255,0.6);
        }

        .newsletter-input:focus {
            background: rgba(255,255,255,0.15);
            border-color: var(--primary-color);
            outline: none;
        }

        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 20px;
            margin-top: 40px;
            text-align: center;
            color: #aaa;
            font-size: 0.85rem;
        }

        .footer-bottom a {
            color: #aaa;
            text-decoration: none;
        }

        .footer-bottom a:hover {
            color: var(--primary-color);
        }

        .cookie-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--white);
            box-shadow: 0 -5px 20px rgba(0,0,0,0.1);
            padding: 15px 0;
            z-index: 1001;
            transform: translateY(100%);
            transition: transform 0.3s;
        }

        .cookie-bar.show {
            transform: translateY(0);
        }

        .cookie-bar p {
            margin: 0;
            font-size: 0.85rem;
        }

        .hero {
            min-height: 80vh;
            display: flex;
            align-items: center;
        }

        .card {
            transition: transform 0.3s, box-shadow 0.3s;
            border-radius: 15px;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        @media (max-width: 768px) {
            .tophead .row > div {
                text-align: center !important;
                margin-bottom: 5px;
            }
            
            .navbar-nav {
                text-align: center;
                margin: 15px 0;
            }
            
            .btn-login, .btn-register {
                display: block;
                width: 100%;
                margin: 5px 0;
                text-align: center;
            }
            
            .hero {
                text-align: center;
                padding: 50px 0;
            }
            
            .navbar-brand img {
                height: 30px;
            }
            
            .navbar-brand span {
                font-size: 1.4rem;
            }
        }
    </style>
    
    {% block stylesheets %}{% endblock %}
</head>
<body>
    {# Tophead Section #}
    <div class="tophead">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <i class="fas fa-phone-alt me-2"></i> +216 12 345 678
                    <span class="mx-2">|</span>
                    <i class="fas fa-envelope me-2"></i> contact@mentis.com
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <i class="fas fa-clock me-2"></i> Mon-Fri: 9:00 AM - 6:00 PM
                    <div class="social-icons d-inline-block ms-3">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Navigation #}
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img src="/logo.png" alt="Mentis Logo">
                <span>Mentis</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    {# Home - visible for all #}
                    {% if (app.user and app.user.type == 'Patient') or is_granted('ROLE_PSYCHOLOGIST') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_home') }}">Home</a>
                    </li>
                    {% endif %}
                    
                    {# Dashboard - visible for all authenticated users #}
                    {% if app.user %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_dashboard') }}">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_chatbot') }}">AI Chatbot</a>
                        </li>
                    {% endif %}
                    
                    {# Content Library - visible for Admin and Psychologist #}
                    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_PSYCHOLOGIST') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('content_index') }}">📚 Content Library</a>
                        </li>
                    {% endif %}
                    
                    {# Content Logs - visible for Admin only #}
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('content_logs') }}">📊 Content Logs</a>
                        </li>
                    {% endif %}
                    
                    {# ASSESSMENTS DROPDOWN #}
                    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_PSYCHOLOGIST') or (app.user and app.user.type == 'Patient') %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                📋 Assessments
                            </a>
                            <ul class="dropdown-menu">
                                {% if app.user and app.user.type == 'Patient' %}
                                    <li><a class="dropdown-item" href="{{ path('take_assessment_index') }}">
                                        <i class="fas fa-play-circle me-2"></i>Take Assessment
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('result_index') }}">
                                        <i class="fas fa-chart-line me-2"></i>My Results
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('result_stats', {userId: app.user.id}) }}">
                                        <i class="fas fa-chart-simple me-2"></i>My Progress
                                    </a></li>
                                {% endif %}
                                
                                {% if is_granted('ROLE_PSYCHOLOGIST') %}
                                    <li><a class="dropdown-item" href="{{ path('result_index') }}">
                                        <i class="fas fa-users me-2"></i>Patient Results
                                    </a></li>
                                {% endif %}
                                
                                {% if is_granted('ROLE_ADMIN') %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header fw-bold text-success">Assessment Management</h6></li>
                                    <li><a class="dropdown-item" href="{{ path('assessment_index') }}">
                                        <i class="fas fa-list me-2"></i>All Assessments
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('assessment_active') }}">
                                        <i class="fas fa-play-circle me-2"></i>Active Assessments
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('assessment_new') }}">
                                        <i class="fas fa-plus me-2"></i>Add Assessment
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header fw-bold text-success">Question Management</h6></li>
                                    <li><a class="dropdown-item" href="{{ path('question_index') }}">
                                        <i class="fas fa-question-circle me-2"></i>All Questions
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('question_new') }}">
                                        <i class="fas fa-plus me-2"></i>Add Question
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header fw-bold text-success">Results</h6></li>
                                    <li><a class="dropdown-item" href="{{ path('result_index') }}">
                                        <i class="fas fa-chart-line me-2"></i>All Results
                                    </a></li>
                                {% endif %}
                            </ul>
                        </li>
                    {% endif %}

                    {# SESSIONS DROPDOWN #}
                    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_PSYCHOLOGIST') or (app.user and app.user.type == 'Patient') %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-calendar-alt me-1"></i>Sessions
                            </a>
                            <ul class="dropdown-menu">
                                {% if app.user and app.user.type == 'Patient' %}
                                    <li><a class="dropdown-item" href="{{ path('session_by_patient', {patientId: app.user.id}) }}">
                                        <i class="fas fa-calendar-check me-2"></i>My Sessions
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('calendar_patient') }}">
                                        <i class="fas fa-calendar-alt me-2"></i>Calendar View
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('session_available') }}">
                                        <i class="fas fa-search me-2"></i>Available Sessions
                                    </a></li>
                                {% endif %}
                                
                                {% if is_granted('ROLE_PSYCHOLOGIST') %}
                                    <li><a class="dropdown-item" href="{{ path('session_index') }}">
                                        <i class="fas fa-list me-2"></i>All Sessions
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('session_active') }}">
                                        <i class="fas fa-play-circle me-2"></i>Active Sessions
                                    </a></li>
                                {% endif %}
                                
                                {% if is_granted('ROLE_ADMIN') %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header fw-bold text-success">Session Management</h6></li>
                                    <li><a class="dropdown-item" href="{{ path('session_index') }}">
                                        <i class="fas fa-list me-2"></i>All Sessions
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('session_active') }}">
                                        <i class="fas fa-play-circle me-2"></i>Active Sessions
                                    </a></li>
                                    <li><a class="dropdown-item" href="{{ path('session_available') }}">
                                        <i class="fas fa-calendar-check me-2"></i>Available Sessions
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="{{ path('session_new') }}">
                                        <i class="fas fa-plus me-2 text-success"></i>Add New Session
                                    </a></li>
                                {% endif %}
                            </ul>
                        </li>
                    {% endif %}

                    {# REVIEWS DROPDOWN #}
                    {% if app.user and app.user.type == 'Patient' %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-star me-1"></i>Reviews
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('review_my_reviews') }}">
                                    <i class="fas fa-list me-2"></i>My Reviews
                                </a></li>
                                <li><a class="dropdown-item" href="{{ path('session_by_patient', {patientId: app.user.id}) }}">
                                    <i class="fas fa-calendar-check me-2"></i>My Sessions
                                </a></li>
                            </ul>
                        </li>
                    {% endif %}

                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-star me-1"></i>Reviews
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="{{ path('review_admin_all') }}">
                                    <i class="fas fa-users me-2"></i>All Reviews
                                </a></li>
                                <li><a class="dropdown-item" href="{{ path('session_index') }}">
                                    <i class="fas fa-calendar-alt me-2"></i>Manage Sessions
                                </a></li>
                            </ul>
                        </li>
                    {% endif %}
                </ul>
                
                <div class="d-flex">
                    {% if app.user %}
                        <div class="dropdown">
                            <button class="btn btn-outline-custom dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle"></i> {{ app.user.firstname }}
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="{{ path('app_dashboard') }}">
                                    <i class="fas fa-tachometer-alt me-2"></i> Dashboard
                                </a></li>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <li><a class="dropdown-item" href="{{ path('app_dashboard_admin') }}">
                                        <i class="fas fa-shield-alt me-2"></i> Admin Panel
                                    </a></li>
                                {% endif %}
                                {% if is_granted('ROLE_PSYCHOLOGIST') %}
                                    <li><a class="dropdown-item" href="{{ path('app_dashboard_psychologist') }}">
                                        <i class="fas fa-clinic-medical me-2"></i> My Practice
                                    </a></li>
                                {% endif %}
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="{{ path('app_logout') }}">
                                    <i class="fas fa-sign-out-alt me-2"></i> Logout
                                </a></li>
                            </ul>
                        </div>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn-login">Login</a>
                        <a href="{{ path('app_register') }}" class="btn-register">Try Free</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>

    {# Main Content #}
    <main>
        {% block body %}{% endblock %}
    </main>

    {# Footer #}
    <footer>
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <a class="footer-logo" href="{{ path('app_home') }}">
                        <img src="/logo.png" alt="Mentis Logo">
                        <span>Mentis</span>
                    </a>
                    <p>Your trusted partner for mental wellness. We provide professional psychological support and resources to help you thrive.</p>
                    <div class="social-icons mt-3">
                        <a href="#" class="me-3"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" class="me-3"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 mb-4">
                    <h5>Company</h5>
                    <ul>
                        <li><a href="{{ path('app_home') }}">Home</a></li>
                        <li><a href="{{ path('app_about') }}">About Us</a></li>
                        <li><a href="{{ path('app_services') }}">Services</a></li>
                        <li><a href="{{ path('app_contact') }}">Contact</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6 mb-4">
                    <h5>Our Services</h5>
                    <ul>
                        <li><a href="#">Individual Therapy</a></li>
                        <li><a href="#">Online Consultation</a></li>
                        <li><a href="#">Emergency Support</a></li>
                        <li><a href="#">Guided Meditation</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 mb-4">
                    <h5>Newsletter</h5>
                    <p>Get wellness tips straight to your inbox</p>
                    <div class="input-group">
                        <input type="email" class="newsletter-input" placeholder="Your email">
                    </div>
                    <button class="btn btn-primary-custom mt-2 w-100" type="button">Subscribe</button>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; {{ "now"|date("Y") }} Mentis. All rights reserved. | 
                <a href="#">Privacy Policy</a> | 
                <a href="#">Terms of Service</a> |
                <a href="#" id="cookiePreferences">Cookie Preferences</a></p>
            </div>
        </div>
    </footer>

    {# Cookie Bar #}
    <div class="cookie-bar" id="cookieBar">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-9">
                    <p>🍪 Mentis and its partners use cookies to improve your experience. By browsing our site, you consent to the use of cookies.</p>
                </div>
                <div class="col-md-3 text-end">
                    <button class="btn btn-primary-custom btn-sm" onclick="acceptCookies()">Accept</button>
                    <button class="btn btn-outline-secondary btn-sm ms-2" onclick="declineCookies()">Decline</button>
                </div>
            </div>
        </div>
    </div>

    {# Scripts #}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            duration: 1000,
            once: true
        });

        function showCookieBar() {
            var cookieBar = document.getElementById('cookieBar');
            if (!localStorage.getItem('cookiesAccepted') && !localStorage.getItem('cookiesDeclined')) {
                cookieBar.classList.add('show');
            }
        }

        function acceptCookies() {
            localStorage.setItem('cookiesAccepted', 'true');
            document.getElementById('cookieBar').classList.remove('show');
        }

        function declineCookies() {
            localStorage.setItem('cookiesDeclined', 'true');
            document.getElementById('cookieBar').classList.remove('show');
        }

        var cookiePref = document.getElementById('cookiePreferences');
        if (cookiePref) {
            cookiePref.addEventListener('click', function(e) {
                e.preventDefault();
                localStorage.removeItem('cookiesAccepted');
                localStorage.removeItem('cookiesDeclined');
                document.getElementById('cookieBar').classList.add('show');
            });
        }

        showCookieBar();
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>