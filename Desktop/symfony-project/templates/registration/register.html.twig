{% block javascripts %}
{{ parent() }}
<script>
(function () {
    // ==================== CV SECTION TOGGLE ====================
    const registerTypeSelect = document.getElementById('registration_form_type');
    const registerCvSection  = document.getElementById('cvUploadSection');

    if (registerTypeSelect && registerCvSection) {
        function toggleCVSection() {
            registerCvSection.style.display = registerTypeSelect.value === 'Psychologist' ? 'block' : 'none';
        }
        registerTypeSelect.addEventListener('change', toggleCVSection);
        toggleCVSection();
    }

    // ==================== CV AUTO-FILL ====================
    const registerCvFileInput = document.getElementById('registration_form_cvFile');
    const registerCvStatusEl  = document.getElementById('cvAnalysisStatus');

    if (registerCvFileInput && registerCvStatusEl) {
        registerCvFileInput.addEventListener('change', async function () {
            const file = this.files[0];
            if (!file || file.type !== 'application/pdf') return;

            registerCvStatusEl.style.display = 'block';
            registerCvStatusEl.innerHTML = '<span style="color:#50C878;">⏳ Analyzing CV with AI...</span>';

            const formData = new FormData();
            formData.append('cv', file);

            try {
                const res  = await fetch('/analyze-cv', { method: 'POST', body: formData });
                const data = await res.json();

                if (!data.success) {
                    registerCvStatusEl.innerHTML = '<span style="color:#dc3545;">❌ ' + (data.error || 'Analysis failed') + '</span>';
                    return;
                }

                const fields = {
                    'registration_form_firstname':   data.firstname,
                    'registration_form_lastname':    data.lastname,
                    'registration_form_email':       data.email,
                    'registration_form_phone':       data.phone,
                    'registration_form_dateofbirth': data.dateofbirth,
                };

                let filled = [];
                for (const [id, value] of Object.entries(fields)) {
                    if (!value) continue;
                    const el = document.getElementById(id);
                    if (el && !el.value.trim()) {
                        el.value = value;
                        el.style.transition = 'background 0.4s';
                        el.style.background = '#e8f5e9';
                        setTimeout(() => { el.style.background = ''; }, 2000);
                        filled.push(id.replace('registration_form_', ''));
                    }
                }

                if (filled.length > 0) {
                    registerCvStatusEl.innerHTML = `<span style="color:#2E7D32;">✅ Auto-filled: ${filled.join(', ')}</span>`;
                } else {
                    registerCvStatusEl.innerHTML = '<span style="color:#888;">ℹ️ CV analyzed — fields already filled or no data found.</span>';
                }

            } catch (err) {
                registerCvStatusEl.innerHTML = '<span style="color:#dc3545;">❌ Network error: ' + err.message + '</span>';
            }
        });
    }

    // ==================== FORM VALIDATION ====================
    const registerForm = document.getElementById('registerForm');

    if (registerForm) {
        registerForm.addEventListener('submit', function (event) {
            let isValid = true;
            document.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));

            const firstname = document.getElementById('registration_form_firstname');
            if (firstname && !firstname.value.trim()) {
                firstname.classList.add('is-invalid');
                document.getElementById('firstnameError').innerText = 'First name is required';
                isValid = false;
            }

            const lastname = document.getElementById('registration_form_lastname');
            if (lastname && !lastname.value.trim()) {
                lastname.classList.add('is-invalid');
                document.getElementById('lastnameError').innerText = 'Last name is required';
                isValid = false;
            }

            const email      = document.getElementById('registration_form_email');
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (email) {
                if (!email.value.trim()) {
                    email.classList.add('is-invalid');
                    document.getElementById('emailError').innerText = 'Email is required';
                    isValid = false;
                } else if (!emailRegex.test(email.value)) {
                    email.classList.add('is-invalid');
                    document.getElementById('emailError').innerText = 'Please enter a valid email address';
                    isValid = false;
                }
            }

            const phone      = document.getElementById('registration_form_phone');
            const phoneRegex = /^[0-9+\-\s()]{8,20}$/;
            if (phone && !phone.value.trim()) {
                phone.classList.add('is-invalid');
                document.getElementById('phoneError').innerText = 'Phone number is required';
                isValid = false;
            } else if (phone && !phoneRegex.test(phone.value)) {
                phone.classList.add('is-invalid');
                document.getElementById('phoneError').innerText = 'Please enter a valid phone number';
                isValid = false;
            }

            const dob = document.getElementById('registration_form_dateofbirth');
            if (dob && !dob.value) {
                dob.classList.add('is-invalid');
                document.getElementById('dobError').innerText = 'Date of birth is required';
                isValid = false;
            }

            const gender = document.getElementById('registration_form_gender');
            if (gender && !gender.value) {
                gender.classList.add('is-invalid');
                document.getElementById('genderError').innerText = 'Gender is required';
                isValid = false;
            }

            const password        = document.getElementById('registration_form_plainPassword_first');
            const confirmPassword = document.getElementById('registration_form_plainPassword_second');

            if (password) {
                if (!password.value) {
                    password.classList.add('is-invalid');
                    document.getElementById('passwordError').innerText = 'Password is required';
                    isValid = false;
                } else if (password.value.length < 6) {
                    password.classList.add('is-invalid');
                    document.getElementById('passwordError').innerText = 'Password must be at least 6 characters';
                    isValid = false;
                }
            }

            if (confirmPassword && password && password.value !== confirmPassword.value) {
                confirmPassword.classList.add('is-invalid');
                document.getElementById('confirmPasswordError').innerText = 'Passwords do not match';
                isValid = false;
            }

            const registerCvFile = document.getElementById('registration_form_cvFile');
            if (registerTypeSelect && registerTypeSelect.value === 'Psychologist' && registerCvFile && !registerCvFile.files.length) {
                registerCvFile.classList.add('is-invalid');
                document.getElementById('cvError').innerText = 'Please upload your CV';
                isValid = false;
            }

            if (!isValid) event.preventDefault();
        });
    }
})();
</script>
