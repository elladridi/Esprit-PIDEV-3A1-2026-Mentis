{% extends 'base.html.twig' %}

{% block title %}Register - Mentis{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center align-items-center min-vh-100">
        <div class="col-md-6 col-lg-5">
            <div class="auth-container">
                <div class="text-center mb-4">
                    <img src="/logo.png" alt="Mentis Logo" style="height: 60px;">
                    <h2 class="mt-3" style="color: #2E7D32;">Create Account</h2>
                    <p class="text-muted">Start your mental wellness journey today</p>
                </div>

                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger">{{ message }}</div>
                {% endfor %}

                {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate', 'id': 'registerForm'}}) }}
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">First Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="fas fa-user" style="color: #50C878;"></i>
                                </span>
                                {{ form_widget(registrationForm.firstname, {'attr': {'class': 'form-control border-start-0', 'placeholder': 'First name'}}) }}
                            </div>
                            <div class="invalid-feedback" id="firstnameError"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Last Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="fas fa-user" style="color: #50C878;"></i>
                                </span>
                                {{ form_widget(registrationForm.lastname, {'attr': {'class': 'form-control border-start-0', 'placeholder': 'Last name'}}) }}
                            </div>
                            <div class="invalid-feedback" id="lastnameError"></div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="fas fa-envelope" style="color: #50C878;"></i>
                            </span>
                            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control border-start-0', 'placeholder': 'you@example.com'}}) }}
                        </div>
                        <div class="invalid-feedback" id="emailError"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="fas fa-phone" style="color: #50C878;"></i>
                            </span>
                            {{ form_widget(registrationForm.phone, {'attr': {'class': 'form-control border-start-0', 'placeholder': '+1234567890'}}) }}
                        </div>
                        <div class="invalid-feedback" id="phoneError"></div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Date of Birth</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="fas fa-calendar" style="color: #50C878;"></i>
                                </span>
                                {{ form_widget(registrationForm.dateofbirth, {'attr': {'class': 'form-control border-start-0', 'type': 'date'}}) }}
                            </div>
                            <div class="invalid-feedback" id="dobError"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Account Type</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="fas fa-tag" style="color: #50C878;"></i>
                                </span>
                                {{ form_widget(registrationForm.type, {'attr': {'class': 'form-select border-start-0'}}) }}
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="fas fa-lock" style="color: #50C878;"></i>
                            </span>
                            {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control border-start-0', 'placeholder': 'Enter password'}}) }}
                        </div>
                        <div class="invalid-feedback" id="passwordError"></div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="fas fa-lock" style="color: #50C878;"></i>
                            </span>
                            {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control border-start-0', 'placeholder': 'Confirm password'}}) }}
                        </div>
                        <div class="invalid-feedback" id="confirmPasswordError"></div>
                    </div>

                    <button type="submit" class="btn btn-primary-custom w-100 py-2">
                        <i class="fas fa-user-plus me-2"></i> Create Account
                    </button>
                {{ form_end(registrationForm) }}

                <div class="text-center mt-4">
                    <p class="text-muted">Already have an account? 
                        <a href="{{ path('app_login') }}" class="text-decoration-none fw-bold" style="color: #50C878;">Sign In</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .auth-container {
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.1);
        animation: fadeInUp 0.6s ease-out;
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .form-control, .form-select {
        border-radius: 10px;
        padding: 12px 15px;
    }
    
    .input-group-text {
        border-radius: 10px 0 0 10px;
        border: 1px solid #ced4da;
        border-right: none;
        background: #f8f9fa;
    }
    
    .form-control, .form-select {
        border-left: none;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: #50C878;
        box-shadow: none;
    }
    
    .input-group:focus-within .input-group-text {
        border-color: #50C878;
    }
    
    .btn-primary-custom {
        background: linear-gradient(135deg, #50C878 0%, #3A9B5E 100%);
        border: none;
        border-radius: 10px;
        font-weight: 600;
        transition: transform 0.3s, box-shadow 0.3s;
    }
    
    .btn-primary-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(80, 200, 120, 0.4);
    }
    
    .alert {
        border-radius: 10px;
        border: none;
    }
</style>

{% block javascripts %}
<script>
    document.getElementById('registerForm')?.addEventListener('submit', function(event) {
        let isValid = true;
        
        document.querySelectorAll('.is-invalid').forEach(el => {
            el.classList.remove('is-invalid');
        });
        
        const firstname = document.querySelector('#registration_form_firstname');
        const lastname = document.querySelector('#registration_form_lastname');
        const email = document.querySelector('#registration_form_email');
        const phone = document.querySelector('#registration_form_phone');
        const dob = document.querySelector('#registration_form_dateofbirth');
        const password = document.querySelector('#registration_form_plainPassword_first');
        const confirmPassword = document.querySelector('#registration_form_plainPassword_second');
        
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        const phoneRegex = /^[\+][0-9]{1,3}[0-9]{7,15}$|^[0-9]{8,15}$/;
        
        if (!firstname.value.trim()) {
            firstname.classList.add('is-invalid');
            document.getElementById('firstnameError').innerText = 'First name required';
            isValid = false;
        } else if (firstname.value.trim().length < 2) {
            firstname.classList.add('is-invalid');
            document.getElementById('firstnameError').innerText = 'Min 2 characters';
            isValid = false;
        }
        
        if (!lastname.value.trim()) {
            lastname.classList.add('is-invalid');
            document.getElementById('lastnameError').innerText = 'Last name required';
            isValid = false;
        } else if (lastname.value.trim().length < 2) {
            lastname.classList.add('is-invalid');
            document.getElementById('lastnameError').innerText = 'Min 2 characters';
            isValid = false;
        }
        
        if (!email.value.trim()) {
            email.classList.add('is-invalid');
            document.getElementById('emailError').innerText = 'Email required';
            isValid = false;
        } else if (!emailRegex.test(email.value)) {
            email.classList.add('is-invalid');
            document.getElementById('emailError').innerText = 'Valid email required';
            isValid = false;
        }
        
        if (!phone.value.trim()) {
            phone.classList.add('is-invalid');
            document.getElementById('phoneError').innerText = 'Phone required';
            isValid = false;
        } else if (!phoneRegex.test(phone.value)) {
            phone.classList.add('is-invalid');
            document.getElementById('phoneError').innerText = 'Valid phone required';
            isValid = false;
        }
        
        if (!dob.value) {
            dob.classList.add('is-invalid');
            document.getElementById('dobError').innerText = 'Date of birth required';
            isValid = false;
        } else {
            const age = new Date().getFullYear() - new Date(dob.value).getFullYear();
            if (age < 18) {
                dob.classList.add('is-invalid');
                document.getElementById('dobError').innerText = 'Must be 18+ years old';
                isValid = false;
            }
        }
        
        if (!password.value) {
            password.classList.add('is-invalid');
            document.getElementById('passwordError').innerText = 'Password required';
            isValid = false;
        } else if (password.value.length < 6) {
            password.classList.add('is-invalid');
            document.getElementById('passwordError').innerText = 'Min 6 characters';
            isValid = false;
        }
        
        if (password.value !== confirmPassword.value) {
            confirmPassword.classList.add('is-invalid');
            document.getElementById('confirmPasswordError').innerText = 'Passwords do not match';
            isValid = false;
        }
        
        if (!isValid) {
            event.preventDefault();
        }
    });
</script>
{% endblock %}
{% endblock %}