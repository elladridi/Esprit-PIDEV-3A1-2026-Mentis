{% extends 'base.html.twig' %}

{% block title %}Session Calendar - Admin Panel{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/main.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    #calendar {
        max-width: 1400px;
        margin: 0 auto;
        background: white;
        padding: 20px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    .fc-event {
        cursor: pointer;
        transition: transform 0.2s;
        border-radius: 8px !important;
        padding: 4px !important;
    }
    .fc-event:hover {
        transform: scale(1.02);
        filter: brightness(1.05);
    }
    .fc-daygrid-day {
        transition: background-color 0.2s;
        cursor: pointer;
    }
    .fc-daygrid-day:hover {
        background-color: rgba(80, 200, 120, 0.1);
    }
    .fc-toolbar-title {
        font-size: 1.5rem;
        font-weight: bold;
        color: #2E7D32;
    }
    .fc-button-primary {
        background-color: #50C878 !important;
        border-color: #50C878 !important;
    }
    .fc-button-primary:hover {
        background-color: #2E7D32 !important;
        border-color: #2E7D32 !important;
    }
    .modal-backdrop {
        z-index: 1040;
    }
    .is-invalid {
        border-color: #dc3545 !important;
    }
    .invalid-feedback {
        display: block;
        font-size: 0.875em;
        color: #dc3545;
        margin-top: 5px;
    }
</style>
{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="text-center mb-4" data-aos="fade-up">
        <h1 class="display-5 fw-bold" style="color: #2E7D32;">
            <i class="fas fa-calendar-alt me-2"></i>Session Management Calendar
        </h1>
        <p class="lead text-muted">Click on a date to add a session | Drag & drop to reschedule | Click on session to edit/delete</p>
    </div>
    
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-gradient text-white py-3 px-4 rounded-top-4" style="background: linear-gradient(135deg, #2E7D32 0%, #50C878 100%);">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0 fw-bold">
                    <i class="fas fa-calendar-week me-2"></i>Sessions Schedule
                </h4>
                <button class="btn btn-light rounded-pill" onclick="refreshCalendar()">
                    <i class="fas fa-sync-alt me-2"></i>Refresh
                </button>
            </div>
        </div>
        <div class="card-body p-4">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<!-- Add/Edit Event Modal with Validation -->
<div class="modal fade" id="eventModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">
            <div class="modal-header" style="background: linear-gradient(135deg, #2E7D32 0%, #50C878 100%);">
                <h5 class="modal-title text-white fw-bold" id="modalTitle">
                    <i class="fas fa-plus-circle me-2"></i>Add New Session
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="eventForm">
                    <input type="hidden" id="eventId">
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Session Title *</label>
                        <input type="text" class="form-control rounded-pill" id="eventTitle" required>
                        <div class="invalid-feedback" id="titleError"></div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Date *</label>
                            <input type="date" class="form-control rounded-pill" id="eventDate" required>
                            <div class="invalid-feedback" id="dateError"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Session Type</label>
                            <select class="form-select rounded-pill" id="eventType">
                                <option value="Individual">Individual</option>
                                <option value="Group">Group</option>
                                <option value="Family">Family</option>
                                <option value="Couple">Couple</option>
                                <option value="Online">Online</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Start Time</label>
                            <input type="time" class="form-control rounded-pill" id="eventStartTime">
                            <div class="invalid-feedback" id="startTimeError"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">End Time</label>
                            <input type="time" class="form-control rounded-pill" id="eventEndTime">
                            <div class="invalid-feedback" id="endTimeError"></div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Location</label>
                        <input type="text" class="form-control rounded-pill" id="eventLocation" placeholder="Room, address, or online link">
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Max Participants</label>
                            <input type="number" class="form-control rounded-pill" id="eventMaxParticipants" value="20" min="1">
                            <div class="invalid-feedback" id="maxError"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Price (€)</label>
                            <input type="number" step="0.01" class="form-control rounded-pill" id="eventPrice" value="0" min="0">
                            <div class="invalid-feedback" id="priceError"></div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-danger rounded-pill px-4" id="deleteBtn" style="display: none;" onclick="deleteEvent()">
                    <i class="fas fa-trash me-2"></i>Delete
                </button>
                <div>
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success rounded-pill px-4" onclick="validateAndSaveEvent()">
                        <i class="fas fa-save me-2"></i>Save
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
let calendar;
let currentEventId = null;

// ========== VALIDATION FUNCTIONS ==========

function showFieldError(fieldId, message) {
    const field = document.getElementById(fieldId);
    if (field) {
        field.classList.add('is-invalid');
        const errorDiv = document.getElementById(fieldId + 'Error') || (() => {
            const div = document.createElement('div');
            div.className = 'invalid-feedback';
            div.id = fieldId + 'Error';
            field.parentNode.appendChild(div);
            return div;
        })();
        errorDiv.textContent = message;
    }
}

function clearFieldError(fieldId) {
    const field = document.getElementById(fieldId);
    if (field) {
        field.classList.remove('is-invalid');
        const errorDiv = document.getElementById(fieldId + 'Error');
        if (errorDiv) {
            errorDiv.textContent = '';
        }
    }
}

function clearAllValidationErrors() {
    const fields = ['eventTitle', 'eventDate', 'eventStartTime', 'eventEndTime', 'eventMaxParticipants', 'eventPrice'];
    fields.forEach(fieldId => clearFieldError(fieldId));
}

function validateEventForm() {
    let isValid = true;
    
    // Validate Title
    const title = document.getElementById('eventTitle').value.trim();
    if (!title) {
        showFieldError('eventTitle', 'Session title is required');
        isValid = false;
    } else {
        clearFieldError('eventTitle');
    }
    
    // Validate Date (not in past)
    const dateValue = document.getElementById('eventDate').value;
    if (dateValue) {
        const selectedDate = new Date(dateValue);
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        
        if (selectedDate < today) {
            showFieldError('eventDate', 'Session date cannot be in the past!');
            isValid = false;
        } else {
            clearFieldError('eventDate');
        }
    }
    
    // Validate Time Order
    const startTime = document.getElementById('eventStartTime').value;
    const endTime = document.getElementById('eventEndTime').value;
    
    if (startTime && endTime && startTime >= endTime) {
        showFieldError('eventEndTime', 'End time must be after start time!');
        isValid = false;
    } else {
        clearFieldError('eventEndTime');
        clearFieldError('eventStartTime');
    }
    
    // Validate Max Participants
    const maxParticipants = parseInt(document.getElementById('eventMaxParticipants').value);
    if (isNaN(maxParticipants) || maxParticipants <= 0) {
        showFieldError('eventMaxParticipants', 'Max participants must be greater than 0!');
        isValid = false;
    } else if (maxParticipants > 100) {
        showFieldError('eventMaxParticipants', 'Max participants cannot exceed 100!');
        isValid = false;
    } else {
        clearFieldError('eventMaxParticipants');
    }
    
    // Validate Price
    const price = parseFloat(document.getElementById('eventPrice').value);
    if (isNaN(price) || price < 0) {
        showFieldError('eventPrice', 'Price cannot be negative!');
        isValid = false;
    } else {
        clearFieldError('eventPrice');
    }
    
    return isValid;
}

function validateAndSaveEvent() {
    clearAllValidationErrors();
    
    if (!validateEventForm()) {
        Swal.fire({
            title: 'Validation Error',
            html: 'Please fix the following errors:<br><br>✓ Session title is required<br>✓ End time must be after start time<br>✓ Date cannot be in the past<br>✓ Price cannot be negative<br>✓ Max participants must be between 1 and 100',
            icon: 'error',
            confirmButtonColor: '#dc3545'
        });
        return;
    }
    
    saveEvent();
}

document.addEventListener('DOMContentLoaded', function() {
    const calendarEl = document.getElementById('calendar');
    
    calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: 'dayGridMonth,timeGridWeek,timeGridDay'
        },
        locale: 'en',
        editable: true,
        selectable: true,
        droppable: true,
        eventDrop: function(info) {
            updateEventDate(info.event.id, info.event.startStr);
        },
        eventResize: function(info) {
            updateEventDate(info.event.id, info.event.startStr);
        },
        dateClick: function(info) {
            showAddEventModal(info.dateStr);
        },
        eventClick: function(info) {
            showEditEventModal(info.event);
        },
        events: {
            url: '{{ path('calendar_api_events') }}',
            method: 'GET',
            failure: function() {
                Swal.fire('Error', 'Could not load events', 'error');
            }
        }
    });
    
    calendar.render();
    
    // Real-time validation listeners
    const endTimeField = document.getElementById('eventEndTime');
    const startTimeField = document.getElementById('eventStartTime');
    const priceField = document.getElementById('eventPrice');
    const maxField = document.getElementById('eventMaxParticipants');
    const dateField = document.getElementById('eventDate');
    
    if (endTimeField && startTimeField) {
        startTimeField.addEventListener('change', function() {
            const startTime = this.value;
            const endTime = endTimeField.value;
            if (startTime && endTime && startTime >= endTime) {
                showFieldError('eventEndTime', 'End time must be after start time!');
            } else {
                clearFieldError('eventEndTime');
            }
        });
        endTimeField.addEventListener('change', function() {
            const startTime = startTimeField.value;
            const endTime = this.value;
            if (startTime && endTime && startTime >= endTime) {
                showFieldError('eventEndTime', 'End time must be after start time!');
            } else {
                clearFieldError('eventEndTime');
            }
        });
    }
    
    if (priceField) {
        priceField.addEventListener('input', function() {
            const price = parseFloat(this.value);
            if (isNaN(price) || price < 0) {
                showFieldError('eventPrice', 'Price cannot be negative!');
            } else {
                clearFieldError('eventPrice');
            }
        });
    }
    
    if (maxField) {
        maxField.addEventListener('input', function() {
            const max = parseInt(this.value);
            if (isNaN(max) || max <= 0) {
                showFieldError('eventMaxParticipants', 'Max participants must be greater than 0!');
            } else if (max > 100) {
                showFieldError('eventMaxParticipants', 'Max participants cannot exceed 100!');
            } else {
                clearFieldError('eventMaxParticipants');
            }
        });
    }
    
    if (dateField) {
        dateField.addEventListener('change', function() {
            const selectedDate = new Date(this.value);
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            if (selectedDate < today) {
                showFieldError('eventDate', 'Session date cannot be in the past!');
            } else {
                clearFieldError('eventDate');
            }
        });
    }
});

function refreshCalendar() {
    if (calendar) {
        calendar.refetchEvents();
        Swal.fire('Refreshed', 'Calendar updated successfully', 'success');
    }
}

function showAddEventModal(date = null) {
    document.getElementById('modalTitle').innerHTML = '<i class="fas fa-plus-circle me-2"></i>Add New Session';
    document.getElementById('eventForm').reset();
    document.getElementById('eventId').value = '';
    document.getElementById('deleteBtn').style.display = 'none';
    clearAllValidationErrors();
    
    if (date) {
        document.getElementById('eventDate').value = date;
    } else {
        document.getElementById('eventDate').value = new Date().toISOString().split('T')[0];
    }
    
    document.getElementById('eventMaxParticipants').value = 20;
    document.getElementById('eventPrice').value = 0;
    
    new bootstrap.Modal(document.getElementById('eventModal')).show();
}

function showEditEventModal(event) {
    document.getElementById('modalTitle').innerHTML = '<i class="fas fa-edit me-2"></i>Edit Session';
    document.getElementById('eventId').value = event.id;
    document.getElementById('eventTitle').value = event.title;
    document.getElementById('eventDate').value = event.startStr.split('T')[0];
    document.getElementById('eventType').value = event.extendedProps?.type || 'Individual';
    document.getElementById('eventLocation').value = event.extendedProps?.location || '';
    document.getElementById('eventMaxParticipants').value = (event.extendedProps?.participants || '0/20').split('/')[1] || 20;
    document.getElementById('eventPrice').value = event.extendedProps?.price || 0;
    document.getElementById('deleteBtn').style.display = 'block';
    currentEventId = event.id;
    
    clearAllValidationErrors();
    
    new bootstrap.Modal(document.getElementById('eventModal')).show();
}

function saveEvent() {
    const eventId = document.getElementById('eventId').value;
    const data = {
        title: document.getElementById('eventTitle').value,
        date: document.getElementById('eventDate').value,
        start_time: document.getElementById('eventStartTime').value,
        end_time: document.getElementById('eventEndTime').value,
        location: document.getElementById('eventLocation').value,
        type: document.getElementById('eventType').value,
        max_participants: document.getElementById('eventMaxParticipants').value,
        price: document.getElementById('eventPrice').value
    };
    
    const url = eventId ? `/calendar/api/events/${eventId}` : '/calendar/api/events';
    const method = eventId ? 'PUT' : 'POST';
    
    fetch(url, {
        method: method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('eventModal')).hide();
            refreshCalendar();
            Swal.fire('Success', data.message, 'success');
        } else {
            Swal.fire('Error', data.message || 'Error saving session', 'error');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        Swal.fire('Error', 'An error occurred', 'error');
    });
}

function updateEventDate(eventId, newStartDate) {
    fetch(`/calendar/api/events/${eventId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ start: newStartDate })
    })
    .then(response => response.json())
    .then(data => {
        if (!data.success) {
            Swal.fire('Error', 'Could not update session date', 'error');
            refreshCalendar();
        }
    });
}

function deleteEvent() {
    const eventId = document.getElementById('eventId').value;
    
    Swal.fire({
        title: 'Delete Session?',
        text: 'This action cannot be undone!',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Yes, delete it!',
        confirmButtonColor: '#dc3545'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch(`/calendar/api/events/${eventId}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    bootstrap.Modal.getInstance(document.getElementById('eventModal')).hide();
                    refreshCalendar();
                    Swal.fire('Deleted!', data.message, 'success');
                } else {
                    Swal.fire('Error', data.message || 'Error deleting session', 'error');
                }
            });
        }
    });
}
</script>
{% endblock %}