{% extends 'base.html.twig' %}

{% block title %}Security Dashboard - Admin{% endblock %}

{% block body %}
<div class="security-dashboard-page">
    <div class="security-ambient-bg"></div>
    <div class="security-grid-overlay"></div>

    <div class="container-fluid py-4 position-relative">
        <!-- Hero -->
        <div class="security-hero-card mb-4">
            <div class="row align-items-center g-4">
                <div class="col-lg-8">
                    <div class="hero-badge">
                        <i class="fas fa-shield-virus me-2"></i> LIVE SECURITY CONTROL
                    </div>
                    <h1 class="hero-title mt-3 mb-2">
                        Security Command Center
                    </h1>
                    <p class="hero-subtitle mb-3">
                        Monitor login attempts, detect suspicious activity, and manage account bans from one immersive control panel.
                    </p>

                    <div class="hero-tags">
                        <span><i class="fas fa-bolt"></i> Real-time monitoring</span>
                        <span><i class="fas fa-user-lock"></i> Access control</span>
                        <span><i class="fas fa-network-wired"></i> Threat visibility</span>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="threat-orb-wrap">
                        <div class="threat-orb">
                            <div class="threat-orb-inner">
                                <span class="threat-label">Threat Pulse</span>
                                <strong>{{ stats.failed_last_24h }}</strong>
                                <small>failed in last 24h</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row g-4 mb-4">
            <div class="col-md-6 col-xl-3">
                <div class="neo-stat-card stat-blue">
                    <div class="neo-stat-icon">
                        <i class="fas fa-sign-in-alt"></i>
                    </div>
                    <div class="neo-stat-content">
                        <span class="neo-stat-label">Total Attempts</span>
                        <h2 class="neo-stat-value" id="totalAttempts">{{ stats.total_attempts }}</h2>
                        <div class="neo-stat-meta">All recorded login entries</div>
                    </div>
                    <div class="neo-stat-glow"></div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="neo-stat-card stat-red">
                    <div class="neo-stat-icon">
                        <i class="fas fa-times-circle"></i>
                    </div>
                    <div class="neo-stat-content">
                        <span class="neo-stat-label">Failed Attempts</span>
                        <h2 class="neo-stat-value text-danger" id="failedAttempts">{{ stats.failed_attempts }}</h2>
                        <div class="neo-stat-meta">Authentication failures detected</div>
                    </div>
                    <div class="neo-stat-glow"></div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="neo-stat-card stat-amber">
                    <div class="neo-stat-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <div class="neo-stat-content">
                        <span class="neo-stat-label">Failed (24h)</span>
                        <h2 class="neo-stat-value text-warning" id="failedLast24h">{{ stats.failed_last_24h }}</h2>
                        <div class="neo-stat-meta">Recent high-risk activity</div>
                    </div>
                    <div class="neo-stat-glow"></div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="neo-stat-card stat-green">
                    <div class="neo-stat-icon">
                        <i class="fas fa-network-wired"></i>
                    </div>
                    <div class="neo-stat-content">
                        <span class="neo-stat-label">Unique IPs</span>
                        <h2 class="neo-stat-value" id="uniqueIps">{{ stats.unique_ips }}</h2>
                        <div class="neo-stat-meta">Distinct network origins</div>
                    </div>
                    <div class="neo-stat-glow"></div>
                </div>
            </div>
        </div>

        <!-- Suspicious Accounts -->
        <div class="panel-card mb-4">
            <div class="panel-card-header danger-header">
                <div class="panel-title-wrap">
                    <div class="panel-icon pulse-danger">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Suspicious Accounts</h5>
                        <p class="panel-subtitle mb-0">Accounts with 3+ failed attempts in the last 24 hours</p>
                    </div>
                </div>

                <button class="btn btn-refresh-panel" id="refreshSuspiciousBtn">
                    <i class="fas fa-sync-alt me-1"></i> Refresh
                </button>
            </div>

            <div class="panel-card-body">
                <div class="table-shell">
                    <div class="table-responsive">
                        <table class="table table-modern align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Failed Attempts</th>
                                    <th>Last Attempt</th>
                                    <th>Risk Level</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="suspiciousTableBody">
                                {% for account in suspiciousAccounts %}
                                    <tr>
                                        <td>
                                            <div class="cell-user">
                                                <div class="cell-avatar danger">
                                                    {{ account.email|slice(0,1)|upper }}
                                                </div>
                                                <div>
                                                    <strong>{{ account.email }}</strong>
                                                    <div class="cell-subtext">Flagged login behavior</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="metric-pill danger">{{ account.failed_count }} failures</span>
                                        </td>
                                        <td>
                                            <div class="date-stack">
                                                <strong>{{ account.last_attempt }}</strong>
                                                <small>Latest suspicious try</small>
                                            </div>
                                        </td>
                                        <td>
                                            {% if account.failed_count >= 6 %}
                                                <span class="risk-chip risk-critical">Critical</span>
                                            {% elseif account.failed_count >= 4 %}
                                                <span class="risk-chip risk-high">High</span>
                                            {% else %}
                                                <span class="risk-chip risk-medium">Medium</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end">
                                            <button class="btn action-btn-modern danger ban-suspicious-btn"
                                                    data-email="{{ account.email }}"
                                                    data-attempts="{{ account.failed_count }}">
                                                <i class="fas fa-gavel me-1"></i> Ban
                                            </button>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">
                                            <div class="empty-state-mini">
                                                <i class="fas fa-shield-check"></i>
                                                <p class="mb-0">No suspicious accounts detected</p>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Login Attempts -->
        <div class="panel-card mb-4">
            <div class="panel-card-header success-header">
                <div class="panel-title-wrap">
                    <div class="panel-icon pulse-green">
                        <i class="fas fa-history"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">Recent Login Attempts</h5>
                        <p class="panel-subtitle mb-0">Last 50 authentication events</p>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-refresh-panel" id="refreshAttemptsBtn">
                        <i class="fas fa-sync-alt me-1"></i> Refresh
                    </button>
                    <button class="btn btn-danger-soft" id="clearOldAttemptsBtn">
                        <i class="fas fa-trash me-1"></i> Clear Old (30+ days)
                    </button>
                </div>
            </div>

            <div class="panel-card-body">
                <div class="table-shell">
                    <div class="table-responsive">
                        <table class="table table-modern align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>IP Address</th>
                                    <th>Status</th>
                                    <th>Attempted At</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="attemptsTableBody">
                                {% for attempt in recentAttempts %}
                                    <tr class="{{ attempt.wasSuccessful ? 'row-safe' : 'row-alert' }}">
                                        <td>
                                            <div class="cell-user">
                                                <div class="cell-avatar {{ attempt.wasSuccessful ? 'success' : 'danger' }}">
                                                    {{ attempt.email|slice(0,1)|upper }}
                                                </div>
                                                <div>
                                                    <strong>{{ attempt.email }}</strong>
                                                    <div class="cell-subtext">
                                                        {{ attempt.wasSuccessful ? 'Authenticated successfully' : 'Authentication failed' }}
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <code class="modern-code">{{ attempt.ipAddress }}</code>
                                        </td>
                                        <td>
                                            {% if attempt.wasSuccessful %}
                                                <span class="status-chip success">
                                                    <i class="fas fa-check-circle"></i> Success
                                                </span>
                                            {% else %}
                                                <span class="status-chip danger">
                                                    <i class="fas fa-times-circle"></i> Failed
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <div class="date-stack">
                                                <strong>{{ attempt.attemptedAt }}</strong>
                                                <small>Recorded event time</small>
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <button class="btn action-btn-modern warning ban-from-attempt"
                                                    data-email="{{ attempt.email }}">
                                                <i class="fas fa-gavel me-1"></i> Ban
                                            </button>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">
                                            <div class="empty-state-mini">
                                                <i class="fas fa-database"></i>
                                                <p class="mb-0">No login attempts recorded</p>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Banned Users Section -->
        <div class="panel-card mb-4">
            <div class="panel-card-header banned-header">
                <div class="panel-title-wrap">
                    <div class="panel-icon pulse-danger">
                        <i class="fas fa-ban"></i>
                    </div>
                    <div>
                        <h5 class="mb-0">
                            Banned Users
                            <span class="live-count-badge ms-2">{{ bannedUsers|length }}</span>
                        </h5>
                        <p class="panel-subtitle mb-0">Accounts currently restricted from access</p>
                    </div>
                </div>

                <button class="btn btn-refresh-panel" id="refreshBannedBtn">
                    <i class="fas fa-sync-alt me-1"></i> Refresh
                </button>
            </div>

            <div class="panel-card-body">
                <div class="table-shell">
                    <div class="table-responsive">
                        <table class="table table-modern align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Banned At</th>
                                    <th>Banned Until</th>
                                    <th>Reason</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="bannedTableBody">
                                {% for user in bannedUsers %}
                                    <tr>
                                        <td>
                                            <div class="cell-user">
                                                <div class="cell-avatar dark">
                                                    {{ user.fullName|slice(0,1)|upper }}
                                                </div>
                                                <div>
                                                    <strong>{{ user.fullName }}</strong>
                                                    <div class="cell-subtext">Restricted account</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>{{ user.email }}</td>
                                        <td>
                                            <div class="date-stack">
                                                <strong>{{ user.bannedAt ? user.bannedAt|date('Y-m-d H:i') : 'N/A' }}</strong>
                                                <small>Ban activation time</small>
                                            </div>
                                        </td>
                                        <td>
                                            {% if user.bannedUntil %}
                                                <span class="metric-pill warning">{{ user.bannedUntil|date('Y-m-d H:i') }}</span>
                                            {% else %}
                                                <span class="metric-pill danger">Permanent</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <span class="reason-badge">
                                                {{ user.banReason|default('No reason provided')|slice(0, 60) }}{% if user.banReason and user.banReason|length > 60 %}...{% endif %}
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <button class="btn action-btn-modern success unban-btn"
                                                    data-user-id="{{ user.id }}"
                                                    data-user-name="{{ user.fullName }}">
                                                <i class="fas fa-check-circle me-1"></i> Unban
                                            </button>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center py-5 text-muted">
                                            <div class="empty-state-mini">
                                                <i class="fas fa-user-check"></i>
                                                <p class="mb-0">No banned users</p>
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ban Confirmation Modal -->
<div class="modal fade" id="banConfirmModal" tabindex="-1" aria-labelledby="banConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content security-modal">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="banConfirmModalLabel">
                    <i class="fas fa-gavel me-2 text-danger"></i>Confirm Ban
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-0">
                <div class="confirm-ban-box">
                    <p class="mb-2">Are you sure you want to ban:</p>
                    <h4 id="banEmail" class="ban-email-text mb-3"></h4>

                    <div class="alert alert-warning border-0 modern-alert">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Suspicious activity detected with <strong id="banAttempts"></strong> failed login attempts.
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-cancel-modern" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-confirm-ban" id="confirmBanBtn">
                    <i class="fas fa-ban me-1"></i> Confirm Ban
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    let currentBanEmail = '';

    function refreshStats() {
        fetch('/admin/security/stats')
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('totalAttempts').innerText = data.total_attempts || 0;
                    document.getElementById('failedAttempts').innerText = data.failed_attempts || 0;
                    document.getElementById('failedLast24h').innerText = data.failed_last_24h || 0;
                    document.getElementById('uniqueIps').innerText = data.unique_ips || 0;
                }
            })
            .catch(error => console.error('Error refreshing stats:', error));
    }

    function getRiskLabel(failedCount) {
        const count = Number(failedCount || 0);
        if (count >= 6) return '<span class="risk-chip risk-critical">Critical</span>';
        if (count >= 4) return '<span class="risk-chip risk-high">High</span>';
        return '<span class="risk-chip risk-medium">Medium</span>';
    }

    function refreshSuspicious() {
        fetch('/admin/security/suspicious')
            .then(response => response.json())
            .then(data => {
                const tbody = document.getElementById('suspiciousTableBody');

                if (!data.success || !data.data || data.data.length === 0) {
                    tbody.innerHTML = `
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <div class="empty-state-mini">
                                    <i class="fas fa-shield-check"></i>
                                    <p class="mb-0">No suspicious accounts detected</p>
                                </div>
                            </td>
                        </tr>
                    `;
                    return;
                }

                tbody.innerHTML = data.data.map(account => `
                    <tr>
                        <td>
                            <div class="cell-user">
                                <div class="cell-avatar danger">
                                    ${(account.email || '?').charAt(0).toUpperCase()}
                                </div>
                                <div>
                                    <strong>${escapeHtml(account.email)}</strong>
                                    <div class="cell-subtext">Flagged login behavior</div>
                                </div>
                            </div>
                        </td>
                        <td><span class="metric-pill danger">${account.failed_count} failures</span></td>
                        <td>
                            <div class="date-stack">
                                <strong>${new Date(account.last_attempt).toLocaleString()}</strong>
                                <small>Latest suspicious try</small>
                            </div>
                        </td>
                        <td>${getRiskLabel(account.failed_count)}</td>
                        <td class="text-end">
                            <button class="btn action-btn-modern danger ban-suspicious-btn"
                                    data-email="${escapeHtml(account.email)}"
                                    data-attempts="${account.failed_count}">
                                <i class="fas fa-gavel me-1"></i> Ban
                            </button>
                        </td>
                    </tr>
                `).join('');

                attachBanEvents();
            })
            .catch(error => console.error('Error refreshing suspicious:', error));
    }

    function refreshRecentAttempts() {
        fetch('/admin/security/recent-attempts')
            .then(response => response.json())
            .then(data => {
                const tbody = document.getElementById('attemptsTableBody');

                if (!data.success || !data.data || data.data.length === 0) {
                    tbody.innerHTML = `
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <div class="empty-state-mini">
                                    <i class="fas fa-database"></i>
                                    <p class="mb-0">No login attempts recorded</p>
                                </div>
                            </td>
                        </tr>
                    `;
                    return;
                }

                tbody.innerHTML = data.data.map(attempt => `
                    <tr class="${attempt.wasSuccessful ? 'row-safe' : 'row-alert'}">
                        <td>
                            <div class="cell-user">
                                <div class="cell-avatar ${attempt.wasSuccessful ? 'success' : 'danger'}">
                                    ${(attempt.email || '?').charAt(0).toUpperCase()}
                                </div>
                                <div>
                                    <strong>${escapeHtml(attempt.email)}</strong>
                                    <div class="cell-subtext">
                                        ${attempt.wasSuccessful ? 'Authenticated successfully' : 'Authentication failed'}
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td><code class="modern-code">${escapeHtml(attempt.ipAddress)}</code></td>
                        <td>
                            ${attempt.wasSuccessful
                                ? '<span class="status-chip success"><i class="fas fa-check-circle"></i> Success</span>'
                                : '<span class="status-chip danger"><i class="fas fa-times-circle"></i> Failed</span>'}
                        </td>
                        <td>
                            <div class="date-stack">
                                <strong>${new Date(attempt.attemptedAt).toLocaleString()}</strong>
                                <small>Recorded event time</small>
                            </div>
                        </td>
                        <td class="text-end">
                            <button class="btn action-btn-modern warning ban-from-attempt"
                                    data-email="${escapeHtml(attempt.email)}">
                                <i class="fas fa-gavel me-1"></i> Ban
                            </button>
                        </td>
                    </tr>
                `).join('');

                attachBanEvents();
            })
            .catch(error => console.error('Error refreshing recent:', error));
    }

    function refreshBannedUsers() {
        fetch('/admin/security/banned-users')
            .then(response => response.json())
            .then(data => {
                const tbody = document.getElementById('bannedTableBody');

                if (!data.success || !data.data || data.data.length === 0) {
                    tbody.innerHTML = `
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <div class="empty-state-mini">
                                    <i class="fas fa-user-check"></i>
                                    <p class="mb-0">No banned users</p>
                                </div>
                            </td>
                        </tr>
                    `;
                    return;
                }

                tbody.innerHTML = data.data.map(user => `
                    <tr>
                        <td>
                            <div class="cell-user">
                                <div class="cell-avatar dark">
                                    ${(user.fullName || '?').charAt(0).toUpperCase()}
                                </div>
                                <div>
                                    <strong>${escapeHtml(user.fullName)}</strong>
                                    <div class="cell-subtext">Restricted account</div>
                                </div>
                            </div>
                        </td>
                        <td>${escapeHtml(user.email)}</td>
                        <td>
                            <div class="date-stack">
                                <strong>${escapeHtml(user.bannedAt || 'N/A')}</strong>
                                <small>Ban activation time</small>
                            </div>
                        </td>
                        <td>
                            ${user.bannedUntil
                                ? `<span class="metric-pill warning">${escapeHtml(user.bannedUntil)}</span>`
                                : '<span class="metric-pill danger">Permanent</span>'}
                        </td>
                        <td>
                            <span class="reason-badge">${escapeHtml((user.banReason || 'No reason provided')).substring(0, 60)}${(user.banReason || '').length > 60 ? '...' : ''}</span>
                        </td>
                        <td class="text-end">
                            <button class="btn action-btn-modern success unban-btn"
                                    data-user-id="${user.id}"
                                    data-user-name="${escapeHtml(user.fullName)}">
                                <i class="fas fa-check-circle me-1"></i> Unban
                            </button>
                        </td>
                    </tr>
                `).join('');

                attachUnbanEvents();
            })
            .catch(error => console.error('Error refreshing banned users:', error));
    }

    function attachBanEvents() {
        document.querySelectorAll('.ban-suspicious-btn, .ban-from-attempt').forEach(btn => {
            btn.removeEventListener('click', handleBanClick);
            btn.addEventListener('click', handleBanClick);
        });
    }

    function attachUnbanEvents() {
        document.querySelectorAll('.unban-btn').forEach(btn => {
            btn.removeEventListener('click', handleUnbanClick);
            btn.addEventListener('click', handleUnbanClick);
        });
    }

    function handleBanClick(e) {
        const btn = e.currentTarget;
        currentBanEmail = btn.dataset.email;
        const attempts = btn.dataset.attempts || 'multiple';

        document.getElementById('banEmail').textContent = currentBanEmail;
        document.getElementById('banAttempts').textContent = attempts;

        const modal = new bootstrap.Modal(document.getElementById('banConfirmModal'));
        modal.show();
    }

    function handleUnbanClick(e) {
        const btn = e.currentTarget;
        const userId = btn.dataset.userId;
        const userName = btn.dataset.userName;

        if (confirm(`Are you sure you want to unban ${userName}?`)) {
            fetch(`/admin/security/unban/${userId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                }
            })
            .then(response => response.json())
            .then(result => {
                if (result.success) {
                    alert(`✅ ${result.user_name} has been unbanned successfully!`);
                    refreshBannedUsers();
                    refreshStats();
                } else {
                    alert('❌ Error: ' + result.message);
                }
            })
            .catch(error => alert('❌ Error: ' + error.message));
        }
    }

    function escapeHtml(str) {
        if (!str) return '';
        return String(str).replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    document.getElementById('refreshSuspiciousBtn')?.addEventListener('click', refreshSuspicious);
    document.getElementById('refreshAttemptsBtn')?.addEventListener('click', refreshRecentAttempts);
    document.getElementById('refreshBannedBtn')?.addEventListener('click', refreshBannedUsers);

    document.getElementById('clearOldAttemptsBtn')?.addEventListener('click', function() {
        if (confirm('Are you sure you want to delete all login attempts older than 30 days? This action cannot be undone.')) {
            fetch('/admin/security/clear-old-attempts', { method: 'POST' })
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        alert('✅ ' + result.message);
                        refreshRecentAttempts();
                        refreshStats();
                    } else {
                        alert('❌ Error: ' + result.message);
                    }
                })
                .catch(error => alert('❌ Error: ' + error.message));
        }
    });

    document.getElementById('confirmBanBtn')?.addEventListener('click', function() {
        if (!currentBanEmail) return;

        const modal = bootstrap.Modal.getInstance(document.getElementById('banConfirmModal'));

        fetch('/admin/security/ban-user', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify({ email: currentBanEmail })
        })
        .then(function(response) {
            if (!response.ok) {
                return response.text().then(function(text) {
                    throw new Error('HTTP ' + response.status + ': ' + text);
                });
            }
            return response.json();
        })
        .then(function(result) {
            if (result.success) {
                alert('✅ ' + (result.user_name || currentBanEmail) + ' has been banned successfully!');
                location.reload();
            } else {
                alert('❌ Error: ' + result.message);
            }
            if (modal) modal.hide();
        })
        .catch(function(error) {
            console.error('Ban error:', error);
            alert('❌ Error: ' + error.message);
        });
    });

    refreshStats();
    refreshSuspicious();
    refreshRecentAttempts();
    refreshBannedUsers();
    attachBanEvents();
    attachUnbanEvents();
});
</script>

