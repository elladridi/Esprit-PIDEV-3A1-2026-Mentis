{% extends 'base.html.twig' %}

{% block title %}{{ title }} - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="info-card p-4 bg-white">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="mb-0">{{ title }}</h3>
                    <a href="{{ path('app_dashboard_admin') }}" class="btn-modern btn-sm">
                        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                    </a>
                </div>
                
                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.firstname) }}
                        {{ form_widget(form.firstname, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.firstname) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.lastname) }}
                        {{ form_widget(form.lastname, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.lastname) }}
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.email) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.phone) }}
                        {{ form_widget(form.phone, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.phone) }}
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.dateofbirth) }}
                        {{ form_widget(form.dateofbirth, {'attr': {'class': 'form-control', 'type': 'date'}}) }}
                        {{ form_errors(form.dateofbirth) }}
                    </div>
                    <div class="col-md-6 mb-3">
                        {{ form_label(form.gender) }}
                        {{ form_widget(form.gender, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.gender) }}
                    </div>
                </div>
                
                <div class="mb-3">
                    {{ form_label(form.plainPassword) }}
                    {{ form_widget(form.plainPassword, {'attr': {'class': 'form-control'}}) }}
                    <small class="text-muted">{% if user.id %}Leave blank to keep current password{% else %}Enter a password{% endif %}</small>
                    {{ form_errors(form.plainPassword) }}
                </div>
                
                <div class="d-flex justify-content-between mt-4">
                    <button type="submit" class="btn-modern">
                        <i class="bi bi-save me-1"></i> Save {{ role|capitalize }}
                    </button>
                    <a href="{{ path('app_dashboard_admin') }}" class="btn btn-secondary">Cancel</a>
                </div>
                
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}