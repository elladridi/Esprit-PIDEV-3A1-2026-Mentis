                                                    </div>
                                                {% endif %}
                                            </div>
                                            <div class="flex-grow-1 overflow-hidden">
                                                <div class="fw-semibold text-truncate"
                                                     style="color: #1a3c34; font-size: 14px;">
                                                    {{ playlist.name }}
                                                </div>
                                                {% if playlist.description %}
                                                    <small class="text-muted d-block text-truncate">
                                                        {{ playlist.description }}
                                                    </small>
                                                {% endif %}
                                                <small class="text-muted">
                                                    <i class="fas fa-music me-1"></i>
                                                    {{ playlist.tracks }} tracks · {{ playlist.owner }}
                                                </small>
                                            </div>
                                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                                 style="width: 36px; height: 36px;
                                                        background: #1DB954;">
                                                <i class="fas fa-play text-white"
                                                   style="font-size: 12px; margin-left: 2px;"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>

                        <div class="text-center mt-4">
                            <a href="https://open.spotify.com" target="_blank"
                               class="btn rounded-pill px-4 py-2 fw-semibold text-white"
                               style="background: #1DB954; border: none;">
                                <i class="fab fa-spotify me-2"></i>Open Spotify
                            </a>
                            <p class="text-muted small mt-2">
                                <i class="fas fa-info-circle me-1"></i>
                                Music therapy can help regulate mood. It is not a substitute
                                for professional treatment.
                            </p>
                        </div>

                    {% else %}
                        <div class="text-center py-5">
                            <i class="fab fa-spotify fa-3x mb-3" style="color: #1DB954;"></i>
                            <p class="text-muted">No playlists available right now.</p>
                            <a href="https://open.spotify.com/genre/wellness-page"
                               target="_blank"
                               class="btn rounded-pill px-4 py-2 text-white"
                               style="background: #1DB954; border: none;">
                                Browse Wellness Music on Spotify
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ══ EMERGENCY MAP TAB ══ #}
        {% if result.riskLevel in ['High', 'Severe'] %}
        <div class="tab-pane fade" id="emergency" role="tabpanel">
            <div class="card shadow-sm border-0 overflow-hidden">
                <div class="card-header bg-danger text-white">
                    <i class="fas fa-map-marker-alt me-2"></i>Emergency Resources Near You
                </div>
                <div class="card-body p-0">
                    <div id="emergencyMap" style="height: 400px; width: 100%;"></div>
                    <div id="mapResults" class="p-3" style="max-height: 200px; overflow-y: auto;"></div>
                    <div class="p-3 bg-light">
                        <strong>📞 Emergency Numbers:</strong><br>
                        USA/Canada: <strong>911</strong> |
                        UK/Europe: <strong>112</strong> |
                        Australia: <strong>000</strong><br>
                        Crisis Line (USA): <strong>988</strong> |
                        Crisis Text: Text <strong>HOME</strong> to <strong>741741</strong>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

    </div>

    {# Bottom action buttons #}
    <div class="d-flex gap-3 mt-4 justify-content-center flex-wrap"
         data-aos="fade-up" data-aos-delay="200">
        <a href="{{ path('take_assessment_index') }}"
           class="btn btn-primary-custom rounded-pill px-4">
            <i class="fas fa-play me-2"></i>Take Another Assessment
        </a>
        <a href="{{ path('result_export_pdf', {id: result.resultId}) }}"
           class="btn btn-outline-secondary rounded-pill px-4">
            <i class="fas fa-file-pdf me-2"></i>Export PDF
        </a>
        <a href="{{ path('safety_plan_index') }}?result_id={{ result.resultId }}"
           class="btn btn-outline-danger rounded-pill px-4">
            <i class="fas fa-shield-heart me-2"></i>Safety Plan
        </a>
    </div>
</div>

{# Meditation Scripts #}
<script>
function playMeditation(youtubeId, title) {
    const embed  = document.getElementById('meditationEmbed');
    const iframe = document.getElementById('meditationIframe');
    const label  = document.getElementById('activeSessionTitle');
    iframe.src   = 'https://www.youtube.com/embed/' + youtubeId + '?autoplay=1&rel=0';
    label.textContent = title;
    embed.style.display = 'block';
    embed.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function closeMeditationEmbed() {
    const embed  = document.getElementById('meditationEmbed');
    const iframe = document.getElementById('meditationIframe');
    iframe.src   = '';
    embed.style.display = 'none';
}

function playPlaylist(embedUrl, card) {
    document.querySelectorAll('.playlist-card').forEach(function (c) {
        c.style.background = '#f8f9fa';
        c.style.transform  = '';
    });
    card.style.background = '#e8f5e9';
    card.style.transform  = 'scale(1.02)';
    const embedDiv    = document.getElementById('spotifyEmbed');
    const iframe      = document.getElementById('spotifyIframe');
    iframe.src        = embedUrl + '?utm_source=generator&theme=0';
    embedDiv.style.display = 'block';
    embedDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}
</script>

{# Emergency Map Scripts #}
{% if result.riskLevel in ['High', 'Severe'] %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
let map = null;
let userLat = null;
let userLon = null;
let markers = [];

function initEmergencyMap() {
    const container = document.getElementById('emergencyMap');
    if (!container || map) return;

    map = L.map('emergencyMap').setView([36.8065, 10.1815], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
            function (pos) {
                userLat = pos.coords.latitude;
                userLon = pos.coords.longitude;
                map.setView([userLat, userLon], 14);
                L.marker([userLat, userLon]).addTo(map)
                    .bindPopup('<b>📍 Your Location</b>').openPopup();
                searchNearbyHospitals();
            },
            function () { searchNearbyHospitals(); }
        );
    } else {
        searchNearbyHospitals();
    }
}

function searchNearbyHospitals() {
    if (!map) return;
    const lat = userLat || 36.8065;
    const lon = userLon || 10.1815;

    const query = `[out:json][timeout:25];(
        node["amenity"="hospital"](around:10000,${lat},${lon});
        way["amenity"="hospital"](around:10000,${lat},${lon});
    );out center 20;`;

    fetch('https://overpass-api.de/api/interpreter?data=' + encodeURIComponent(query))
        .then(r => r.json())
        .then(data => {
            markers.forEach(m => map.removeLayer(m));
            markers = [];

            const resultsDiv = document.getElementById('mapResults');
            resultsDiv.innerHTML = '<strong class="mb-2 d-block">Nearby Hospitals:</strong>';

            data.elements.forEach(el => {
                const elLat = el.lat || (el.center && el.center.lat);
                const elLon = el.lon  || (el.center && el.center.lon);
                if (!elLat || !elLon) return;

                const name   = (el.tags && el.tags.name) || 'Hospital';
                const marker = L.marker([elLat, elLon]).addTo(map)
                    .bindPopup(`<b>🏥 ${name}</b><br>Emergency services available`);
                markers.push(marker);

                const div = document.createElement('div');
                div.className = 'mb-2 pb-2 border-bottom';
                div.innerHTML = `<i class="fas fa-hospital me-2 text-danger"></i> ${name}`;
                resultsDiv.appendChild(div);
            });

            if (markers.length === 0) {
                resultsDiv.innerHTML += '<p class="text-muted">No hospitals found nearby.</p>';
            }
        })
        .catch(() => {
            document.getElementById('mapResults').innerHTML =
                '<p class="text-muted">Could not load map data.</p>';
        });
}

document.getElementById('emergency-tab')?.addEventListener('shown.bs.tab', function () {
    setTimeout(initEmergencyMap, 100);
});
</script>
{% endif %}

