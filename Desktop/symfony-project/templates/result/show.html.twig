{% extends 'base.html.twig' %}

{% block title %}Assessment Result - Mentis{% endblock %}

{% block body %}
<div class="container py-4">
    {# Back Button #}
    <div class="mb-4" data-aos="fade-right">
        <a href="{{ path('result_index') }}" class="text-decoration-none" style="color: #50C878;">
            <i class="fas fa-arrow-left me-2"></i> Back to Results
        </a>
    </div>

    {# ── EMERGENCY BANNER ── #}
    {% if result.riskLevel in ['High', 'Severe'] %}
    <div class="alert alert-danger border-0 shadow-sm mb-4" data-aos="fade-up" role="alert">
        <div class="d-flex align-items-center">
            <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
            <div>
                <h5 class="mb-1 fw-bold">⚠️ CRITICAL RISK DETECTED</h5>
                <p class="mb-0">Please seek immediate professional support. Emergency: 911 (US) / 112 (EU) | Crisis Line: 988</p>
            </div>
        </div>
    </div>
    {% endif %}

    {# ── TABS ── #}
    <ul class="nav nav-tabs mb-4" id="resultTab" role="tablist" data-aos="fade-up">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="summary-tab" data-bs-toggle="tab" data-bs-target="#summary" type="button" role="tab">
                <i class="fas fa-chart-simple me-2"></i>Summary
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="analysis-tab" data-bs-toggle="tab" data-bs-target="#analysis" type="button" role="tab">
                <i class="fas fa-robot me-2"></i>AI Analysis
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="recommendations-tab" data-bs-toggle="tab" data-bs-target="#recommendations" type="button" role="tab">
                <i class="fas fa-lightbulb me-2"></i>Recommendations
            </button>
        </li>
        {% if result.riskLevel in ['High', 'Severe'] %}
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="emergency-tab" data-bs-toggle="tab" data-bs-target="#emergency" type="button" role="tab">
                <i class="fas fa-map-marker-alt me-2"></i>Emergency Map
            </button>
        </li>
        {% endif %}
    </ul>

    <div class="tab-content" data-aos="fade-up" data-aos-delay="100">
        {# ══════════════ SUMMARY TAB ══════════════ #}
        <div class="tab-pane fade show active" id="summary" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    {# Score Cards #}
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="card border-0 text-center p-3" style="background: #F1F8E9;">
                                <i class="fas fa-star fa-2x mb-2" style="color: #50C878;"></i>
                                <h2 class="mb-0 fw-bold" style="color: #2E7D32;">{{ result.totalScore }}</h2>
                                <small class="text-muted">Total Score</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-0 text-center p-3" style="background: #F1F8E9;">
                                <i class="fas fa-chart-line fa-2x mb-2" style="color: #50C878;"></i>
                                <h2 class="mb-0 fw-bold 
                                    {% if result.riskLevel in ['High', 'Severe'] %}text-danger
                                    {% elseif result.riskLevel in ['Moderate', 'Mild'] %}text-warning
                                    {% else %}text-success{% endif %}">
                                    {{ result.riskLevel }}
                                </h2>
                                <small class="text-muted">Risk Level</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-0 text-center p-3" style="background: #F1F8E9;">
                                <i class="fas fa-calendar-alt fa-2x mb-2" style="color: #50C878;"></i>
                                <h5 class="mb-0">{{ result.takenAt ? result.takenAt|date('M d, Y H:i') : 'N/A' }}</h5>
                                <small class="text-muted">Date Taken</small>
                            </div>
                        </div>
                    </div>

                    {# Assessment Info #}
                    <div class="mb-4">
                        <h5 class="fw-bold" style="color: #2E7D32;">Assessment Details</h5>
                        <hr class="my-2" style="border-color: #50C878;">
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <p><strong>Assessment:</strong> {{ assessment ? assessment.title : 'N/A' }}</p>
                                <p><strong>Type:</strong> {{ assessment ? assessment.type : 'N/A' }}</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Patient:</strong> {{ user ? user.firstname ~ ' ' ~ user.lastname : 'N/A' }}</p>
                                <p><strong>Session Suggested:</strong> 
                                    {% if result.suggestSession %}
                                        <span class="badge bg-danger">Yes</span>
                                    {% else %}
                                        <span class="badge bg-success">No</span>
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    </div>

                    {# Interpretation #}
                    {% if result.interpretation %}
                    <div class="mb-4">
                        <h5 class="fw-bold" style="color: #2E7D32;">Interpretation</h5>
                        <hr class="my-2" style="border-color: #50C878;">
                        <p class="mt-3 text-muted">{{ result.interpretation }}</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ══════════════ AI ANALYSIS TAB ══════════════ #}
        <div class="tab-pane fade" id="analysis" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3" style="color: #2E7D32;">
                        <i class="fas fa-robot me-2"></i>AI-Powered Analysis
                    </h5>
                    <hr class="my-2 mb-4" style="border-color: #50C878;">
                    
                    {% if aiAnalysis is defined and aiAnalysis %}
                        <div class="p-3" style="background: #F8F9FA; border-radius: 10px;">
                            <p class="text-muted" style="line-height: 1.8; white-space: pre-line;">
                                {{ aiAnalysis|replace({'**': '', '###': '', '##': '', '# ': ''}) }}
                            </p>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <i class="fas fa-robot fa-3x mb-3" style="color: #50C878;"></i>
                            <p class="text-muted">AI analysis was not generated for this result.</p>
                            <a href="{{ path('take_assessment_index') }}" class="btn btn-primary-custom rounded-pill">
                                Take a new assessment
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ══════════════ RECOMMENDATIONS TAB ══════════════ #}
        <div class="tab-pane fade" id="recommendations" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3" style="color: #2E7D32;">
                        <i class="fas fa-lightbulb me-2"></i>Personalized Recommendations
                    </h5>
                    <hr class="my-2 mb-4" style="border-color: #50C878;">
                    
                    {% if result.recommendedContent %}
                        <div class="p-3 mb-4" style="background: #F8F9FA; border-radius: 10px;">
                            <p class="text-muted" style="line-height: 1.8; white-space: pre-line;">
                                {{ result.recommendedContent }}
                            </p>
                        </div>
                    {% endif %}

                    {# YouTube Videos Section #}
                    <h6 class="fw-bold mt-3 mb-3">
                        <i class="fab fa-youtube me-2" style="color: #FF0000;"></i>Recommended Videos
                    </h6>
                    
                    {% if videos is defined and videos|length > 0 %}
                        <div class="row g-3">
                            {% for video in videos|slice(0, 3) %}
                            <div class="col-md-4">
                                <a href="{{ video.watchUrl }}" target="_blank" class="text-decoration-none">
                                    <div class="card border-0 shadow-sm h-100">
                                        <div class="position-relative">
                                            <img src="{{ video.thumbnail ?: 'https://i.ytimg.com/vi/' ~ video.videoId ~ '/mqdefault.jpg' }}" 
                                                 class="card-img-top" 
                                                 alt="{{ video.title }}"
                                                 style="height: 150px; object-fit: cover; border-radius: 10px 10px 0 0;">
                                            <div class="position-absolute top-50 start-50 translate-middle">
                                                <i class="fab fa-youtube fa-3x text-white" style="text-shadow: 0 0 10px rgba(0,0,0,0.5);"></i>
                                            </div>
                                        </div>
                                        <div class="card-body p-2">
                                            <p class="small fw-bold mb-0 text-dark">{{ video.title|slice(0, 50) }}...</p>
                                            <small class="text-muted">{{ video.channelTitle }}</small>
                                        </div>
                                    </div>
                                </a>
                            </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-center py-4">
                            <i class="fab fa-youtube fa-3x mb-2" style="color: #FF0000;"></i>
                            <p class="text-muted">No video recommendations available.</p>
                        </div>
                    {% endif %}
                    
                    <div class="alert alert-info mt-3 small">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Disclaimer:</strong> This analysis is for informational purposes only and is not a clinical diagnosis. Please consult a qualified mental health professional.
                    </div>
                </div>
            </div>
        </div>

        {# ══════════════ EMERGENCY MAP TAB ══════════════ #}
        {% if result.riskLevel in ['High', 'Severe'] %}
        <div class="tab-pane fade" id="emergency" role="tabpanel">
            <div class="card shadow-sm border-0 overflow-hidden">
                <div class="card-header bg-danger text-white">
                    <i class="fas fa-map-marker-alt me-2"></i> Emergency Resources Near You
                </div>
                <div class="card-body p-0">
                    <div id="emergencyMap" style="height: 400px; width: 100%;"></div>
                    <div id="mapResults" class="p-3" style="max-height: 200px; overflow-y: auto;"></div>
                    <div class="p-3 bg-light">
                        <strong>📞 Emergency Numbers:</strong><br>
                        USA/Canada: <strong>911</strong> | UK/Europe: <strong>112</strong> | Australia: <strong>000</strong><br>
                        Crisis Line (USA): <strong>988</strong> | Crisis Text: Text <strong>HOME</strong> to <strong>741741</strong>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>

    {# Action Buttons #}
    <div class="d-flex gap-3 mt-4 justify-content-center" data-aos="fade-up" data-aos-delay="200">
        <a href="{{ path('take_assessment_index') }}" class="btn btn-primary-custom rounded-pill px-4">
            <i class="fas fa-play me-2"></i>Take Another Assessment
        </a>
        <a href="{{ path('result_export_pdf', {id: result.resultId}) }}" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="fas fa-file-pdf me-2"></i>Export PDF
        </a>
    </div>
</div>

{% if result.riskLevel in ['High', 'Severe'] %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
let map = null;
let userLat = null;
let userLon = null;
let markers = [];

function initEmergencyMap() {
    const container = document.getElementById('emergencyMap');
    if (!container) return;
    
    map = L.map('emergencyMap').setView([36.8065, 10.1815], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
    }).addTo(map);
    
    // Get user location
    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
            function(pos) {
                userLat = pos.coords.latitude;
                userLon = pos.coords.longitude;
                map.setView([userLat, userLon], 14);
                
                L.marker([userLat, userLon]).addTo(map)
                    .bindPopup('<b>📍 Your Location</b>')
                    .openPopup();
                
                searchNearbyHospitals();
            },
            function() {
                searchNearbyHospitals();
            }
        );
    } else {
        searchNearbyHospitals();
    }
}

function searchNearbyHospitals() {
    if (!map) return;
    
    const lat = userLat || 36.8065;
    const lon = userLon || 10.1815;
    
    const query = `[out:json][timeout:25];(
        node["amenity"="hospital"](around:10000,${lat},${lon});
        way["amenity"="hospital"](around:10000,${lat},${lon});
    );out center 20;`;
    
    fetch('https://overpass-api.de/api/interpreter?data=' + encodeURIComponent(query))
        .then(r => r.json())
        .then(data => {
            markers.forEach(m => map.removeLayer(m));
            markers = [];
            
            const resultsDiv = document.getElementById('mapResults');
            resultsDiv.innerHTML = '<strong class="mb-2 d-block">Nearby Hospitals:</strong>';
            
            data.elements.forEach(el => {
                const elLat = el.lat || (el.center && el.center.lat);
                const elLon = el.lon || (el.center && el.center.lon);
                if (!elLat || !elLon) return;
                
                const name = (el.tags && el.tags.name) || 'Hospital';
                
                const marker = L.marker([elLat, elLon]).addTo(map)
                    .bindPopup(`<b>🏥 ${name}</b><br>Emergency services available`);
                markers.push(marker);
                
                const div = document.createElement('div');
                div.className = 'mb-2 pb-2 border-bottom';
                div.innerHTML = `<i class="fas fa-hospital me-2 text-danger"></i> ${name}`;
                resultsDiv.appendChild(div);
            });
            
            if (markers.length === 0) {
                resultsDiv.innerHTML += '<p class="text-muted">No hospitals found nearby.</p>';
            }
        })
        .catch(() => {
            document.getElementById('mapResults').innerHTML = '<p class="text-muted">Could not load map data.</p>';
        });
}

document.getElementById('emergency-tab')?.addEventListener('shown.bs.tab', function() {
    setTimeout(initEmergencyMap, 100);
});
</script>
{% endif %}
{% endblock %}

{% block stylesheets %}
<style>
    .btn-primary-custom {
        background: linear-gradient(135deg, #50C878 0%, #3A9B5E 100%);
        border: none;
        transition: transform 0.3s, box-shadow 0.3s;
        color: white;
    }
    .btn-primary-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(80, 200, 120, 0.4);
        color: white;
    }
    .nav-tabs .nav-link {
        color: #2E7D32;
        font-weight: 500;
    }
    .nav-tabs .nav-link.active {
        color: #50C878;
        border-bottom-color: #50C878;
        font-weight: 600;
    }
</style>
{% endblock %}