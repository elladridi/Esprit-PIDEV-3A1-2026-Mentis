{% extends 'base.html.twig' %}

{% block title %}Assessment Result - Mentis{% endblock %}

{% block body %}
<div class="container py-4">

    {# Back Button #}
    <div class="mb-4" data-aos="fade-right">
        <a href="{{ path('result_index') }}" class="text-decoration-none" style="color: #50C878;">
            <i class="fas fa-arrow-left me-2"></i> Back to Results
        </a>
    </div>

    {# Emergency Banner #}
    {% if result.riskLevel in ['High', 'Severe'] %}
    <div class="alert alert-danger border-0 shadow-sm mb-4" data-aos="fade-up" role="alert">
        <div class="d-flex align-items-center">
            <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
            <div>
                <h5 class="mb-1 fw-bold">⚠️ CRITICAL RISK DETECTED</h5>
                <p class="mb-0">
                    Please seek immediate professional support.
                    Emergency: 911 (US) / 112 (EU) | Crisis Line: 988
                </p>
            </div>
        </div>
    </div>
    {% endif %}

    {# Tabs #}
    <ul class="nav nav-tabs mb-4" id="resultTab" role="tablist" data-aos="fade-up">

        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="summary-tab"
                    data-bs-toggle="tab" data-bs-target="#summary"
                    type="button" role="tab">
                <i class="fas fa-chart-simple me-2"></i>Summary
            </button>
        </li>

        <li class="nav-item" role="presentation">
            <button class="nav-link" id="analysis-tab"
                    data-bs-toggle="tab" data-bs-target="#analysis"
                    type="button" role="tab">
                <i class="fas fa-robot me-2"></i>AI Analysis
            </button>
        </li>

        {% if freeText is defined and freeText %}
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="sentiment-tab"
                    data-bs-toggle="tab" data-bs-target="#sentiment"
                    type="button" role="tab">
                <i class="fas fa-brain me-2"></i>Sentiment
            </button>
        </li>
        {% endif %}

        <li class="nav-item" role="presentation">
            <button class="nav-link" id="recommendations-tab"
                    data-bs-toggle="tab" data-bs-target="#recommendations"
                    type="button" role="tab">
                <i class="fas fa-lightbulb me-2"></i>Recommendations
            </button>
        </li>

        <li class="nav-item" role="presentation">
            <button class="nav-link" id="meditation-tab"
                    data-bs-toggle="tab" data-bs-target="#meditation"
                    type="button" role="tab">
                <i class="fas fa-spa me-2"></i>Meditations
            </button>
        </li>

        <li class="nav-item" role="presentation">
            <button class="nav-link" id="spotify-tab"
                    data-bs-toggle="tab" data-bs-target="#spotify"
                    type="button" role="tab">
                <i class="fab fa-spotify me-2" style="color: #1DB954;"></i>Music
            </button>
        </li>

        {% if result.riskLevel in ['High', 'Severe'] %}
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="emergency-tab"
                    data-bs-toggle="tab" data-bs-target="#emergency"
                    type="button" role="tab">
                <i class="fas fa-map-marker-alt me-2"></i>Emergency Map
            </button>
        </li>
        {% endif %}

    </ul>

    {# Tab Content #}
    <div class="tab-content" data-aos="fade-up" data-aos-delay="100">

        {# ══ SUMMARY TAB ══ #}
        <div class="tab-pane fade show active" id="summary" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    {# Score Cards #}
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="card border-0 text-center p-3" style="background: #F1F8E9;">
                                <i class="fas fa-star fa-2x mb-2" style="color: #50C878;"></i>
                                <h2 class="mb-0 fw-bold" style="color: #2E7D32;">
                                    {{ result.totalScore }}
                                </h2>
                                <small class="text-muted">Total Score</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-0 text-center p-3" style="background: #F1F8E9;">
                                <i class="fas fa-chart-line fa-2x mb-2" style="color: #50C878;"></i>
                                <h2 class="mb-0 fw-bold
                                    {% if result.riskLevel in ['High', 'Severe'] %}text-danger
                                    {% elseif result.riskLevel in ['Moderate', 'Mild'] %}text-warning
                                    {% else %}text-success{% endif %}">
                                    {{ result.riskLevel }}
                                </h2>
                                <small class="text-muted">Risk Level</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-0 text-center p-3" style="background: #F1F8E9;">
                                <i class="fas fa-calendar-alt fa-2x mb-2" style="color: #50C878;"></i>
                                <h5 class="mb-0">
                                    {{ result.takenAt ? result.takenAt|date('M d, Y H:i') : 'N/A' }}
                                </h5>
                                <small class="text-muted">Date Taken</small>
                            </div>
                        </div>
                    </div>

                    {# Assessment Info #}
                    <div class="mb-4">
                        <h5 class="fw-bold" style="color: #2E7D32;">Assessment Details</h5>
                        <hr class="my-2" style="border-color: #50C878;">
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <p><strong>Assessment:</strong> {{ assessment ? assessment.title : 'N/A' }}</p>
                                <p><strong>Type:</strong> {{ assessment ? assessment.type : 'N/A' }}</p>
                            </div>
                            <div class="col-md-6">
                                <p>
                                    <strong>Patient:</strong>
                                    {{ user ? user.firstname ~ ' ' ~ user.lastname : 'N/A' }}
                                </p>
                                <p>
                                    <strong>Session Suggested:</strong>
                                    {% if result.suggestSession %}
                                        <span class="badge bg-danger">Yes</span>
                                    {% else %}
                                        <span class="badge bg-success">No</span>
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                    </div>

                    {# Interpretation #}
                    {% if result.interpretation %}
                    <div class="mb-4">
                        <h5 class="fw-bold" style="color: #2E7D32;">Interpretation</h5>
                        <hr class="my-2" style="border-color: #50C878;">
                        <p class="mt-3 text-muted">{{ result.interpretation }}</p>
                    </div>
                    {% endif %}

                    {# In the summary tab — Safety Plan prompt box #}
                    {% if result.riskLevel in ['High', 'Severe', 'Moderate'] %}
                    <div class="mt-4 p-3 rounded-3"
                         style="background: #fff3f3; border: 1px solid #ffcdd2;">
                        <div class="d-flex align-items-center gap-3">
                            <i class="fas fa-shield-heart fa-2x" style="color: #e74c3c;"></i>
                            <div class="flex-grow-1">
                                <strong style="color: #c0392b;">
                                    Build your personal safety plan
                                </strong>
                                <p class="mb-0 small text-muted">
                                    A step-by-step plan to help you stay safe during difficult moments
                                </p>
                            </div>
                            <a href="{{ path('safety_plan_index') }}?result_id={{ result.resultId }}"
                               class="btn btn-danger rounded-pill px-4 flex-shrink-0">
                                <i class="fas fa-shield-heart me-2"></i>Safety Plan
                            </a>
                        </div>
                    </div>
                    {% endif %}

                </div>
            </div>
        </div>

        {# ══ AI ANALYSIS TAB ══ #}
        <div class="tab-pane fade" id="analysis" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3" style="color: #2E7D32;">
                        <i class="fas fa-robot me-2"></i>AI-Powered Analysis
                    </h5>
                    <hr class="my-2 mb-4" style="border-color: #50C878;">

                    {% if aiAnalysis is defined and aiAnalysis %}
                        <div class="p-3" style="background: #F8F9FA; border-radius: 10px;">
                            <p class="text-muted" style="line-height: 1.8; white-space: pre-line;">
                                {{ aiAnalysis|replace({'**': '', '###': '', '##': '', '# ': ''}) }}
                            </p>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <i class="fas fa-robot fa-3x mb-3" style="color: #50C878;"></i>
                            <p class="text-muted">AI analysis was not generated for this result.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ══ SENTIMENT TAB ══ #}
        {% if freeText is defined and freeText %}
        <div class="tab-pane fade" id="sentiment" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    <h5 class="fw-bold mb-4" style="color: #2E7D32;">
                        <i class="fas fa-brain me-2"></i>AI Sentiment Analysis
                    </h5>

                    {# Crisis Alert #}
                    {% if sentimentData.crisis_detected is defined and sentimentData.crisis_detected %}
                        <div class="alert alert-danger border-0 rounded-3 mb-4">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
                                <div>
                                    <h6 class="fw-bold mb-1">Crisis Indicators Detected</h6>
                                    <p class="mb-0 small">
                                        Your response contained some concerning language.
                                        Please reach out to a professional.
                                        Crisis Line: <strong>988</strong> |
                                        Text: <strong>HOME to 741741</strong>
                                    </p>
                                </div>
                            </div>
                        </div>
                    {% endif %}

                    {# Sentiment Score Bar #}
                    {% if sentimentData.sentiment_score is defined %}
                        {% set score        = sentimentData.sentiment_score %}
                        {% set scorePercent = (score * 100)|round %}
                        {% set barColor =
                            score >= 0.7 ? '#27ae60' :
                            score >= 0.4 ? '#f39c12' : '#e74c3c'
                        %}
                        <div class="mb-4 p-4 rounded-4"
                             style="background: #f8f9fa; border: 1px solid #e9ecef;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold" style="color: #2E7D32;">
                                    Emotional Tone Score
                                </span>
                                <span class="badge rounded-pill px-3 py-2 fw-semibold"
                                      style="background: {{ barColor }}; color: white;">
                                    {{ sentimentData.sentiment_label|replace({'_': ' '})|title }}
                                </span>
                            </div>
                            <div class="progress mb-2" style="height: 12px; border-radius: 10px;">
                                <div class="progress-bar"
                                     style="width: {{ scorePercent }}%;
                                            background: {{ barColor }};
                                            border-radius: 10px;">
                                </div>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small class="text-danger">Very Negative</small>
                                <small class="text-muted">Neutral</small>
                                <small class="text-success">Very Positive</small>
                            </div>
                        </div>
                    {% endif %}

                    {# Your Words #}
                    <div class="mb-4 p-3 rounded-3"
                         style="background: #f0faf4; border-left: 4px solid #50C878;">
                        <small class="text-muted d-block mb-2 fw-bold">Your response:</small>
                        <p class="mb-0 fst-italic" style="color: #1a3c34; line-height: 1.7;">
                            "{{ freeText }}"
                        </p>
                    </div>

                    <div class="row g-4">

                        {# Emotions Detected #}
                        {% if sentimentData.emotion_tags is defined and sentimentData.emotion_tags|length > 0 %}
                        <div class="col-md-6">
                            <div class="p-3 rounded-3 h-100"
                                 style="background: #fff3f3; border: 1px solid #ffcdd2;">
                                <h6 class="fw-bold mb-3" style="color: #c0392b;">
                                    <i class="fas fa-heart me-2"></i>Emotions Detected
                                </h6>
                                <div class="d-flex flex-wrap gap-2">
                                    {% for emotion in sentimentData.emotion_tags %}
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background: #ffebee; color: #c0392b;
                                                     border: 1px solid #ffcdd2; font-size: 13px;">
                                            {{ emotion|title }}
                                        </span>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                        {% endif %}

                        {# Key Themes #}
                        {% if sentimentData.key_themes is defined and sentimentData.key_themes|length > 0 %}
                        <div class="col-md-6">
                            <div class="p-3 rounded-3 h-100"
                                 style="background: #f3f0ff; border: 1px solid #d1c4e9;">
                                <h6 class="fw-bold mb-3" style="color: #7b1fa2;">
                                    <i class="fas fa-tags me-2"></i>Key Themes
                                </h6>
                                <div class="d-flex flex-wrap gap-2">
                                    {% for theme in sentimentData.key_themes %}
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background: #f3e5f5; color: #7b1fa2;
                                                     border: 1px solid #d1c4e9; font-size: 13px;">
                                            {{ theme|title }}
                                        </span>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                        {% endif %}

                        {# Protective Factors #}
                        {% if sentimentData.protective_factors is defined and sentimentData.protective_factors|length > 0 %}
                        <div class="col-md-6">
                            <div class="p-3 rounded-3 h-100"
                                 style="background: #f0faf4; border: 1px solid #c8dcd2;">
                                <h6 class="fw-bold mb-3" style="color: #2E7D32;">
                                    <i class="fas fa-shield-alt me-2"></i>Protective Factors
                                </h6>
                                <div class="d-flex flex-wrap gap-2">
                                    {% for factor in sentimentData.protective_factors %}
                                        <span class="badge rounded-pill px-3 py-2"
                                              style="background: #e8f5e9; color: #2E7D32;
                                                     border: 1px solid #c8dcd2; font-size: 13px;">
                                            {{ factor|title }}
                                        </span>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                        {% endif %}

                        {# Clinical Note #}
                        {% if sentimentData.clinical_note is defined and sentimentData.clinical_note %}
                        <div class="col-md-6">
                            <div class="p-3 rounded-3 h-100"
                                 style="background: #e3f2fd; border: 1px solid #bbdefb;">
                                <h6 class="fw-bold mb-3" style="color: #1565c0;">
                                    <i class="fas fa-user-md me-2"></i>Clinical Observation
                                </h6>
                                <p class="mb-0 small" style="color: #1565c0; line-height: 1.7;">
                                    {{ sentimentData.clinical_note }}
                                </p>
                            </div>
                        </div>
                        {% endif %}

                    </div>

                    <div class="alert alert-secondary mt-4 small rounded-3 border-0">
                        <i class="fas fa-info-circle me-2"></i>
                        This sentiment analysis is AI-generated for informational purposes only
                        and does not constitute a clinical diagnosis.
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {# ══ RECOMMENDATIONS TAB ══ #}
        <div class="tab-pane fade" id="recommendations" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3" style="color: #2E7D32;">
                        <i class="fas fa-lightbulb me-2"></i>Personalized Recommendations
                    </h5>
                    <hr class="my-2 mb-4" style="border-color: #50C878;">

                    {% if result.recommendedContent %}
                        <div class="p-3 mb-4" style="background: #F8F9FA; border-radius: 10px;">
                            <p class="text-muted" style="line-height: 1.8; white-space: pre-line;">
                                {{ result.recommendedContent }}
                            </p>
                        </div>
                    {% endif %}

                    {# YouTube Videos #}
                    <h6 class="fw-bold mt-3 mb-3">
                        <i class="fab fa-youtube me-2" style="color: #FF0000;"></i>
                        Recommended Videos
                    </h6>

                    {% if videos is defined and videos|length > 0 %}
                        <div class="row g-3">
                            {% for video in videos|slice(0, 3) %}
                            <div class="col-md-4">
                                <a href="{{ video.watchUrl }}" target="_blank"
                                   class="text-decoration-none">
                                    <div class="card border-0 shadow-sm h-100">
                                        <div class="position-relative">
                                            <img src="{{ video.thumbnail ?: 'https://i.ytimg.com/vi/' ~ video.videoId ~ '/mqdefault.jpg' }}"
                                                 class="card-img-top"
                                                 alt="{{ video.title }}"
                                                 style="height: 150px; object-fit: cover;
                                                        border-radius: 10px 10px 0 0;">
                                            <div class="position-absolute top-50 start-50 translate-middle">
                                                <i class="fab fa-youtube fa-3x text-white"
                                                   style="text-shadow: 0 0 10px rgba(0,0,0,0.5);"></i>
                                            </div>
                                        </div>
                                        <div class="card-body p-2">
                                            <p class="small fw-bold mb-0 text-dark">
                                                {{ video.title|slice(0, 50) }}...
                                            </p>
                                            <small class="text-muted">{{ video.channelTitle }}</small>
                                        </div>
                                    </div>
                                </a>
                            </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-center py-4">
                            <i class="fab fa-youtube fa-3x mb-2" style="color: #FF0000;"></i>
                            <p class="text-muted">No video recommendations available.</p>
                        </div>
                    {% endif %}

                    <div class="alert alert-info mt-3 small">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Disclaimer:</strong> This analysis is for informational purposes
                        only and is not a clinical diagnosis. Please consult a qualified mental
                        health professional.
                    </div>
                </div>
            </div>
        </div>

        {# ══ MEDITATION TAB ══ #}
        <div class="tab-pane fade" id="meditation" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    <h5 class="fw-bold mb-1" style="color: #2E7D32;">
                        <i class="fas fa-spa me-2"></i>Guided Meditation Sessions
                    </h5>
                    <p class="text-muted mb-4">
                        Personalized sessions based on your {{ result.riskLevel }} risk level
                    </p>

                    {# Active video embed #}
                    <div id="meditationEmbed" class="mb-4 rounded-4 overflow-hidden"
                         style="display: none; background: #000;">
                        <div class="d-flex justify-content-between align-items-center p-3"
                             style="background: #1a3c34;">
                            <span id="activeSessionTitle" class="text-white fw-semibold"></span>
                            <button onclick="closeMeditationEmbed()"
                                    class="btn btn-sm btn-outline-light rounded-pill px-3">
                                <i class="fas fa-times me-1"></i>Close
                            </button>
                        </div>
                        <iframe id="meditationIframe"
                                width="100%"
                                height="315"
                                src=""
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write;
                                       encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen>
                        </iframe>
                    </div>

                    {% if meditations is defined and meditations|length > 0 %}
                        <div class="row g-4">
                            {% for session in meditations %}
                            <div class="col-md-6">
                                <div class="card border-0 rounded-4 h-100 shadow-sm"
                                     style="overflow: hidden; transition: all 0.3s ease;">

                                    <div class="p-3 text-white"
                                         style="background: linear-gradient(135deg,
                                                {{ session.color }}, {{ session.color }}cc);">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <span class="badge rounded-pill mb-2"
                                                      style="background: rgba(255,255,255,0.25);
                                                             font-size: 11px;">
                                                    {{ session.type }}
                                                </span>
                                                <h6 class="fw-bold mb-0">{{ session.title }}</h6>
                                            </div>
                                            <i class="fas {{ session.icon }} fa-2x"
                                               style="opacity: 0.6;"></i>
                                        </div>
                                        <div class="d-flex gap-3 mt-2">
                                            <small>
                                                <i class="fas fa-clock me-1"></i>{{ session.duration }}
                                            </small>
                                            <small>
                                                <i class="fas fa-signal me-1"></i>{{ session.difficulty }}
                                            </small>
                                        </div>
                                    </div>

                                    <div class="card-body p-3">
                                        <p class="text-muted small mb-3">{{ session.description }}</p>

                                        <div class="accordion accordion-flush mb-3"
                                             id="steps{{ loop.index }}">
                                            <div class="accordion-item border-0 rounded-3"
                                                 style="background: #f8f9fa;">
                                                <h2 class="accordion-header">
                                                    <button class="accordion-button collapsed py-2 px-3 rounded-3"
                                                            type="button"
                                                            data-bs-toggle="collapse"
                                                            data-bs-target="#stepsBody{{ loop.index }}"
                                                            style="background: #f8f9fa;
                                                                   font-size: 13px;
                                                                   font-weight: 600;">
                                                        <i class="fas fa-list-ol me-2"
                                                           style="color: {{ session.color }};"></i>
                                                        View Steps ({{ session.steps|length }})
                                                    </button>
                                                </h2>
                                                <div id="stepsBody{{ loop.index }}"
                                                     class="accordion-collapse collapse">
                                                    <div class="accordion-body py-2 px-3">
                                                        <ol class="mb-0 ps-3">
                                                            {% for step in session.steps %}
                                                                <li class="small text-muted mb-1">
                                                                    {{ step }}
                                                                </li>
                                                            {% endfor %}
                                                        </ol>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <button onclick="playMeditation('{{ session.youtubeId }}', '{{ session.title }}')"
                                                class="btn w-100 rounded-pill py-2 text-white fw-semibold"
                                                style="background: {{ session.color }};
                                                       border: none; font-size: 14px;">
                                            <i class="fab fa-youtube me-2"></i>Start Session
                                        </button>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>

                        <div class="mt-4 p-3 rounded-3"
                             style="background: #f0faf4; border: 1px solid #c8dcd2;">
                            <div class="d-flex align-items-center gap-3">
                                <i class="fas fa-clock fa-2x" style="color: #50C878;"></i>
                                <div>
                                    <div class="fw-semibold" style="color: #2E7D32;">
                                        Recommended Daily Practice
                                    </div>
                                    <small class="text-muted">
                                        Even 5 minutes of daily meditation can significantly
                                        reduce stress and anxiety over time.
                                    </small>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <i class="fas fa-spa fa-3x mb-3" style="color: #50C878;"></i>
                            <p class="text-muted">No sessions available for your current results.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ══ SPOTIFY TAB ══ #}
        <div class="tab-pane fade" id="spotify" role="tabpanel">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    <div class="d-flex align-items-center mb-4">
                        <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                             style="width: 50px; height: 50px; background: #1DB954;">
                            <i class="fab fa-spotify fa-xl text-white"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">Music Therapy Recommendations</h5>
                            <small class="text-muted">
                                Curated playlists based on your assessment results
                            </small>
                        </div>
                    </div>

                    {# Spotify Embed #}
                    <div id="spotifyEmbed" class="mb-4 rounded-4 overflow-hidden"
                         style="display: none;">
                        <iframe id="spotifyIframe"
                                style="border-radius: 12px;"
                                src=""
                                width="100%"
                                height="152"
                                frameborder="0"
                                allowfullscreen=""
                                allow="autoplay; clipboard-write; encrypted-media;
                                       fullscreen; picture-in-picture"
                                loading="lazy">
                        </iframe>
                    </div>

