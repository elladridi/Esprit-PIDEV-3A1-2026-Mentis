{% extends 'base.html.twig' %}

{% block title %}Progress Dashboard - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    {# Back Button #}
    <div class="mb-4" data-aos="fade-right">
        <a href="{{ path('result_index') }}" class="text-decoration-none" style="color: #50C878;">
            <i class="fas fa-arrow-left me-2"></i> Back to Results
        </a>
    </div>

    {# Header #}
    <div class="text-center mb-5" data-aos="fade-up">
        {% if user is defined and user %}
            <h6 class="text-muted mb-2">
                <i class="fas fa-user-circle me-1"></i>{{ user.fullName }} — {{ user.type }}
            </h6>
        {% endif %}
        <h1 class="display-4 fw-bold mb-3" style="color: #2E7D32;">
            <i class="fas fa-chart-line me-2"></i>Progress Dashboard
        </h1>
        <p class="lead text-muted">Track your mental health journey over time</p>
    </div>

    {% if stats.totalAssessments == 0 %}
        {# No Data State #}
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center py-5" data-aos="fade-up">
                <div class="card shadow-sm border-0 p-5" style="background: linear-gradient(135deg, #F1F8E9, #E8F5E8);">
                    <i class="fas fa-chart-line fa-4x mb-3" style="color: #50C878;"></i>
                    <h3 class="text-muted mb-3">No assessments taken yet</h3>
                    <p class="text-muted mb-4">Start your journey by taking your first assessment</p>
                    <a href="{{ path('take_assessment_index') }}" class="btn btn-primary-custom rounded-pill px-5 py-2">
                        <i class="fas fa-play me-2"></i>Take First Assessment
                    </a>
                </div>
            </div>
        </div>
    {% else %}
        {# 🔥 STAT CARDS #}
        <div class="row g-4 mb-5" data-aos="fade-up" data-aos-delay="100">
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm h-100 text-center p-4" style="background: linear-gradient(135deg, #F1F8E9, #E8F5E8);">
                    <i class="fas fa-clipboard-list fa-3x mb-3" style="color: #50C878;"></i>
                    <div class="h3 fw-bold mb-1" style="color: #2E7D32;">{{ stats.totalAssessments }}</div>
                    <small class="text-muted text-uppercase fw-semibold">Assessments Taken</small>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm h-100 text-center p-4" style="background: linear-gradient(135deg, #E3F2FD, #BBDEFB);">
                    <i class="fas fa-calculator fa-3x mb-3" style="color: #2196F3;"></i>
                    <div class="h3 fw-bold mb-1" style="color: #1976D2;">{{ stats.averageScore|number_format(1) }}</div>
                    <small class="text-muted text-uppercase fw-semibold">Average Score</small>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm h-100 text-center p-4" 
                     style="{% if stats.latestScore > stats.averageScore %}background: linear-gradient(135deg, #FFEBEE, #FFCDD2);{% else %}background: linear-gradient(135deg, #E8F5E8, #C8E6C9);{% endif %}">
                    <i class="fas {% if stats.latestScore > stats.averageScore %}fas fa-arrow-up{% else %}fas fa-arrow-down{% endif %} fa-3x mb-3" 
                       style="color: {{ stats.latestScore > stats.averageScore ? '#D32F2F' : '#388E3C' }};"></i>
                    <div class="h3 fw-bold mb-1" style="color: {{ stats.latestScore > stats.averageScore ? '#D32F2F' : '#388E3C' }};">
                        {{ stats.latestScore }}
                    </div>
                    <small class="text-muted text-uppercase fw-semibold">Latest Score</small>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card border-0 shadow-sm h-100 text-center p-4" style="background: linear-gradient(135deg, #FFEBEE, #FFCDD2);">
                    <i class="fas fa-exclamation-triangle fa-3x mb-3" style="color: #D32F2F;"></i>
                    <div class="h3 fw-bold mb-1" style="color: #D32F2F;">{{ stats.highRiskCount }}</div>
                    <small class="text-muted text-uppercase fw-semibold">High Risk Assessments</small>
                </div>
            </div>
        </div>

        <div class="row g-4">
            {# 📊 SCORE CHART #}
            <div class="col-lg-8" data-aos="fade-up" data-aos-delay="200">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="card-title mb-0 fw-bold" style="color: #2E7D32;">
                                <i class="fas fa-chart-line me-2"></i>Score Over Time
                            </h5>
                            <small class="text-muted">{{ chartData|length }} assessments</small>
                        </div>
                        {% if chartData|length > 0 %}
                            <div style="position: relative; height: 350px;">
                                <canvas id="scoreChart"></canvas>
                            </div>
                        {% else %}
                            <div class="text-center py-5">
                                <i class="fas fa-chart-line fa-3x text-muted mb-3"></i>
                                <p class="text-muted">Not enough data for chart</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            {# 🎯 RISK BREAKDOWN #}
            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="300">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-4 fw-bold" style="color: #2E7D32;">
                            <i class="fas fa-shield-alt me-2"></i>Risk Breakdown
                        </h5>
                        <div class="d-flex flex-column gap-3">
                            {% set riskColors = {
                                'Low':      ['#E8F5E8', '#4CAF50'],
                                'Minimal':  ['#E8F5E8', '#81C784'],
                                'Mild':     ['#FFF3E0', '#FF9800'],
                                'Moderate': ['#FFEBEE', '#F44336'],
                                'High':     ['#FFCDD2', '#D32F2F'],
                                'Severe':   ['#FFCDD2', '#B71C1C']
                            } %}
                            {% for level, count in riskBreakdown %}
                                {% set colors = riskColors[level] ?? ['#F5F5F5', '#9E9E9E'] %}
                                {% set pct = ((count / stats.totalAssessments) * 100)|round(1) %}
                                <div class="d-flex align-items-center p-3 rounded-3" 
                                     style="background: {{ colors[0] }}; border-left: 4px solid {{ colors[1] }};">
                                    <div class="flex-grow-1">
                                        <div class="fw-bold small text-dark">{{ level }}</div>
                                        <div class="small text-muted">{{ count }} assessments ({{ pct }}%)</div>
                                    </div>
                                    <div class="progress" style="width: 60px; height: 6px;">
                                        <div class="progress-bar" style="width: {{ pct }}%; background: {{ colors[1] }};"></div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# 📋 RECENT RESULTS #}
        <div class="row mt-4">
            <div class="col-12" data-aos="fade-up" data-aos-delay="400">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="card-title mb-0 fw-bold" style="color: #2E7D32;">
                                <i class="fas fa-history me-2"></i>Recent Assessments ({{ results|length }})
                            </h5>
                            <a href="{{ path('result_index') }}" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                View All
                            </a>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Assessment</th>
                                        <th class="text-center">Score</th>
                                        <th class="text-center">Risk</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for result in results|slice(0, 8) %}
                                    <tr>
                                        <td>
                                            <strong class="d-block">{{ result.assessment ? result.assessment.title : 'N/A' }}</strong>
                                            <small class="text-muted">{{ result.assessment ? result.assessment.type : '' }}</small>
                                        </td>
                                        <td class="text-center">
                                            <span class="fw-bold h6 mb-0" style="color: #2E7D32;">{{ result.totalScore }}</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge rounded-pill px-3 py-2 fw-semibold
                                                {% if result.riskLevel in ['High', 'Severe'] %}bg-danger
                                                {% elseif result.riskLevel in ['Moderate', 'Mild'] %}bg-warning text-dark
                                                {% else %}bg-success{% endif %}">
                                                {{ result.riskLevel }}
                                            </span>
                                        </td>
                                        <td>
                                            <small class="text-muted">{{ result.takenAt ? result.takenAt|date('MMM dd, yyyy') : 'N/A' }}</small>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="{{ path('result_show', {id: result.resultId}) }}" 
                                                   class="btn btn-outline-primary rounded-pill px-3">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="{{ path('result_export_pdf', {id: result.resultId}) }}" 
                                                   class="btn btn-outline-danger rounded-pill px-3">
                                                    <i class="fas fa-file-pdf"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# 🎮 ACTION BUTTONS #}
        <div class="text-center mt-5" data-aos="fade-up" data-aos-delay="500">
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a href="{{ path('take_assessment_index') }}" class="btn btn-primary-custom rounded-pill px-5 py-3">
                    <i class="fas fa-play-circle me-2"></i>Take New Assessment
                </a>
                <a href="{{ path('result_index') }}" class="btn btn-outline-secondary rounded-pill px-5 py-3">
                    <i class="fas fa-list me-2"></i>All Results
                </a>
                {% if results|first %}
                    <a href="{{ path('result_export_pdf', {id: results|first.resultId}) }}" 
                       class="btn btn-outline-danger rounded-pill px-4 py-3">
                        <i class="fas fa-file-pdf me-2"></i>Export Latest PDF
                    </a>
                {% endif %}
            </div>
        </div>
    {% endif %}
</div>

{# Chart.js #}
{% if chartData|length > 0 %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
<script>
const chartData = {{ chartData|json_encode|raw }};

const ctx = document.getElementById('scoreChart')?.getContext('2d');
if (ctx && chartData.length > 0) {
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: chartData.map(d => new Date(d.date)),
            datasets: [{
                label: 'Score',
                data: chartData.map(d => d.score),
                borderColor: '#50C878',
                backgroundColor: 'rgba(80, 200, 120, 0.1)',
                borderWidth: 3,
                pointBackgroundColor: '#50C878',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 6,
                pointHoverRadius: 8,
                tension: 0.4,
                fill: true,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        title: function(context) {
                            return `Assessment: ${chartData[context[0].dataIndex].assessment}`;
                        },
                        afterLabel: function(context) {
                            return `Risk: ${chartData[context.dataIndex].risk}`;
                        }
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: 'rgba(0,0,0,0.05)' },
                    ticks: { 
                        color: '#6c757d',
                        font: { size: 12, weight: '500' },
                        callback: function(value) { return value + '%'; }
                    }
                },
                x: {
                    grid: { display: false },
                    ticks: { 
                        color: '#6c757d',
                        font: { size: 11 }
                    }
                }
            },
            interaction: {
                intersect: false,
                mode: 'index'
            }
        }
    });
}
</script>
{% endif %}
{% endblock %}

{% block stylesheets %}
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<style>
.btn-primary-custom {
    background: linear-gradient(135deg, #50C878 0%, #3A9B5E 100%);
    border: none;
    color: white;
    transition: all 0.3s ease;
    font-weight: 600;
}
.btn-primary-custom:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(80, 200, 120, 0.4);
    color: white !important;
}
.card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-radius: 20px;
}
.card:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.12) !important;
}
.progress {
    border-radius: 10px;
    height: 8px;
    background: #e9ecef;
}
.progress-bar {
    border-radius: 10px;
    transition: width 0.6s ease;
}
.table-hover tbody tr:hover {
    background-color: rgba(80, 200, 120, 0.05);
}
</style>
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>AOS.init({ duration: 1000, once: true });</script>
{% endblock %}