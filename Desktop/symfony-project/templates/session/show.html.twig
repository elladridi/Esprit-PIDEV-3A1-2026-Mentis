{% extends 'base.html.twig' %}

{% block title %}{{ session.title }} - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    {# Back Button #}
    <div class="mb-4">
        <a href="{{ path('session_index') }}" 
           class="text-decoration-none d-inline-flex align-items-center" style="color: #50C878;">
            <i class="fas fa-arrow-left me-2"></i> Back to Sessions
        </a>
    </div>

    <div class="row g-5">
        {# Left Panel - Details #}
        <div class="col-lg-8" data-aos="fade-up">
            <div class="card shadow-lg border-0 rounded-4 h-100 overflow-hidden">
                {# Header #}
                <div class="card-header bg-gradient text-white py-5 px-5 position-relative overflow-hidden" 
                     style="background: linear-gradient(135deg, #2E7D32 0%, #50C878 100%);">
                    <div class="position-absolute top-0 end-0 p-3">
                        <span class="badge rounded-pill px-4 py-2 fw-semibold fs-6
                            {% if session.status == 'active' %}bg-success
                            {% elseif session.status == 'scheduled' %}bg-info text-dark
                            {% elseif session.status == 'completed' %}bg-secondary
                            {% elseif session.status == 'cancelled' %}bg-danger
                            {% else %}bg-warning text-dark{% endif %}">
                            {{ session.status }}
                        </span>
                    </div>
                    <div class="row align-items-center">
                        <div class="col-md-3 text-center">
                            <div class="rounded-circle bg-white d-flex align-items-center justify-content-center shadow-lg" 
                                 style="width: 140px; height: 140px; font-size: 48px; color: #50C878; margin: 0 auto;">
                                <i class="fas fa-users"></i>
                            </div>
                        </div>
                        <div class="col-md-9">
                            <h1 class="display-4 fw-bold mb-2" style="color: white; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">
                                {{ session.title }}
                            </h1>
                            <h4 class="mb-1" style="color: rgba(255,255,255,0.95);">
                                <i class="fas fa-tag me-2"></i>{{ session.sessionType }} Session
                            </h4>
                            <p class="lead mb-0" style="color: rgba(255,255,255,0.85);">
                                <i class="fas fa-map-marker-alt me-2"></i>{{ session.location }}
                            </p>
                        </div>
                    </div>
                </div>

                <div class="card-body p-5">
                    {# Stats Row #}
                    <div class="row g-4 mb-5">
                        <div class="col-md-3 text-center">
                            <div class="h3 fw-bold mb-1" style="color: #50C878;">{{ session.sessionDate|date('M d, Y') }}</div>
                            <small class="text-muted text-uppercase fw-semibold">Date</small>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="h3 fw-bold mb-1" style="color: #2E7D32;">{{ session.startTime|date('H:i') }} - {{ session.endTime|date('H:i') }}</div>
                            <small class="text-muted text-uppercase fw-semibold">Time</small>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="h3 fw-bold mb-1" style="color: #28a745;">{{ session.currentParticipants }}/{{ session.maxParticipants }}</div>
                            <small class="text-muted text-uppercase fw-semibold">Participants</small>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="h3 fw-bold mb-1" style="color: #17a2b8;">${{ session.price }}</div>
                            <small class="text-muted text-uppercase fw-semibold">Price</small>
                        </div>
                    </div>

                    {# Category & Popularity #}
                    <div class="row g-3 mb-5">
                        <div class="col-md-6">
                            <div class="card border-0 bg-light rounded-3 p-3">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-tags fa-2x me-3" style="color: #50C878;"></i>
                                    <div>
                                        <small class="text-muted text-uppercase fw-semibold">Category</small>
                                        <div class="fw-bold">{{ session.category|default('General') }}</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 bg-light rounded-3 p-3">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-chart-line fa-2x me-3" style="color: #f39c12;"></i>
                                    <div>
                                        <small class="text-muted text-uppercase fw-semibold">Popularity</small>
                                        <div class="fw-bold">{{ session.popularity }} bookings</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Quick Actions #}
                    <div class="row g-3 mb-5">
                        <div class="col-md-3">
                            <form method="post" action="{{ path('session_reserve', {id: session.sessionId}) }}">
                                <input type="hidden" name="patientId" value="{{ app.user.id ?? 1 }}">
                                <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill py-3 {% if session.reservedBy is not null %}disabled{% endif %}">
                                    {% if session.reservedBy is null %}
                                        <i class="fas fa-calendar-check me-2"></i>Reserve Now
                                    {% else %}
                                        <i class="fas fa-lock me-2"></i>Already Reserved
                                    {% endif %}
                                </button>
                            </form>
                        </div>
                        <div class="col-md-3">
                            <a href="{{ path('session_edit', {id: session.sessionId}) }}" 
                               class="btn btn-outline-primary btn-lg w-100 rounded-pill py-3">
                                <i class="fas fa-edit me-2"></i>Edit Details
                            </a>
                        </div>
                        <div class="col-md-3">
                            <form method="post" action="{{ path('session_toggle_status', {id: session.sessionId}) }}" 
                                  style="display: contents;">
                                <button type="submit" class="btn btn-outline-warning btn-lg w-100 rounded-pill py-3">
                                    <i class="fas fa-toggle-{{ session.status == 'active' ? 'off' : 'on' }} me-2"></i>
                                    {{ session.status == 'active' ? 'Deactivate' : 'Activate' }}
                                </button>
                            </form>
                        </div>
                        <div class="col-md-3">
                            {% if session.reservedBy is not null %}
                            <form method="post" action="{{ path('session_cancel_reservation', {id: session.sessionId}) }}">
                                <input type="hidden" name="patientId" value="{{ session.reservedBy }}">
                                <button type="submit" class="btn btn-outline-danger btn-lg w-100 rounded-pill py-3">
                                    <i class="fas fa-times-circle me-2"></i>Cancel Reservation
                                </button>
                            </form>
                            {% endif %}
                        </div>
                    </div>

                    {# Danger Zone #}
                    <div class="card border-0 bg-danger-subtle rounded-3 p-4 mt-5">
                        <div class="row align-items-center">
                            <div class="col-md-2 text-center">
                                <i class="fas fa-exclamation-triangle fa-3x text-danger"></i>
                            </div>
                            <div class="col-md-7">
                                <h5 class="fw-bold mb-2 text-danger">Danger Zone</h5>
                                <p class="mb-0 text-danger-emphasis">Delete this session permanently.</p>
                            </div>
                            <div class="col-md-3 text-end">
                                <form method="post" action="{{ path('session_delete', {id: session.sessionId}) }}" 
                                      onsubmit="return confirm('⚠️ PERMANENTLY DELETE this session? This cannot be undone.')" 
                                      style="display: inline;">
                                    <button type="submit" class="btn btn-danger rounded-pill px-4 py-2">
                                        <i class="fas fa-trash me-1"></i>Delete Forever
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Right Panel - Reservation Info #}
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
            <div class="card shadow-lg border-0 h-100 rounded-4 overflow-hidden">
                <div class="card-header bg-light border-0 py-4 px-4">
                    <h5 class="mb-0 fw-bold" style="color: #2E7D32;">
                        <i class="fas fa-user-check me-2"></i>Reservation Status
                    </h5>
                </div>
                <div class="card-body p-4">
                    {% if session.reservedBy %}
                        <div class="text-center mb-4">
                            <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;">
                                <i class="fas fa-user-circle fa-3x text-success"></i>
                            </div>
                            <h5 class="mb-1">Reserved</h5>
                            <small class="text-muted">Patient ID: {{ session.reservedBy }}</small>
                            <div class="mt-2 small text-muted">
                                <i class="fas fa-clock me-1"></i>Reserved at: {{ session.reservedAt ? session.reservedAt|date('M d, H:i') : 'N/A' }}
                            </div>
                        </div>

                        {% if session.sessionType == 'Online' and session.meetingLink %}
                            <hr>
                            <div class="text-center mt-3">
                                <a href="{{ session.meetingLink }}" target="_blank" class="btn btn-info btn-lg w-100 rounded-pill py-3">
                                    <i class="fas fa-video me-2"></i>Join Video Call
                                </a>
                                <small class="text-muted d-block mt-2">Available 15min before session start</small>
                            </div>
                        {% endif %}
                    {% else %}
                        <div class="text-center py-4">
                            <i class="fas fa-calendar-plus fa-4x text-muted mb-3"></i>
                            <h5 class="text-muted">Available</h5>
                            <p class="text-muted small mb-0">This session is available for reservation</p>
                        </div>
                    {% endif %}

                    <hr class="my-4">

                    <div class="small text-muted">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Total Spots:</span>
                            <span class="fw-bold">{{ session.maxParticipants }}</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Remaining Spots:</span>
                            <span class="fw-bold text-success">{{ session.maxParticipants - session.currentParticipants }}</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>Price per person:</span>
                            <span class="fw-bold">${{ session.price }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<style>
.btn-primary-custom {
    background: linear-gradient(135deg, #50C878 0%, #3A9B5E 100%);
    border: none;
    color: white;
    transition: all 0.3s ease;
    font-weight: 600;
}
.btn-primary-custom:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(80, 200, 120, 0.4);
    color: white !important;
}
.bg-gradient {
    position: relative;
}
.bg-gradient::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(46,125,50,0.1) 0%, rgba(80,200,120,0.2) 100%);
    z-index: 1;
}
.card {
    border-radius: 28px;
}
.btn-lg {
    font-size: 15px;
}
</style>
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>AOS.init({ duration: 1000, once: true });</script>
{% endblock %}