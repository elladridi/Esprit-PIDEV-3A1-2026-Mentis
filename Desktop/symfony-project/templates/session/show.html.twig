            {# Reservation Status Card #}
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-light border-0 py-4 px-4"><h5 class="mb-0 fw-bold" style="color: #2E7D32;"><i class="fas fa-user-check me-2"></i>{{ trans.reservation_status }}</h5></div>
                <div class="card-body p-4">
                    {% if session.reservedBy %}
                        <div class="text-center mb-4">
                            <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;"><i class="fas fa-user-circle fa-3x text-success"></i></div>
                            <h5 class="mb-1">{{ trans.reserved }}</h5>
                            <small class="text-muted">Patient ID: {{ session.reservedBy }}</small>
                            <div class="mt-2 small text-muted"><i class="fas fa-clock me-1"></i>{{ trans.reserved }} at: {{ session.reservedAt ? session.reservedAt|date('M d, H:i') : 'N/A' }}</div>
                        </div>
                    {% else %}
                        <div class="text-center py-4"><i class="fas fa-calendar-plus fa-4x text-muted mb-3"></i><h5 class="text-muted">{{ trans.available }}</h5><p class="text-muted small mb-0">This session is available for reservation</p></div>
                    {% endif %}
                    <hr class="my-4">
                    <div class="small text-muted">
                        <div class="d-flex justify-content-between mb-2"><span>Total Spots:</span><span class="fw-bold">{{ session.maxParticipants }}</span></div>
                        <div class="d-flex justify-content-between mb-2"><span>Remaining Spots:</span><span class="fw-bold text-success">{{ session.maxParticipants - session.currentParticipants }}</span></div>
                        <div class="d-flex justify-content-between"><span>Price per person:</span><span class="fw-bold">${{ session.price }}</span></div>
                    </div>
                </div>
            </div>

            {# Video Meeting Card - RIGHT BELOW RESERVATION STATUS #}
            {% if session.reservedBy and session.reservedBy == app.user.id %}
                <div class="card shadow-lg border-0 rounded-4 mt-4">
                    <div class="card-header bg-light border-0 py-3 px-4"><h5 class="mb-0 fw-bold text-primary"><i class="fas fa-video me-2"></i>{{ trans.video_meeting }}</h5></div>
                    <div class="card-body p-4">
                        {% if session.meetingLink %}
                            <div class="text-center">
                                <div class="alert alert-success p-3 rounded-3">
                                    <i class="fas fa-check-circle fa-2x text-success mb-2"></i>
                                    <h6 class="mb-2">{{ trans.meeting_ready }}</h6>
                                    <p class="small text-muted mb-3">{{ trans.created }}: {{ session.meetingCreatedAt|date('d/m/Y H:i') }}</p>
                                    <div class="d-flex flex-column gap-2">
                                        <a href="{{ path('session_join_meeting', {id: session.sessionId}) }}" target="_blank" class="btn btn-primary rounded-pill px-4"><i class="fas fa-video me-2"></i>{{ trans.join_meeting }}</a>
                                        <button onclick="copyMeetingLink('{{ trans.link_copied|e('js') }}', '{{ trans.copy_failed|e('js') }}', '{{ trans.no_link|e('js') }}')" class="btn btn-outline-secondary rounded-pill px-4"><i class="fas fa-copy me-2"></i>{{ trans.copy_link }}</button>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="text-center">
                                <div class="alert alert-info p-3 rounded-3">
                                    <i class="fas fa-info-circle fa-2x text-info mb-2"></i>
                                    <h6 class="mb-2">{{ trans.no_meeting }}</h6>
                                    <form method="post" action="{{ path('session_create_meeting', {id: session.sessionId}) }}" class="mt-3"><button type="submit" class="btn btn-success rounded-pill px-4"><i class="fas fa-plus-circle me-2"></i>{{ trans.create_meeting }}</button></form>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% elseif session.meetingLink %}
                <div class="card shadow-lg border-0 rounded-4 mt-4">
                    <div class="card-header bg-light border-0 py-3 px-4"><h5 class="mb-0 fw-bold text-primary"><i class="fas fa-video me-2"></i>{{ trans.video_meeting }}</h5></div>
                    <div class="card-body p-4">
                        <div class="text-center"><div class="alert alert-success p-3 rounded-3"><i class="fas fa-video fa-2x text-success mb-2"></i><h6 class="mb-2">{{ trans.meeting_ready }}</h6><a href="{{ path('session_join_meeting', {id: session.sessionId}) }}" target="_blank" class="btn btn-primary rounded-pill px-4 mt-3"><i class="fas fa-video me-2"></i>{{ trans.join_meeting }}</a></div></div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

