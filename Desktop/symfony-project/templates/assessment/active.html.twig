{% extends 'base.html.twig' %}

{% block title %}Active Assessments - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    {# Header #}
    <div class="d-flex justify-content-between align-items-center mb-5" data-aos="fade-up">
        <div>
            <h1 class="display-5 fw-bold mb-2" style="color: #2E7D32;">
                <i class="fas fa-play-circle me-2"></i>Active Assessments
            </h1>
            <p class="text-muted mb-0">{{ assessments|length }} assessments available</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('assessment_index') }}" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="fas fa-list me-2"></i>All Assessments
            </a>
            <a href="{{ path('assessment_new') }}" class="btn btn-primary-custom rounded-pill px-4">
                <i class="fas fa-plus me-2"></i>Add New
            </a>
        </div>
    </div>

    {# Flash Messages #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show rounded-pill mb-4 d-flex align-items-center" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show rounded-pill mb-4 d-flex align-items-center" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% if assessments is empty %}
        <div class="text-center py-5" data-aos="fade-up">
            <div class="card shadow-sm border-0 p-5 rounded-4" style="background: linear-gradient(135deg, #F1F8E9, #E8F5E8); max-width: 500px; margin: 0 auto;">
                <i class="fas fa-clipboard-list fa-4x mb-3" style="color: #50C878;"></i>
                <h3 class="text-muted mb-3">No Active Assessments</h3>
                <p class="text-muted mb-4">Create your first assessment or activate existing ones</p>
                <a href="{{ path('assessment_new') }}" class="btn btn-primary-custom rounded-pill px-5 py-2">
                    <i class="fas fa-plus me-2"></i>Create Assessment
                </a>
            </div>
        </div>
    {% else %}
        <div class="card shadow-sm border-0" data-aos="fade-up">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 rounded-4 overflow-hidden">
                        <thead class="table-light">
                            <tr>
                                <th class="border-0 py-4 px-4 fw-bold" style="color: #2E7D32; font-size: 15px;">Title</th>
                                <th class="border-0 py-4 px-3 fw-bold text-center" style="color: #2E7D32; font-size: 15px;">Type</th>
                                <th class="border-0 py-4 px-3 fw-bold" style="color: #2E7D32; font-size: 15px;">Description</th>
                                <th class="border-0 py-4 px-3 fw-bold text-center" style="color: #2E7D32; font-size: 15px;">Questions</th>
                                <th class="border-0 py-4 px-3 fw-bold text-end" style="color: #2E7D32; font-size: 15px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for assessment in assessments %}
                            <tr class="align-middle">
                                <td class="py-4 px-4 fw-semibold" style="color: #1a3c34;">
                                    {{ assessment.title }}
                                </td>
                                <td class="py-4 px-3 text-center">
                                    <span class="badge rounded-pill px-3 py-2 fw-semibold" 
                                          style="background: 
                                              {% if assessment.type == 'Depression' %}linear-gradient(135deg, #9b59b6, #8e44ad);
                                              {% elseif assessment.type == 'Anxiety' %}linear-gradient(135deg, #e74c3c, #c0392b);
                                              {% elseif assessment.type == 'Stress' %}linear-gradient(135deg, #f39c12, #e67e22);
                                              {% elseif assessment.type == 'Wellness' %}linear-gradient(135deg, #27ae60, #2ecc71);
                                              {% else %}linear-gradient(135deg, #3498db, #2980b9);{% endif %}
                                              color: white;">
                                        {{ assessment.type }}
                                    </span>
                                </td>
                                <td class="py-4 px-3" style="color: #6c757d; font-size: 14px;">
                                    {{ assessment.description ? assessment.description|slice(0, 60) ~ (assessment.description|length > 60 ? '...' : '') : '<em>No description</em>'|raw }}
                                </td>
                                <td class="py-4 px-3 text-center fw-bold h6 mb-0" style="color: #50C878;">
                                    {{ assessment.questions|length }}
                                </td>
                                <td class="py-4 px-3 text-end">
                                    <div class="btn-group" role="group">
                                        <a href="{{ path('take_assessment_start', {id: assessment.assessmentId}) }}" 
                                           class="btn btn-success btn-sm rounded-pill px-4">
                                            <i class="fas fa-play me-1"></i>Test
                                        </a>
                                        <a href="{{ path('assessment_show', {id: assessment.assessmentId}) }}" 
                                           class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                            <i class="fas fa-cog"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        {# Summary #}
        <div class="text-center mt-4" data-aos="fade-up">
            <small class="text-muted">
                Showing {{ assessments|length }} active assessment{{ assessments|length|default(0) != 1 ? 's' : '' }}
            </small>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block stylesheets %}
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<style>
.btn-primary-custom {
    background: linear-gradient(135deg, #50C878 0%, #3A9B5E 100%);
    border: none;
    color: white;
    transition: all 0.3s ease;
    font-weight: 600;
}
.btn-primary-custom:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(80, 200, 120, 0.4);
    color: white !important;
}
.table-hover tbody tr:hover {
    background-color: rgba(80, 200, 120, 0.08);
}
.card {
    border-radius: 24px;
}
</style>
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>AOS.init({ duration: 800 });</script>
{% endblock %}