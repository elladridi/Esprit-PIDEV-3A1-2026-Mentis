{% extends 'base.html.twig' %}

{% block title %}Edit {{ assessment.title }} - Mentis{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="mb-4">
        <a href="{{ path('assessment_show', {id: assessment.assessmentId}) }}"
           class="text-decoration-none d-inline-flex align-items-center" style="color: #50C878;">
            <i class="fas fa-arrow-left me-2"></i> Back to Assessment
        </a>
    </div>

    <div class="text-center mb-5" data-aos="fade-up">
        <h1 class="display-5 fw-bold mb-3" style="color: #2E7D32;">
            <i class="fas fa-edit me-2"></i>Edit Assessment
        </h1>
        <p class="lead text-muted">Update assessment details and settings</p>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show rounded-pill mb-4 d-flex align-items-center" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show rounded-pill mb-4 d-flex align-items-center" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4" data-aos="fade-up" data-aos-delay="100">
                <div class="card-body p-5">

                    {{ form_start(form, {attr: {enctype: 'multipart/form-data', novalidate: 'novalidate'}}) }}

                    {# Title #}
                    <div class="mb-4">
                        <label class="form-label fw-bold mb-2" style="color: #2E7D32;">
                            {{ form_label(form.title) }} <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.title) }}
                        {{ form_errors(form.title) }}
                    </div>

                    {# Type & Status #}
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold mb-2" style="color: #2E7D32;">
                                {{ form_label(form.type) }}
                            </label>
                            {{ form_widget(form.type) }}
                            {{ form_errors(form.type) }}
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold mb-2" style="color: #2E7D32;">
                                {{ form_label(form.status) }}
                            </label>
                            {{ form_widget(form.status) }}
                            {{ form_errors(form.status) }}
                        </div>
                    </div>

                    {# Description #}
                    <div class="mb-4">
                        <label class="form-label fw-bold mb-2" style="color: #2E7D32;">
                            {{ form_label(form.description) }}
                        </label>
                        {{ form_widget(form.description) }}
                        {{ form_errors(form.description) }}
                    </div>

                    {# Image #}
                    <div class="mb-5">
                        <label class="form-label fw-bold mb-3 d-block" style="color: #2E7D32;">
                            {{ form_label(form.imageFile) }}
                        </label>

                        {% if assessment.imagePath %}
                            <div class="mb-3 text-center">
                                <img src="{{ asset(assessment.imagePath) }}"
                                     class="rounded-4 shadow-sm mb-2 d-block mx-auto"
                                     alt="{{ assessment.title }}"
                                     style="width: 300px; height: 200px; object-fit: cover; border: 3px solid #50C878;">
                                <small class="text-muted">Current image. Upload new to replace.</small>
                            </div>
                        {% endif %}

                        {{ form_widget(form.imageFile) }}
                        {{ form_errors(form.imageFile) }}
                        <small class="text-muted d-block mt-2">Max 5MB — JPG, PNG, GIF, WebP</small>
                    </div>

                    {# Buttons #}
                    <div class="d-flex gap-3 justify-content-end">
                        <a href="{{ path('assessment_show', {id: assessment.assessmentId}) }}"
                           class="btn btn-outline-secondary rounded-pill px-5 py-2">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                        <button type="submit"
                                class="btn rounded-pill px-5 py-2 fw-bold text-white"
                                style="background: linear-gradient(135deg, #50C878 0%, #2E7D32 100%);">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
.form-control:focus, .form-select:focus {
    border-color: #50C878 !important;
    box-shadow: 0 0 0 0.25rem rgba(80, 200, 120, 0.25) !important;
}
.card { border-radius: 24px; }
</style>
{% endblock %}

{% block javascripts %}
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>AOS.init({ duration: 800 });</script>
{% endblock %}