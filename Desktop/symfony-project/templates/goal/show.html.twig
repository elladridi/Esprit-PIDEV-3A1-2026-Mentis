{% extends 'base.html.twig' %}

{% block title %}Goal Details{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header {% if goal.isCompleted %}bg-success{% else %}bg-primary{% endif %} text-white">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h1 class="mb-2">
                                {% if goal.isCompleted %}
                                    <i class="bi bi-check-circle"></i>
                                {% else %}
                                    <i class="bi bi-target"></i>
                                {% endif %}
                                {{ goal.title }}
                            </h1>
                        </div>
                        {% if goal.isCompleted %}
                            <span class="badge bg-light text-success">Completed</span>
                        {% else %}
                            <span class="badge bg-light text-primary">In Progress</span>
                        {% endif %}
                    </div>
                </div>

                <div class="card-body p-5">
                    <div class="mb-4">
                        <h5>Description</h5>
                        <p class="text-muted">{{ goal.description }}</p>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted">Deadline</h6>
                            <p class="h5">
                                <i class="bi bi-calendar-event"></i>
                                {{ goal.deadline|date('F d, Y \a\t H:i') }}
                            </p>
                            {% if not goal.isCompleted and goal.deadline < "now"|date('U')|date('Y-m-d H:i:s') %}
                                <div class="alert alert-danger alert-sm" role="alert">
                                    <small>⚠️ This goal is overdue!</small>
                                </div>
                            {% endif %}
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Created</h6>
                            <p class="h5">
                                <i class="bi bi-calendar"></i>
                                {{ goal.createdAt|date('F d, Y') }}
                            </p>
                        </div>
                    </div>

                    <div class="d-flex gap-2 pt-3 border-top">
                        <a href="{{ path('app_goal_edit', {id: goal.id}) }}" class="btn btn-secondary">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        {% if not goal.isCompleted %}
                            <form method="POST" action="{{ path('app_goal_toggle', {id: goal.id}) }}" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ goal.id) }}">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-check-circle"></i> Mark as Completed
                                </button>
                            </form>
                        {% else %}
                            <form method="POST" action="{{ path('app_goal_toggle', {id: goal.id}) }}" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ goal.id) }}">
                                <button type="submit" class="btn btn-warning">
                                    <i class="bi bi-arrow-counterclockwise"></i> Mark as Incomplete
                                </button>
                            </form>
                        {% endif %}
                        <form method="POST" action="{{ path('app_goal_delete', {id: goal.id}) }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ goal.id) }}">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure?')">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </form>
                        <a href="{{ path('app_goal_index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .alert-sm {
        padding: 0.5rem;
        margin-top: 0.5rem;
        font-size: 0.875rem;
    }
</style>
{% endblock %}
