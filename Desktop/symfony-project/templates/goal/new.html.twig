{% extends 'base.html.twig' %}

{% block title %}Create New Goal{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h1 class="mb-4">
                        <i class="bi bi-target"></i> Create New Goal
                    </h1>
                    <p class="text-muted mb-4">Set a new objective and track your progress</p>

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                    <div class="mb-4">
                        {{ form_label(form.title, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.title) }}
                        {{ form_errors(form.title) }}
                        {% if form.title.vars.help %}
                            <small class="form-text text-muted d-block mt-2">
                                {{ form.title.vars.help }}
                            </small>
                        {% endif %}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.description) }}
                        {{ form_errors(form.description) }}
                        {% if form.description.vars.help %}
                            <small class="form-text text-muted d-block mt-2">
                                {{ form.description.vars.help }}
                            </small>
                        {% endif %}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.deadline, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.deadline) }}
                        {{ form_errors(form.deadline) }}
                        {% if form.deadline.vars.help %}
                            <small class="form-text text-muted d-block mt-2">
                                {{ form.deadline.vars.help }}
                            </small>
                        {% endif %}
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-circle"></i> Create Goal
                        </button>
                        <a href="{{ path('app_goal_index') }}" class="btn btn-secondary btn-lg">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
