{% extends 'base.html.twig' %}

{% block title %}Goals - My Objectives{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-0">
                <i class="bi bi-target"></i> My Goals
            </h1>
            <p class="text-muted">Track and manage your objectives</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="{{ path('app_goal_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New Goal
            </a>
        </div>
    </div>

    {% if goals is empty %}
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i>
            <strong>No goals yet.</strong> Start setting your objectives for personal growth!
        </div>
    {% else %}
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Your Goals</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Description</th>
                                <th>Deadline</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for goal in goals %}
                                <tr>
                                    <td>{{ goal.title }}</td>
                                    <td>{{ goal.description|slice(0, 50) }}{% if goal.description|length > 50 %}...{% endif %}</td>
                                    <td>{{ goal.deadline|date('M d, Y') }}</td>
                                    <td>
                                        {% if goal.isCompleted %}
                                            <span class="badge bg-success">Completed</span>
                                        {% else %}
                                            <span class="badge bg-warning">Ongoing</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <a href="{{ path('app_goal_show', {id: goal.id}) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                        <a href="{{ path('app_goal_edit', {id: goal.id}) }}" class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form method="POST" action="{{ path('app_goal_toggle', {id: goal.id}) }}" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ goal.id) }}">
                                            <button type="submit" class="btn btn-sm {% if goal.isCompleted %}btn-outline-warning{% else %}btn-outline-success{% endif %}">
                                                <i class="bi {% if goal.isCompleted %}bi-arrow-counterclockwise{% else %}bi-check-circle{% endif %}"></i>
                                            </button>
                                        </form>
                                        <form method="POST" action="{{ path('app_goal_delete', {id: goal.id}) }}" style="display:inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ goal.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    {% endif %}
</div>

<style>
    .hover-shadow:hover {
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
    }
    .alert-sm {
        padding: 0.25rem 0.5rem;
        margin: 0;
        font-size: 0.875rem;
    }
</style>
{% endblock %}
